# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-at-least-32-chars

# Run: node scripts/set-admin-password.mjs  — then paste the output here
ADMIN_PASSWORD_HASH=

# From Vercel dashboard → Storage → Blob → your store token
BLOB_READ_WRITE_TOKEN=

# Optional: email notifications for new enquiries
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@empereal.com
SMTP_TO=info@empereal.com

# Consent-gated analytics.
# Prefer Google Tag Manager for multi-tag deployments. When both GTM and a
# direct GA4 ID are set, GTM takes precedence to prevent duplicate page views.
PUBLIC_GTM_ID=
PUBLIC_GA4_ID=
PUBLIC_META_PIXEL_ID=
PUBLIC_CLARITY_ID=

# Search, social-domain, and social-card verification metadata.
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=
PUBLIC_FACEBOOK_DOMAIN_VERIFICATION=
# Include the leading @, for example: @emperealenergy
PUBLIC_TWITTER_SITE=
