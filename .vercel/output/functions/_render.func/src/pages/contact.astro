---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/site/ContactForm.astro";
---
<BaseLayout
  title="Contact Empereal — Solar & EPC Enquiries"
  description="Get in touch with Empereal's energy experts. Request a consultation, ask about our solar, desalination, or energy storage solutions, or send us a general enquiry."
>
  <section class="section-pad bg-white">
    <div class="mx-auto max-w-5xl px-6 sm:px-10 lg:px-14">
      <div class="grid gap-12 lg:grid-cols-[1.1fr_1fr] lg:items-start">
        <!-- Left: headings + contact info -->
        <div>
          <p class="eyebrow">Get In Touch</p>
          <h1 class="fluid-h2 mt-3">Talk to our<br />energy experts</h1>
          <p class="fluid-lead mt-5 text-muted max-w-md">
            Whether you're planning a utility-scale installation or exploring solar for your facility, we're here to help you find the right solution.
          </p>

          <dl class="mt-10 space-y-5 text-sm text-muted">
            <div class="flex items-start gap-3">
              <dt class="sr-only">Address</dt>
              <svg viewBox="0 0 20 20" class="h-5 w-5 mt-0.5 text-accent shrink-0" fill="none" aria-hidden="true">
                <path d="M10 2c3.3 0 6 2.7 6 6 0 4.5-6 10-6 10S4 12.5 4 8c0-3.3 2.7-6 6-6z" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="10" cy="8" r="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
              </svg>
              <dd>Dubai, United Arab Emirates</dd>
            </div>
            <div class="flex items-start gap-3">
              <dt class="sr-only">Email</dt>
              <svg viewBox="0 0 20 20" class="h-5 w-5 mt-0.5 text-accent shrink-0" fill="none" aria-hidden="true">
                <rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
                <path d="M2 6l8 6 8-6" stroke="currentColor" stroke-width="1.5"/>
              </svg>
              <dd><a href="mailto:info@empereal.com" class="hover:text-primary transition-colors">info@empereal.com</a></dd>
            </div>
            <div class="flex items-start gap-3">
              <dt class="sr-only">Phone</dt>
              <svg viewBox="0 0 20 20" class="h-5 w-5 mt-0.5 text-accent shrink-0" fill="none" aria-hidden="true">
                <path d="M4 5c0-.5.4-1 1-1h2l1.5 3.5L7 9c.8 1.5 2 2.7 3.5 3.5L12 11l3.5 1.5V15c0 .5-.4 1-1 1C9 16 4 11 4 5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
              <dd>+971 XX XXX XXXX</dd>
            </div>
          </dl>

          <!-- WhatsApp shortcut -->
          <a
            href="https://wa.me/971501234567"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-flex items-center gap-2 rounded-lg bg-success hover:bg-success-dark px-5 py-3 text-sm font-semibold text-white transition-colors shadow-sm"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
              <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2s-.8.9-1 1.1c-.2.2-.4.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5H8c-.2 0-.5.1-.7.3-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3.2 5 4.4.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.3-.7.3-1.2.2-1.4-.1-.2-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.4c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/>
            </svg>
            Chat on WhatsApp
          </a>
        </div>

        <!-- Right: form -->
        <div class="rounded-2xl bg-slate-50 ring-1 ring-primary/10 p-6 sm:p-8">
          <h2 class="text-lg font-semibold text-ink mb-6">Send us a message</h2>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
