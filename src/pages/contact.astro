---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/primitives/Container.astro";
import ContactForm from "../components/site/ContactForm.astro";

const stats = [
  { value: "24h", label: "Response Time" },
  { value: "15+", label: "Countries Active" },
  { value: "140+", label: "Projects Delivered" },
  { value: "18+", label: "Years Experience" },
];

const contactInfo = [
  {
    title: "Global Operations – UAE",
    value: "Office 211, Arenco Building 4, Dubai Investments Park, Dubai, UAE",
    icon: `<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>`,
  },
  {
    title: "Email Address",
    value: "info@emperealenergy.com",
    href: "mailto:info@emperealenergy.com",
    icon: `<rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7" stroke="currentColor" stroke-width="1.5"/>`,
  },
  {
    title: "Phone Number",
    value: "Tel: +971 4 883 5515 · Mob: +971 56 376 2386",
    icon: `<path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    title: "Business Hours",
    value: "Saturday – Thursday | 9 am to 6 pm",
    icon: `<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  },
  {
    title: "Global Presence",
    value: "Headquarters in Singapore | Operations across Asia, the Middle East & the USA",
    icon: `<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20M2 12h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
];

interface Office {
  name: string;
  address: string;
  phone?: string;
  mobile?: string;
  hours?: string;
  tag?: string;
}

const offices: Office[] = [
  {
    name: "Empereal Singapore",
    address: "7500A Beach Road,\n#14-302 The PLAZA,\nSingapore 199591",
    hours: "Monday – Friday | 9 am to 6 pm",
    tag: "HQ",
  },
  {
    name: "Empereal UAE – Global Operations",
    address: "Office 211, Arenco Building 4,\nDubai Investments Park,\nDubai, UAE",
    phone: "+971 4 883 5515",
    mobile: "+971 56 376 2386",
    hours: "Saturday – Thursday | 9 am to 6 pm",
  },
  {
    name: "Empereal India",
    address: "366, Thudiyalur Road, KG Campus,\nSaravanampatti, Coimbatore – 641035,\nTamil Nadu, India",
    phone: "+91 422 661 9991",
    hours: "Monday – Friday | 8:30 am – 6:00 pm\nSaturday | 8:30 am – 3:00 pm\nSunday | Closed",
  },
  {
    name: "Empereal USA",
    address: "7480 Birdwood Avenue,\n#1120 McLean,\nVA 22102, USA",
    phone: "+1 973 747 7323",
    hours: "Monday – Friday | 9 am to 6 pm",
  },
];
---
<BaseLayout
  title="Contact Us | Empereal"
  description="Whether you're exploring a new project or looking for expert guidance, our team is ready to help. Reach out today and let's build high-performance clean energy solutions together."
  image="/images/footer-bg.jpg"
  imageAlt="Large-scale solar infrastructure engineered by Empereal"
>
  <!-- Hero Section -->
  <section
    class="page-hero relative isolate overflow-hidden bg-primary-dark text-white flex flex-col"
    aria-labelledby="contact-hero-title"
  >
    <div class="absolute inset-0 -z-10" aria-hidden="true">
      <div class="absolute inset-0 bg-primary-dark"></div>
      <img
        src="/images/footer-bg.jpg"
        alt=""
        class="h-full w-full object-cover opacity-35"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/85 via-primary-dark/60 to-primary-dark/20"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/65 via-transparent to-transparent"></div>
      <div class="absolute -bottom-32 -right-32 h-[520px] w-[520px] rounded-full bg-accent/15 blur-[140px] animate-pulse-glow"></div>
      <svg class="absolute inset-0 w-full h-full opacity-[0.06]" viewBox="0 0 1440 800" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <defs>
          <pattern id="contactHeroGrid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M40 0H0v40" fill="none" stroke="#fff" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="1440" height="800" fill="url(#contactHeroGrid)"/>
      </svg>
    </div>

    <Container class="relative flex-1 flex items-start pt-32 sm:items-center sm:pt-0">
      <div class="pb-16 sm:py-20 lg:py-24 max-w-3xl mx-auto text-center">
        <p class="eyebrow !text-accent hero-enter hero-enter-1">Contact Us</p>
        <h1 id="contact-hero-title" class="fluid-display mt-4 text-white hero-enter hero-enter-2">
          Get in <span class="text-accent">Touch</span>
        </h1>
        <p class="fluid-lead mt-6 text-white/85 max-w-2xl mx-auto hero-enter hero-enter-3">
          Whether you're exploring a new project or looking for expert guidance, our team is ready to help. Reach out today and let’s build high-performance clean energy solutions together.
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-3 hero-enter hero-enter-4">
          <a
            href="#form"
            class="site-cta site-cta-on-dark press"
          >
            Send Enquiry
          </a>
          <a
            href="#company-profile-download"
            data-company-profile-download
            class="site-cta site-cta-on-dark"
          >
            Download Company Profile
          </a>
        </div>

        <!-- Stats Banner -->
        <dl class="mt-12 grid grid-cols-2 lg:grid-cols-4 divide-y divide-white/10 lg:divide-y-0 lg:divide-x lg:divide-white/10 border-y border-white/10 py-5 lg:py-7 max-w-2xl mx-auto hero-enter hero-enter-4">
          {stats.map((s) => (
            <div class="px-6 py-2 flex flex-col items-center">
              <dt class="order-2 mt-1 text-[10px] uppercase tracking-[0.15em] text-white/65 font-medium text-center">{s.label}</dt>
              <dd class="order-1 font-display text-2xl sm:text-3xl font-semibold text-white">{s.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </Container>
  </section>

  <!-- Main Form Section -->
  <section id="form" class="section-pad bg-white" aria-labelledby="form-heading">
    <Container>
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <!-- Left: Contact Form -->
        <div class="bg-white rounded-2xl border border-primary/10 p-6 sm:p-8 md:p-10 shadow-card hover:shadow-card-lg transition-all duration-300 reveal">
          <h2 id="form-heading" class="text-xl sm:text-2xl font-bold text-primary-dark mb-2">Send Us a Message</h2>
          <p class="text-sm text-muted mb-8">Fill in the details below and our team will respond within 24 hours.</p>
          <ContactForm />
        </div>

        <!-- Right: Cards & Information -->
        <div class="space-y-6 reveal-stagger">
          <!-- Consultation Card -->
          <div class="bg-[#003B64] rounded-2xl p-6 sm:p-8 text-white hover:shadow-card transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center shrink-0 ring-1 ring-white/15">
                <svg viewBox="0 0 24 24" class="h-6 w-6 text-accent" fill="none" aria-hidden="true">
                  <path d="M8 2v4M16 2v4M3 9h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="min-w-0">
                <h3 class="text-base sm:text-lg font-semibold text-white">Schedule a Consultation</h3>
                <p class="text-xs sm:text-sm text-white/70 leading-relaxed mt-2">Book a free 30-minute discovery call with our energy experts to discuss your project needs.</p>
                <a
                  href="mailto:info@emperealenergy.com?subject=Consultation Request"
                  class="site-cta site-cta-on-dark mt-4"
                >
                  Book a Call
                </a>
              </div>
            </div>
          </div>

          <!-- Contact Information Card -->
          <div class="bg-surface rounded-2xl p-6 sm:p-8 border border-primary/10 hover:shadow-card transition-all duration-300">
            <h3 class="text-lg font-bold text-primary-dark mb-6">Contact Information</h3>
            <div class="space-y-6">
              {contactInfo.map((info) => (
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-lg bg-accent-soft text-primary-dark ring-1 ring-accent/25 flex items-center justify-center shrink-0">
                    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" aria-hidden="true">
                      <Fragment set:html={info.icon} />
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <div class="text-xs font-semibold text-primary-dark uppercase tracking-wider">{info.title}</div>
                    <div class="mt-1 text-sm text-muted leading-relaxed">
                      {info.href ? (
                        <a href={info.href} class="hover:text-primary transition-colors font-medium">{info.value}</a>
                      ) : (
                        info.value
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Quick Actions Grid -->
          <div class="grid grid-cols-3 gap-3">
            <a
              href="mailto:info@emperealenergy.com"
              class="flex flex-col items-center gap-2 p-4 rounded-xl bg-white border border-primary/10 hover:border-accent hover:shadow-card transition-all group text-center"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"/>
              </svg>
              <span class="text-2xs font-bold uppercase tracking-wider text-primary-dark">Email Us</span>
            </a>
            <a
              href="tel:+97148835515"
              class="flex flex-col items-center gap-2 p-4 rounded-xl bg-white border border-primary/10 hover:border-accent hover:shadow-card transition-all group text-center"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="text-2xs font-bold uppercase tracking-wider text-primary-dark">Call Us</span>
            </a>
            <a
              href="https://wa.me/971563762386"
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center gap-2 p-4 rounded-xl bg-white border border-primary/10 hover:border-accent hover:shadow-card transition-all group text-center"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5 text-accent group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="text-2xs font-bold uppercase tracking-wider text-primary-dark">WhatsApp</span>
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Regional Offices Section -->
  <section class="section-pad bg-surface border-t border-primary/5" aria-labelledby="offices-heading">
    <Container>
      <div class="text-center max-w-2xl mx-auto reveal-stagger">
        <p class="eyebrow">Global Presence</p>
        <h2 id="offices-heading" class="fluid-h2 mt-3">Regional Offices</h2>
        <p class="mt-4 text-muted fluid-lead">
          Empereal operates across key markets in Asia, the Middle East, and the United States — combining local presence with global technical expertise.
        </p>
      </div>

      <div class="mt-10 grid items-stretch gap-5 sm:grid-cols-2 2xl:grid-cols-4 reveal-stagger">
        {offices.map((office) => (
          <article class="flex h-full min-w-0 flex-col rounded-2xl border border-primary/10 bg-white p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-card sm:p-6">
            <div class="flex flex-1 flex-col">
              <div class="mb-5 flex min-w-0 items-start gap-3">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent-soft text-primary-dark ring-1 ring-accent/25">
                  <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M10 12h4M10 8h4M14 21v-3a2 2 0 0 0-4 0v3M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16"/>
                  </svg>
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="text-sm font-bold leading-snug text-primary-dark sm:text-base">{office.name}</h3>
                </div>
                {office.tag && (
                  <span class="inline-flex shrink-0 items-center rounded-full bg-accent/20 px-2 py-0.5 text-3xs font-bold uppercase tracking-wider text-primary-dark">
                    {office.tag}
                  </span>
                )}
              </div>
              <address class="min-w-0 whitespace-pre-line text-sm not-italic leading-6 text-muted">{office.address}</address>
            </div>
            {(office.phone || office.mobile || office.hours) && (
            <div class="mt-5 space-y-3 border-t border-primary/10 pt-4 sm:mt-6">
              {office.phone && (
                <a href={`tel:${office.phone.replace(/\s+/g, '')}`} class="grid min-w-0 grid-cols-[1rem_minmax(0,1fr)] items-start gap-2.5 text-xs font-semibold leading-5 text-muted transition-colors hover:text-primary sm:text-[13px]">
                  <svg viewBox="0 0 24 24" class="mt-0.5 h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                  <span>Tel: {office.phone}</span>
                </a>
              )}
              {office.mobile && (
                <a href={`tel:${office.mobile.replace(/\s+/g, '')}`} class="grid min-w-0 grid-cols-[1rem_minmax(0,1fr)] items-start gap-2.5 text-xs font-semibold leading-5 text-muted transition-colors hover:text-primary sm:text-[13px]">
                  <svg viewBox="0 0 24 24" class="mt-0.5 h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 1 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                  <span>Mob: {office.mobile}</span>
                </a>
              )}
              {office.hours && (
                <div class="grid min-w-0 grid-cols-[1rem_minmax(0,1fr)] items-start gap-2.5 text-xs font-semibold leading-5 text-muted sm:text-[13px]">
                  <svg viewBox="0 0 24 24" class="mt-0.5 h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2" stroke-linecap="round"/>
                  </svg>
                  <span class="min-w-0 whitespace-pre-line"><span class="block font-bold text-primary-dark">Working hours</span>{office.hours}</span>
                </div>
              )}
            </div>
            )}
          </article>
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .page-hero {
    min-height: calc(100vh - 6rem);
    min-height: calc(100svh - 6rem);
    min-height: calc(100dvh - 6rem);
  }
  @media (min-width: 1024px) {
    .page-hero {
      min-height: calc(100vh - 7rem);
      min-height: calc(100svh - 7rem);
      min-height: calc(100dvh - 7rem);
    }
  }
</style>
