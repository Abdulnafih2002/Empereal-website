---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/primitives/Container.astro";
import { awards, awardYears } from "../data/awards";
---
<BaseLayout
  title="Awards & Industry Recognition — Empereal"
  description="Recognized for technical excellence, project delivery, and leadership in solar energy."
  image="/images/Award Page/awards-hero.webp"
  imageAlt="Solar architecture and photovoltaic installations at Expo City Dubai"
  preloadImage="/images/Award Page/awards-hero.webp"
>
  <section
    class="relative isolate overflow-hidden bg-primary-dark py-20 text-white lg:py-28"
    aria-labelledby="awards-hero-title"
  >
    <div class="absolute inset-0 -z-10">
      <img
        src="/images/Award Page/awards-hero.webp"
        alt=""
        width="1541"
        height="860"
        class="absolute inset-0 h-full w-full object-cover opacity-80"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-primary-dark/75 via-primary/55 to-primary-dark/80" aria-hidden="true"></div>
    </div>

    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-accent">
          Excellence. Delivery. Leadership.
        </p>
        <h1 id="awards-hero-title" class="fluid-h2 mt-3 text-white">Awards &amp; Industry Recognition</h1>
        <p class="mt-4 fluid-lead text-white/80">
          Recognized for technical excellence, project delivery, and leadership in solar energy.
        </p>
      </div>
    </Container>
  </section>

  <section class="section-pad bg-white" aria-labelledby="awards-archive-title" data-awards-archive>
    <Container>
      <div class="mb-10 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div class="max-w-xl">
          <p class="eyebrow">Recognition Archive</p>
          <h2 id="awards-archive-title" class="fluid-h2 mt-3">A record of excellence through the years.</h2>
        </div>

        <div class="flex flex-wrap gap-2" aria-label="Filter awards by year">
          {awardYears.map((year) => (
            <button
              type="button"
              class="award-filter inline-flex min-h-[38px] items-center rounded-full border border-primary/15 bg-white px-4 py-1.5 text-sm font-semibold text-muted transition-colors hover:bg-primary-50 hover:text-primary-dark"
              aria-pressed={year === "All" ? "true" : "false"}
              data-award-filter={year}
            >
              {year}
            </button>
          ))}
        </div>
      </div>

      <p class="sr-only" aria-live="polite" data-award-status>
        Showing all {awards.length} awards.
      </p>

      <div id="awards-list" class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 reveal-stagger" role="list">
        {awards.map((award) => (
          <article
            class="group flex h-full flex-col overflow-hidden rounded-2xl border border-primary/5 bg-white text-ink shadow-card transition-all duration-300 hover:-translate-y-0.5 hover:shadow-card-lg"
            role="listitem"
            data-award-card
            data-year={award.year}
          >
            <div class="relative flex aspect-[16/10] items-center justify-center overflow-hidden bg-gradient-to-br from-white via-primary-50/60 to-accent-soft/50 p-7">
              <span class="absolute h-44 w-44 rounded-full border border-primary/[0.06] bg-white/65 transition-transform duration-500 group-hover:scale-110" aria-hidden="true"></span>
              <img
                src={award.image}
                alt={award.imageAlt}
                width={award.imageWidth}
                height={award.imageHeight}
                class="relative h-full w-full object-contain drop-shadow-[0_14px_22px_rgba(0,59,100,0.10)] transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
              <span class="absolute left-3 top-3 inline-flex items-center rounded-md bg-white/95 px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.15em] text-primary-dark shadow">
                {award.year}
              </span>
            </div>

            <div class="flex flex-1 flex-col p-5 lg:p-6">
              <h3 class="font-display text-base font-semibold leading-snug text-primary-dark lg:text-lg">
                {award.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-muted">{award.description}</p>
              <div class="mt-auto pt-5">
                <span class="block h-px w-10 bg-accent/70 transition-all duration-300 group-hover:w-16" aria-hidden="true"></span>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="hidden py-20 text-center text-muted" data-awards-empty>
        <p class="text-lg font-medium">No awards found for this year.</p>
      </div>
    </Container>
  </section>

  <section class="bg-primary py-16 text-white lg:py-20">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="fluid-h3 font-display font-bold text-white">Interested in Our Work?</h2>
        <p class="mt-4 fluid-body text-white/80">
          Connect with our team to explore how Empereal can deliver technically excellent clean energy solutions for your project.
        </p>
        <a href="/contact" class="site-cta site-cta-on-dark mt-8">
          Get in Touch
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>

<script>
  const initialiseAwardFilters = () => {
    document.querySelectorAll<HTMLElement>("[data-awards-archive]").forEach((archive) => {
      if (archive.dataset.filtersReady === "true") return;

      const filters = Array.from(archive.querySelectorAll<HTMLButtonElement>("[data-award-filter]"));
      const cards = Array.from(archive.querySelectorAll<HTMLElement>("[data-award-card]"));
      const empty = archive.querySelector<HTMLElement>("[data-awards-empty]");
      const status = archive.querySelector<HTMLElement>("[data-award-status]");
      const validYears = filters.map((filter) => filter.dataset.awardFilter ?? "All");

      if (!filters.length || !cards.length || !empty || !status) return;

      const applyFilter = (year: string, updateUrl = true) => {
        const selectedYear = validYears.includes(year) ? year : "All";
        let visibleCount = 0;

        filters.forEach((filter) => {
          filter.setAttribute("aria-pressed", String(filter.dataset.awardFilter === selectedYear));
        });

        cards.forEach((card) => {
          const visible = selectedYear === "All" || card.dataset.year === selectedYear;
          card.hidden = !visible;
          if (visible) visibleCount += 1;
        });

        empty.classList.toggle("hidden", visibleCount > 0);
        status.textContent = selectedYear === "All"
          ? `Showing all ${visibleCount} awards.`
          : `Showing ${visibleCount} ${visibleCount === 1 ? "award" : "awards"} from ${selectedYear}.`;

        if (updateUrl) {
          const url = new URL(window.location.href);
          if (selectedYear === "All") {
            url.searchParams.delete("year");
          } else {
            url.searchParams.set("year", selectedYear);
          }
          window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
        }
      };

      filters.forEach((filter) => {
        filter.addEventListener("click", () => applyFilter(filter.dataset.awardFilter ?? "All"));
      });

      archive.dataset.filtersReady = "true";
      const initialYear = new URL(window.location.href).searchParams.get("year") ?? "All";
      applyFilter(initialYear, false);
    });
  };

  initialiseAwardFilters();
  document.addEventListener("astro:page-load", initialiseAwardFilters);
</script>

<style>
  [data-award-card][hidden] {
    display: none !important;
  }

  .award-filter[aria-pressed="true"] {
    border-color: #003b64;
    background: #003b64;
    color: #ffffff;
    box-shadow: 0 1px 2px rgba(0, 59, 100, 0.14);
  }
</style>
