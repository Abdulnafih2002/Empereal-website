---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionsHero from "../components/sections/solutions/SolutionsHero.astro";
import SolutionsIntro from "../components/sections/solutions/SolutionsIntro.astro";
import SolutionAreas from "../components/sections/solutions/SolutionAreas.astro";
import ApplicationSectors from "../components/sections/solutions/ApplicationSectors.astro";
import DeliveryApproach from "../components/sections/solutions/DeliveryApproach.astro";
import SolutionsCTA from "../components/sections/solutions/SolutionsCTA.astro";
import { getSolutions } from "../lib/storage.js";

const solutions = await getSolutions();
---
<BaseLayout
  title="Solutions — Empereal Clean Energy & Water Engineering"
  description="Five engineering disciplines, one delivery partner. Empereal delivers Architectural BIPV & Solar Facade, Solar PV Systems, Energy Storage, Green Hydrogen, and Water Desalination solutions — feasibility through O&M."
  image="/images/uae-pavilion-1.jpg"
  imageAlt="Architectural solar engineering at the UAE Pavilion"
>
  <SolutionsHero />
  <SolutionsIntro />
  <SolutionAreas solutions={solutions} />
  <ApplicationSectors />
  <DeliveryApproach />
  <SolutionsCTA />
</BaseLayout>
