---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/home/Hero.astro";
import CleanEnergySolutions from "../components/sections/home/CleanEnergySolutions.astro";
import AboutEmpereal from "../components/sections/home/AboutEmpereal.astro";
import OurProjects from "../components/sections/home/OurProjects.astro";
import NewsInsights from "../components/sections/home/NewsInsights.astro";
import Testimonial from "../components/sections/home/Testimonial.astro";
---
<BaseLayout
  title="empereal | Engineering the future of clean energy."
  description="Smart Solar & EPC Solutions — delivering high-performance BIPV, solar PV, energy storage and green hydrogen projects across the Middle East and Asia."
  image="/images/empereal-og.png"
  imageAlt="Empereal — Engineering the future of clean energy"
  imageWidth={1200}
  imageHeight={630}
  preloadImage="/images/sustainability-city.jpg"
  showClients={true}
>
  <Hero />
  <AboutEmpereal />
  <CleanEnergySolutions />
  <OurProjects />
  <NewsInsights />
  <Testimonial />
</BaseLayout>
