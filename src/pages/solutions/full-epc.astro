---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/primitives/Container.astro";
import ProjectCard from "../../components/sections/projects/ProjectCard.astro";
import RelatedEngagementBanner from "../../components/sections/solutions/RelatedEngagementBanner.astro";
import { projects } from "../../data/projects.ts";

const relatedProjectSlugs = ["dewa-hq", "masdar-10mw", "uae-pavilion-expo"];
const relatedProjects = relatedProjectSlugs
  .map((slug) => projects.find((project) => project.slug === slug))
  .filter((project): project is NonNullable<typeof project> => Boolean(project));

const scopeItems = [
  {
    group: "Design & Advisory",
    items: [
      "Feasibility studies and site assessments",
      "Full architectural, structural and electrical design",
      "Energy yield modelling and financial analysis",
      "Authority approvals and permitting support",
    ],
  },
  {
    group: "Execution & Operations",
    items: [
      "Procurement and supply chain management",
      "Civil, structural and electrical construction",
      "Testing, commissioning and performance certification",
      "Long-term O&M and performance monitoring",
    ],
  },
];

const audiences = [
  {
    title: "Developers & Investors",
    desc: "Single-contract delivery from feasibility to operation — protecting your capital with full accountability at every stage.",
    icon: `<path d="M3 21h18M9 8h1M9 12h1M9 16h1M14 8h1M14 12h1M14 16h1M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    title: "Utilities & IPPs",
    desc: "Utility-scale EPC execution with rigorous QA, grid studies, and long-term O&M — from MW to GW.",
    icon: `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    title: "Industrial Clients",
    desc: "High-performance C&I solar delivered under a full EPC contract, sized for self-consumption and export.",
    icon: `<path d="M2 20h20M4 20V10l8-7 8 7v10M9 20v-5h6v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    title: "Government & Public Sector",
    desc: "Full lifecycle delivery for national renewable energy programmes — compliant, auditable, and on time.",
    icon: `<circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  },
];

const steps = [
  {
    n: "01",
    title: "Discovery & Feasibility",
    desc: "Deep-dive into your requirements, site assessment, and financial modeling.",
  },
  {
    n: "02",
    title: "Design & Engineering",
    desc: "Complete multi-disciplinary design with 3D visualization and approval support.",
  },
  {
    n: "03",
    title: "Procurement & Planning",
    desc: "Strategic sourcing, logistics coordination, and construction scheduling.",
  },
  {
    n: "04",
    title: "Construction & Installation",
    desc: "Full-scale execution with rigorous quality and safety protocols.",
  },
  {
    n: "05",
    title: "Commissioning & Certification",
    desc: "Performance testing, grid synchronization, and compliance certification.",
  },
  {
    n: "06",
    title: "Handover & O&M",
    desc: "Comprehensive documentation, training, and ongoing maintenance partnership.",
  },
];

const relatedModels = [
  {
    title: "Design & Consultancy Only",
    desc: "Independent engineering guidance from the earliest stage of a project. We provide feasibility studies, technical and architectural design, and authority approvals — positioning your project for success before a single panel is procured.",
    image: "/images/mercedes-binghatti.jpg",
    href: "/solutions/design-consultancy",
  },
];
---
<BaseLayout
  title="Full End-to-End EPC | Empereal Solutions"
  description="Complete project lifecycle management under a single contract — from feasibility through design, procurement, construction, commissioning, and long-term O&M. We take full accountability from concept to operation."
  image="/images/dewa-hq-2.jpg"
  imageAlt="Empereal end-to-end solar EPC project delivery"
>
  <!-- Hero Section -->
  <section
    class="page-hero relative isolate overflow-hidden bg-primary-dark text-white flex flex-col"
    aria-labelledby="epc-hero-title"
  >
    <div class="absolute inset-0 -z-10" aria-hidden="true">
      <!-- Solid dark base so text is always readable regardless of image brightness -->
      <div class="absolute inset-0 bg-primary-dark"></div>
      <img
        src="/images/dewa-hq-2.jpg"
        alt="Full End-to-End EPC"
        class="h-full w-full object-cover opacity-50"
        loading="eager"
        decoding="async"
      />
      <!-- Readability overlay matching home hero pattern -->
      <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/80 via-primary-dark/55 to-primary-dark/15"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/60 via-transparent to-transparent"></div>
      <div class="absolute -bottom-32 -right-32 h-[520px] w-[520px] rounded-full bg-accent/15 blur-[140px] animate-pulse-glow"></div>
      <svg class="absolute inset-0 w-full h-full opacity-[0.06]" viewBox="0 0 1440 800" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <defs>
          <pattern id="epcHeroGrid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M40 0H0v40" fill="none" stroke="#fff" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="1440" height="800" fill="url(#epcHeroGrid)"/>
      </svg>
    </div>

    <Container class="relative flex-1 flex items-start pt-32 sm:items-center sm:pt-0">
      <div class="pb-16 sm:py-20 lg:py-24 max-w-3xl">
        <p class="eyebrow !text-accent hero-enter hero-enter-1">Our Solution</p>
        <h1 id="epc-hero-title" class="fluid-display mt-4 text-white hero-enter hero-enter-2">
          Full End-to-End <span class="text-accent">EPC</span>
        </h1>
        <p class="fluid-lead mt-6 text-white/85 max-w-2xl hero-enter hero-enter-3">
          Delivering the complete project from initial concept through procurement, installation, testing &amp; commissioning and handover, providing the client with a fully operational, tested, and documented project.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3 hero-enter hero-enter-4">
          <a
            href="#scope"
            class="hero-home-pill"
          >
            Our Services
          </a>
        </div>

        <!-- Stats Banner -->
        <dl class="mt-12 grid grid-cols-1 sm:grid-cols-3 divide-y divide-white/10 sm:divide-y-0 sm:divide-x sm:divide-white/10 border-y border-white/10 py-5 lg:py-7 max-w-2xl hero-enter hero-enter-4">
          <div class="px-6 py-2 flex flex-col items-start">
            <dt class="order-2 mt-1 text-[10px] uppercase tracking-[0.15em] text-white/65 font-medium">Years of Experience</dt>
            <dd class="order-1 font-display text-2xl sm:text-3xl font-semibold text-white">18+</dd>
          </div>
          <div class="px-6 py-2 flex flex-col items-start">
            <dt class="order-2 mt-1 text-[10px] uppercase tracking-[0.15em] text-white/65 font-medium">of Solar Commissioned</dt>
            <dd class="order-1 font-display text-2xl sm:text-3xl font-semibold text-white">695 MW</dd>
          </div>
          <div class="px-6 py-2 flex flex-col items-start">
            <dt class="order-2 mt-1 text-[10px] uppercase tracking-[0.15em] text-white/65 font-medium">Projects Delivered</dt>
            <dd class="order-1 font-display text-2xl sm:text-3xl font-semibold text-white">140+</dd>
          </div>
        </dl>
      </div>
    </Container>
  </section>

  <!-- Scope of Services -->
  <section id="scope" class="section-pad bg-surface" aria-labelledby="epc-scope-title">
    <Container>
      <div class="max-w-2xl reveal">
        <p class="eyebrow">Scope of Services</p>
        <h2 id="epc-scope-title" class="fluid-h2 mt-3">What we deliver</h2>
        <p class="fluid-lead mt-5 text-muted">
          Complete project lifecycle management under a single contract — from concept to long-term operation.
        </p>
      </div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 reveal-stagger">
        {scopeItems.map((group) => (
          <div class="bg-white rounded-2xl border border-primary/10 p-6 sm:p-8 hover:shadow-card transition-all">
            <h3 class="text-sm font-bold uppercase tracking-[0.1em] text-accent">{group.group}</h3>
            <ul class="mt-5 space-y-3">
              {group.items.map((item) => (
                <li class="flex gap-3">
                  <span class="mt-2 inline-block h-[2px] w-4 bg-accent rounded-full shrink-0" aria-hidden="true"></span>
                  <span class="text-sm text-ink/80 leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Who We Support -->
  <section class="section-pad bg-white" aria-labelledby="epc-support-title">
    <Container>
      <div class="text-center max-w-2xl mx-auto reveal-stagger">
        <p class="eyebrow">Who we support</p>
        <h2 id="epc-support-title" class="fluid-h2 mt-3">Who we support</h2>
        <p class="mt-4 text-muted fluid-lead">
          We partner with organisations across the energy and infrastructure ecosystem.
        </p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4 reveal-stagger">
        {audiences.map((a) => (
          <div class="group relative flex flex-col overflow-hidden rounded-2xl bg-white border border-primary/10 p-6 shadow-card hover:shadow-card-lg hover:-translate-y-1 transition-all duration-300">
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-accent-soft text-primary-dark ring-1 ring-accent/20">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" aria-hidden="true">
                <Fragment set:html={a.icon} />
              </svg>
            </div>
            <h3 class="mt-4 font-display text-base font-semibold text-primary-dark">{a.title}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed flex-1">{a.desc}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Our Process -->
  <section class="section-pad bg-[#003B64] text-white" aria-labelledby="epc-process-title">
    <Container>
      <div class="text-center max-w-2xl mx-auto reveal">
        <p class="eyebrow !text-accent">Our Process</p>
        <h2 id="epc-process-title" class="fluid-h2 mt-3 text-white">Our Process</h2>
        <p class="fluid-lead mt-5 text-white/60">
          How we deliver under this engagement model, from start to finish.
        </p>
      </div>

      <ol class="mt-12 grid gap-8 sm:gap-5 sm:grid-cols-2 lg:grid-cols-3 relative reveal-stagger">
        {steps.map((s) => (
          <li class="flex gap-5 items-start">
            <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-accent text-primary-dark font-bold text-sm shadow-md shadow-accent/30 ring-4 ring-[#003B64]">
              {s.n}
            </span>
            <div class="min-w-0">
              <h3 class="text-sm font-semibold text-white">{s.title}</h3>
              <p class="mt-1.5 text-xs text-white/55 leading-relaxed">{s.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </Container>
  </section>

  <!-- Related Projects -->
  <section class="section-pad bg-white" aria-labelledby="epc-project-title">
    <Container>
      <div class="text-center max-w-2xl mx-auto reveal">
        <p class="eyebrow">Our Work</p>
        <h2 id="epc-project-title" class="fluid-h2 mt-3">Related Projects</h2>
      </div>

      <ul class="mx-auto mt-10 flex max-w-6xl flex-wrap justify-center gap-5 reveal-stagger">
        {relatedProjects.map((project) => (
          <li class="flex w-full sm:w-[calc(50%-10px)] lg:w-[calc(33.333%-14px)]">
            <ProjectCard project={project} class="w-full" />
          </li>
        ))}
      </ul>

      <div class="mt-10 text-center reveal">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 rounded-md border border-primary/20 bg-white hover:border-primary hover:bg-primary-50 px-6 py-3 text-sm font-semibold text-primary transition-colors min-h-[44px]"
        >
          Explore All Projects
          <svg viewBox="0 0 20 20" class="h-4 w-4 arrow-slide" fill="none" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Container>
  </section>


  <!-- Other engagement model -->
  <section class="section-pad bg-white" aria-label="Other engagement model">
    <Container>
      <div class="mx-auto grid max-w-5xl gap-5 reveal-stagger">
        {relatedModels.map((m) => (
          <RelatedEngagementBanner
            title={m.title}
            desc={m.desc}
            image={m.image}
            href={m.href}
          />
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .page-hero {
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
  }
</style>
