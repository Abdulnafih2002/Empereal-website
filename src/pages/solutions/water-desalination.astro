---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SolutionsSubNav from "../../components/sections/solutions/SolutionsSubNav.astro";
import WaterHero from "../../components/sections/water-desalination/WaterHero.astro";
import WaterIntro from "../../components/sections/water-desalination/WaterIntro.astro";
import WaterTechCards from "../../components/sections/water-desalination/WaterTechCards.astro";
import WaterLFRSplit from "../../components/sections/water-desalination/WaterLFRSplit.astro";
import WaterScope from "../../components/sections/water-desalination/WaterScope.astro";
import WaterUseCases from "../../components/sections/water-desalination/WaterUseCases.astro";
import WaterDeliverySteps from "../../components/sections/water-desalination/WaterDeliverySteps.astro";
import WaterOtherSolutions from "../../components/sections/water-desalination/WaterOtherSolutions.astro";
import SolutionsCTA from "../../components/sections/solutions/SolutionsCTA.astro";
import Container from "../../components/primitives/Container.astro";
import { projects } from "../../data/projects.ts";

const relatedSlugs = ["jeddah-oceanarium", "zamani-islands"];
const relatedProjects = relatedSlugs
  .map((s) => projects.find((p) => p.slug === s))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const flagLookup: Record<string, string> = {
  AE: "🇦🇪",
  SA: "🇸🇦",
  MV: "🇲🇻",
};
---
<BaseLayout
  title="Water & Desalination | Empereal Solutions"
  description="Solar thermal and photovoltaic-powered desalination systems delivering fresh water from seawater and brackish sources to ultra-pure industrial process water."
  image="/images/jeddah-oceanarium.jpg"
  imageAlt="Solar-powered water and desalination infrastructure"
  showClients={false}
>
  <SolutionsSubNav active="water" />
  <WaterHero />
  <WaterIntro />
  <WaterTechCards />
  <WaterLFRSplit />
  <WaterScope />
  <WaterUseCases />
  <WaterDeliverySteps />

  <!-- Related Projects -->
  <section class="section-pad bg-white" aria-labelledby="project-title">
    <Container>
      <div class="text-center max-w-2xl mx-auto reveal">
        <p class="eyebrow">Our Work</p>
        <h2 id="project-title" class="fluid-h2 mt-3">Related Projects</h2>
      </div>

      <div class="mt-10 flex flex-wrap justify-center gap-6 max-w-4xl mx-auto reveal">
        {relatedProjects.map((p) => (
          <article class="group relative flex flex-col overflow-hidden rounded-2xl bg-white border border-primary/10 shadow-card hover:shadow-card-lg hover:-translate-y-1 transition-all duration-300 w-full sm:w-[calc(50%-12px)] max-w-sm">
            <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-primary-dark via-primary to-accent/40">
              <img
                src={p.image}
                alt={p.title}
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
                decoding="async"
                onerror="this.remove()"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/30 to-transparent" aria-hidden="true"></div>
              <div class="absolute left-4 top-4 inline-flex items-center gap-2 rounded-md bg-accent px-3 py-1.5 text-[11px] font-bold uppercase tracking-[0.15em] text-primary-dark shadow">
                <span aria-hidden="true">{flagLookup[p.countryCode] || "🌐"}</span>
                {p.country}
              </div>
            </div>

            <div class="flex flex-col flex-1 p-5 lg:p-6 text-left">
              <h3 class="font-display text-lg lg:text-xl font-semibold text-primary-dark">{p.title}</h3>
              <p class="mt-2 text-sm text-muted leading-relaxed flex-1">
                {p.summary}
              </p>
              <a href={`/projects#${p.slug}`} class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary group-hover:text-accent-dark transition-colors">
                View case study
                <svg viewBox="0 0 20 20" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" aria-hidden="true">
                  <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-10 text-center reveal">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 rounded-md border border-primary/20 bg-white hover:border-primary hover:bg-primary-50 px-6 py-3 text-sm font-semibold text-primary transition-colors min-h-[44px]"
        >
          Explore All Projects
          <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </Container>
  </section>

  <WaterOtherSolutions />
  <SolutionsCTA />
</BaseLayout>
