---
export const prerender = false;
import CRMLayout from "../../../layouts/CRMLayout.astro";
import ImageUpload from "../../../components/crm/ImageUpload.astro";
import { getFeatures, getEnquiries } from "../../../lib/storage.js";

const [{ highlight, cards }, enquiries] = await Promise.all([
  getFeatures(),
  getEnquiries(),
]);
const newCount = enquiries.filter((e) => e.status === "new").length;
---
<CRMLayout title="Features Section" newEnquiries={newCount}>
  <!-- ── Featured Highlight Card ─────────────────────────────── -->
  <section class="mb-10">
    <div class="flex items-center gap-3 mb-5">
      <div class="h-px flex-1 bg-slate-200"></div>
      <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest shrink-0">Featured Highlight Card</p>
      <div class="h-px flex-1 bg-slate-200"></div>
    </div>
    <p class="text-xs text-slate-400 mb-5">The dark navy card displayed prominently in the features section.</p>

    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/60 overflow-hidden">
      <div class="border-b border-slate-100 px-6 py-4">
        <h2 class="text-sm font-semibold text-slate-900">Highlight Card Content</h2>
      </div>
      <form id="highlight-form" class="p-6 space-y-5">
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="h-eyebrow" class="block text-sm font-medium text-slate-700 mb-1.5">Eyebrow label</label>
            <input id="h-eyebrow" name="eyebrow" type="text" value={highlight.eyebrow}
              placeholder="e.g. Trusted by Industry Leaders"
              class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 placeholder-slate-400 transition focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20" />
          </div>
          <div>
            <ImageUpload name="imageUrl" value={highlight.imageUrl} label="Hover Image" />
          </div>
        </div>
        <div>
          <label for="h-title" class="block text-sm font-medium text-slate-700 mb-1.5">Heading</label>
          <input id="h-title" name="title" type="text" value={highlight.title}
            class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 placeholder-slate-400 transition focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20" />
        </div>
        <div>
          <label for="h-desc" class="block text-sm font-medium text-slate-700 mb-1.5">Description</label>
          <textarea id="h-desc" name="description" rows="3"
            class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 placeholder-slate-400 transition focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20 resize-none">{highlight.description}</textarea>
        </div>
        <div class="grid gap-5 sm:grid-cols-3">
          <div>
            <label for="h-badge-label" class="block text-sm font-medium text-slate-700 mb-1.5">Badge label</label>
            <input id="h-badge-label" name="badgeLabel" type="text" value={highlight.badgeLabel}
              class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 transition focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20" />
          </div>
          <div>
            <label for="h-badge-value" class="block text-sm font-medium text-slate-700 mb-1.5">Badge value</label>
            <input id="h-badge-value" name="badgeValue" type="text" value={highlight.badgeValue}
              class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 transition focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20" />
          </div>
          <div>
            <label for="h-badge-suffix" class="block text-sm font-medium text-slate-700 mb-1.5">Badge subtitle</label>
            <input id="h-badge-suffix" name="badgeSuffix" type="text" value={highlight.badgeSuffix}
              class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 transition focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20" />
          </div>
        </div>
        <div class="w-36">
          <label for="h-gauge" class="block text-sm font-medium text-slate-700 mb-1.5">Gauge % (0–100)</label>
          <input id="h-gauge" name="gaugePercent" type="number" min="0" max="100" value={highlight.gaugePercent}
            class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 transition focus:border-orange focus:outline-none focus:ring-2 focus:ring-orange/20" />
        </div>

        <p id="hl-status" class="hidden text-sm" aria-live="polite"></p>
        <div class="pt-1 border-t border-slate-100">
          <button type="submit"
            class="rounded-lg bg-primary hover:bg-primary-light px-5 py-2.5 text-sm font-semibold text-white transition-colors shadow-sm">
            Save Highlight
          </button>
        </div>
      </form>
    </div>
  </section>

  <!-- ── Feature Cards ──────────────────────────────────────── -->
  <section>
    <div class="flex items-center gap-3 mb-5">
      <div class="h-px flex-1 bg-slate-200"></div>
      <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest shrink-0">Feature Cards</p>
      <div class="h-px flex-1 bg-slate-200"></div>
    </div>
    <p class="text-xs text-slate-400 mb-5">The white cards shown alongside the highlight card in the features section.</p>

    <div class="flex items-center justify-between mb-4">
      <p class="text-sm text-slate-500">{cards.length} card{cards.length !== 1 ? "s" : ""}</p>
      <a href="/crm/features/new"
        class="inline-flex items-center gap-2 rounded-lg bg-primary hover:bg-primary-light px-4 py-2 text-sm font-semibold text-white transition-colors shadow-sm">
        <svg class="h-3.5 w-3.5" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 1v10M1 6h10"/></svg>
        Add Card
      </a>
    </div>

    {cards.length === 0 ? (
      <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/60 py-12 text-center">
        <p class="text-sm text-slate-400">No feature cards yet.</p>
      </div>
    ) : (
      <div class="space-y-2">
        {cards.map((c) => (
          <div class="flex items-start gap-4 bg-white rounded-xl shadow-sm ring-1 ring-slate-200/60 px-5 py-4 hover:shadow-md transition-shadow">
            <div class="flex-shrink-0 h-8 w-8 rounded-lg bg-primary/10 flex items-center justify-center">
              <span class="text-xs font-bold text-primary">#{c.order}</span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-slate-800">{c.title}</p>
              <p class="mt-0.5 text-sm text-slate-400 line-clamp-1">{c.description}</p>
              {c.href && <p class="mt-0.5 text-xs text-orange">→ {c.href}</p>}
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <a href={`/crm/features/${c.id}`}
                class="inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 px-3 py-1.5 text-xs font-medium text-slate-600 transition-colors">
                <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.5 1.5L10.5 3.5L4 10H2V8L8.5 1.5z"/></svg>
                Edit
              </a>
              <button type="button" data-delete-id={c.id}
                class="inline-flex items-center gap-1 rounded-lg border border-red-200 bg-red-50 hover:bg-red-100 px-3 py-1.5 text-xs font-medium text-red-600 transition-colors">
                <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h8M5 3V2h2v1M10 3l-.5 7a1 1 0 01-1 .9H3.5a1 1 0 01-1-.9L2 3"/></svg>
                Delete
              </button>
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</CRMLayout>

<script>
  const hlForm = document.getElementById("highlight-form") as HTMLFormElement | null;
  const hlStatus = document.getElementById("hl-status") as HTMLParagraphElement | null;

  hlForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!hlForm || !hlStatus) return;
    hlStatus.classList.add("hidden");

    const fd = new FormData(hlForm);
    const body = {
      eyebrow: fd.get("eyebrow"),
      title: fd.get("title"),
      description: fd.get("description"),
      badgeLabel: fd.get("badgeLabel"),
      badgeValue: fd.get("badgeValue"),
      badgeSuffix: fd.get("badgeSuffix"),
      gaugePercent: Number(fd.get("gaugePercent")),
      imageUrl: fd.get("imageUrl") || undefined,
    };

    const res = await fetch("/api/crm/features/highlight", {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });

    hlStatus.textContent = res.ok ? "Saved successfully." : "Failed to save.";
    hlStatus.className = res.ok ? "text-sm text-green-600" : "text-sm text-red-600";
    hlStatus.classList.remove("hidden");
    setTimeout(() => hlStatus?.classList.add("hidden"), 3000);
  });

  document.querySelectorAll<HTMLButtonElement>("[data-delete-id]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = btn.dataset.deleteId;
      if (!confirm("Delete this feature card?")) return;
      const res = await fetch(`/api/crm/features/cards/${id}`, { method: "DELETE" });
      if (res.ok) window.location.reload();
    });
  });
</script>
