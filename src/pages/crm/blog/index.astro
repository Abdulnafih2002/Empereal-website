---
export const prerender = false;
import CRMLayout from "../../../layouts/CRMLayout.astro";
import { getBlogPosts, getEnquiries } from "../../../lib/storage.js";

const [posts, enquiries] = await Promise.all([getBlogPosts(), getEnquiries()]);
const newCount = enquiries.filter((e) => e.status === "new").length;
---
<CRMLayout title="Blog / News" newEnquiries={newCount}>
  <div class="flex items-center justify-between mb-6">
    <p class="text-sm text-slate-500">
      {posts.length} post{posts.length !== 1 ? "s" : ""}
    </p>
    <a
      href="/crm/blog/new"
      class="inline-flex items-center gap-2 rounded-lg bg-primary hover:bg-primary-light px-4 py-2.5 text-sm font-semibold text-white transition-colors shadow-sm"
    >
      <svg class="h-3.5 w-3.5" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 1v10M1 6h10"/></svg>
      Add Post
    </a>
  </div>

  {posts.length === 0 ? (
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/60 py-20 text-center">
      <svg class="h-10 w-10 mx-auto text-slate-200 mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <path d="M7 8h10M7 12h10M7 16h6" stroke-linecap="round"/>
      </svg>
      <p class="text-sm font-medium text-slate-400">No posts yet</p>
      <a href="/crm/blog/new" class="mt-3 inline-block text-sm text-primary hover:text-orange transition-colors">Add your first post →</a>
    </div>
  ) : (
    <div class="space-y-2">
      {posts.map((p) => (
        <div class="flex items-center gap-4 bg-white rounded-xl shadow-sm ring-1 ring-slate-200/60 px-5 py-4 hover:shadow-md transition-shadow">
          <div class="flex-shrink-0 h-8 w-8 rounded-lg bg-primary/10 flex items-center justify-center">
            <span class="text-xs font-bold text-primary">#{p.order}</span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-slate-800 truncate">{p.title}</p>
            <div class="flex items-center gap-2 mt-0.5">
              <span class="text-[10px] font-bold uppercase tracking-wide text-orange">{p.tag}</span>
              <span class="text-slate-300">·</span>
              <span class="text-xs text-slate-400">{p.date}</span>
              <span class="text-slate-300">·</span>
              <span class="text-xs text-slate-400">{p.readTime}</span>
            </div>
            <p class="mt-0.5 text-sm text-slate-400 line-clamp-1">{p.excerpt}</p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <a
              href={`/blog/${p.slug}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 px-3 py-1.5 text-xs font-medium text-slate-500 transition-colors"
            >
              <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 2H2a1 1 0 00-1 1v7a1 1 0 001 1h7a1 1 0 001-1V8M7.5 1.5h3v3M5 7L10.5 1.5"/></svg>
              View
            </a>
            <a
              href={`/crm/blog/${p.id}`}
              class="inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 px-3 py-1.5 text-xs font-medium text-slate-600 transition-colors"
            >
              <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.5 1.5L10.5 3.5L4 10H2V8L8.5 1.5z"/></svg>
              Edit
            </a>
            <button
              type="button"
              class="inline-flex items-center gap-1 rounded-lg border border-red-200 bg-red-50 hover:bg-red-100 px-3 py-1.5 text-xs font-medium text-red-600 transition-colors"
              data-delete-id={p.id}
              data-delete-title={p.title}
            >
              <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h8M5 3V2h2v1M10 3l-.5 7a1 1 0 01-1 .9H3.5a1 1 0 01-1-.9L2 3"/></svg>
              Delete
            </button>
          </div>
        </div>
      ))}
    </div>
  )}
</CRMLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-delete-id]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = btn.dataset.deleteId;
      const title = btn.dataset.deleteTitle ?? "this post";
      if (!confirm(`Delete "${title}"?`)) return;
      const res = await fetch(`/api/crm/blog/${id}`, { method: "DELETE" });
      if (res.ok) window.location.reload();
    });
  });
</script>
