---
import Container from "../primitives/Container.astro";

type NavLink = { label: string; href: string; children?: { label: string; href: string; desc?: string }[] };

const nav: NavLink[] = [
  {
    label: "About Empereal",
    href: "/about",
    children: [
      { label: "Who We Are", href: "/about", desc: "A global smart energy & EPC leader." },
      { label: "Leadership", href: "/leadership", desc: "Founder-led, experience-driven." },
    ],
  },
  {
    label: "Solutions",
    href: "/solutions",
    children: [
      { label: "Design & Consultancy Only", href: "/solutions/design-consultancy", desc: "Independent engineering, resource studies, and system design." },
      { label: "Implementation & Construction Only", href: "/solutions/implementation", desc: "Your execution partner for build, installation, and commissioning." },
      { label: "Full End-to-End EPC", href: "/solutions/full-epc", desc: "Complete project lifecycle delivery and accountability." },
      { label: "Solar Power Systems", href: "/solutions/solar-power-systems", desc: "Utility, C&I, BIPV, O&M." },
      { label: "Water & Desalination", href: "/solutions/water-desalination", desc: "Solar thermal & PV-RO systems." },
      { label: "Energy Storage", href: "/solutions/energy-storage", desc: "BESS & patented thermal storage." },
      { label: "Architectural BIPV & Integrated Solar Solutions", href: "/solutions/integrated-infrastructure", desc: "BIPV, smart energy, power + water integration." },
      { label: "Green Hydrogen", href: "/solutions/green-hydrogen", desc: "Fuel-switching at scale." },
    ],
  },
  {
    label: "Projects",
    href: "/projects",
  },
  { label: "News & Insights", href: "/blog" },
];

const serviceIconRoot = "/images/Service%20icons/Services";
const howWeServeIconRoot = "/images/Service%20icons/How%20we%20serve";
const solutionNavIcons: Record<string, string> = {
  "/solutions/design-consultancy": `${howWeServeIconRoot}/design-consultancy.webp`,
  "/solutions/full-epc": `${howWeServeIconRoot}/full-epc.webp`,
  "/solutions/implementation": `${howWeServeIconRoot}/implementation.webp`,
  "/solutions/solar-power-systems": `${serviceIconRoot}/solar-pv.webp`,
  "/solutions/water-desalination": `${serviceIconRoot}/water-desalination.webp`,
  "/solutions/energy-storage": `${serviceIconRoot}/energy-storage.webp`,
  "/solutions/integrated-infrastructure": `${serviceIconRoot}/architecture-bipv.webp`,
  "/solutions/green-hydrogen": `${serviceIconRoot}/green-hydrogen.webp`,
};
---
<header
  id="site-header"
  class="is-transparent fixed top-0 z-40 h-16 lg:h-20 w-full bg-white border-b border-primary/5"
  data-header
>
  <Container class="flex items-center justify-between gap-4 h-16 lg:h-20">
    <a href="/" class="flex items-center" aria-label="Empereal home">
      <img src="/logo.svg" alt="Empereal — Energizing Communities" class="logo-dark h-9 lg:h-10 w-auto" />
      <img src="/logo-light.svg" alt="" aria-hidden="true" class="logo-light h-9 lg:h-10 w-auto" />
    </a>

    <nav aria-label="Primary" class="hidden lg:flex items-center gap-1 self-stretch" data-primary-nav>
      {nav.map((item) => (
        <div class="self-stretch flex items-center group" data-nav-item>
          {item.children ? (
            item.label === "Solutions" ? (
              <a
                href={item.href}
                aria-haspopup="true"
                class="inline-flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium text-ink hover:text-primary transition-colors"
              >
                {item.label}
                <svg viewBox="0 0 12 12" class="h-3 w-3 text-muted transition-transform group-hover:rotate-180" fill="none" aria-hidden="true">
                  <path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            ) : (
              <button
                type="button"
                aria-haspopup="true"
                class="inline-flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium text-ink hover:text-primary transition-colors bg-transparent border-0 cursor-default"
              >
                {item.label}
                <svg viewBox="0 0 12 12" class="h-3 w-3 text-muted transition-transform group-hover:rotate-180" fill="none" aria-hidden="true">
                  <path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            )
          ) : (
            <a
              href={item.href}
              class="inline-flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium text-ink hover:text-primary transition-colors"
            >
              {item.label}
            </a>
          )}

          {item.children && (
            <div
              class="invisible opacity-0 translate-y-1 pointer-events-none absolute left-0 right-0 top-full transition-all duration-150 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto"
              role="menu"
            >
              <div class="w-full bg-white shadow-card-lg ring-1 ring-primary/5 border-t border-primary/5">
                {item.label === "Solutions" ? (
                  <Container class="py-8">
                    <div class="grid grid-cols-[1.2fr_auto_2.8fr] gap-8">
                      {/* Left Column: HOW WE DELIVER */}
                      <div class="flex flex-col">
                        <p class="text-[11px] font-bold uppercase tracking-[0.1em] text-muted">How We Deliver</p>
                        <div class="mt-4 flex flex-col gap-3">
                          <a href="/solutions/design-consultancy" class="group/item flex gap-4 rounded-lg p-3 hover:bg-primary-50 transition-colors" role="menuitem">
                            <div class="shrink-0 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent-soft text-primary-dark ring-1 ring-accent/20">
                              <img src={solutionNavIcons["/solutions/design-consultancy"]} alt="" class="h-7 w-7 object-contain" loading="lazy" decoding="async" />
                            </div>
                            <div>
                              <div class="text-sm font-semibold text-primary-dark group-hover/item:text-primary transition-colors">Design & Consultancy Only</div>
                              <div class="text-xs text-muted mt-1">Independent engineering, resource studies, and system design.</div>
                            </div>
                          </a>
                          
                          <a href="/solutions/implementation" class="group/item flex gap-4 rounded-lg p-3 hover:bg-primary-50 transition-colors" role="menuitem">
                            <div class="shrink-0 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent-soft text-primary-dark ring-1 ring-accent/20">
                              <img src={solutionNavIcons["/solutions/implementation"]} alt="" class="h-7 w-7 object-contain" loading="lazy" decoding="async" />
                            </div>
                            <div>
                              <div class="text-sm font-semibold text-primary-dark group-hover/item:text-primary transition-colors">Implementation & Construction Only</div>
                              <div class="text-xs text-muted mt-1">Your execution partner for build, installation, and commissioning.</div>
                            </div>
                          </a>

                          <a href="/solutions/full-epc" class="group/item flex gap-4 rounded-lg p-3 hover:bg-primary-50 transition-colors" role="menuitem">
                            <div class="shrink-0 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent-soft text-primary-dark ring-1 ring-accent/20">
                              <img src={solutionNavIcons["/solutions/full-epc"]} alt="" class="h-7 w-7 object-contain" loading="lazy" decoding="async" />
                            </div>
                            <div>
                              <div class="text-sm font-semibold text-primary-dark group-hover/item:text-primary transition-colors">Full End-to-End EPC</div>
                              <div class="text-xs text-muted mt-1">Complete project lifecycle delivery and accountability.</div>
                            </div>
                          </a>
                        </div>
                      </div>

                      {/* Vertical Separator Divider */}
                      <div class="w-px bg-primary/10 self-stretch" aria-hidden="true"></div>

                      {/* Right Column: CORE SOLUTIONS */}
                      <div class="flex flex-col">
                        <p class="text-[11px] font-bold uppercase tracking-[0.1em] text-muted">Core Solutions</p>
                        <div class="mt-4 grid grid-cols-2 gap-4">
                          {/* Col 1 */}
                          <div class="flex flex-col gap-2">
                            <a href="/solutions/solar-power-systems" class="group/item flex items-center gap-3 rounded-lg p-2.5 hover:bg-primary-50 transition-colors" role="menuitem">
                              <div class="shrink-0 inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent-soft text-primary-dark ring-1 ring-accent/20">
                                <img src={solutionNavIcons["/solutions/solar-power-systems"]} alt="" class="h-6 w-6 object-contain" loading="lazy" decoding="async" />
                              </div>
                              <div class="text-sm font-semibold text-primary-dark group-hover/item:text-primary transition-colors">Solar Power Systems</div>
                            </a>

                            <a href="/solutions/energy-storage" class="group/item flex items-center gap-3 rounded-lg p-2.5 hover:bg-primary-50 transition-colors" role="menuitem">
                              <div class="shrink-0 inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent-soft text-primary-dark ring-1 ring-accent/20">
                                <img src={solutionNavIcons["/solutions/energy-storage"]} alt="" class="h-6 w-6 object-contain" loading="lazy" decoding="async" />
                              </div>
                              <div class="text-sm font-semibold text-primary-dark group-hover/item:text-primary transition-colors">Energy Storage</div>
                            </a>

                            <a href="/solutions/green-hydrogen" class="group/item flex items-center gap-3 rounded-lg p-2.5 hover:bg-primary-50 transition-colors" role="menuitem">
                              <div class="shrink-0 inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent-soft text-primary-dark ring-1 ring-accent/20">
                                <img src={solutionNavIcons["/solutions/green-hydrogen"]} alt="" class="h-6 w-6 object-contain" loading="lazy" decoding="async" />
                              </div>
                              <div class="text-sm font-semibold text-primary-dark group-hover/item:text-primary transition-colors">Green Hydrogen</div>
                            </a>
                          </div>

                          {/* Col 2 */}
                          <div class="flex flex-col gap-2">
                            <a href="/solutions/water-desalination" class="group/item flex items-center gap-3 rounded-lg p-2.5 hover:bg-primary-50 transition-colors" role="menuitem">
                              <div class="shrink-0 inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent-soft text-primary-dark ring-1 ring-accent/20">
                                <img src={solutionNavIcons["/solutions/water-desalination"]} alt="" class="h-6 w-6 object-contain" loading="lazy" decoding="async" />
                              </div>
                              <div class="text-sm font-semibold text-primary-dark group-hover/item:text-primary transition-colors">Water & Desalination</div>
                            </a>

                            <a href="/solutions/integrated-infrastructure" class="group/item flex items-center gap-3 rounded-lg p-2.5 hover:bg-primary-50 transition-colors" role="menuitem">
                              <div class="shrink-0 inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent-soft text-primary-dark ring-1 ring-accent/20">
                                <img src={solutionNavIcons["/solutions/integrated-infrastructure"]} alt="" class="h-6 w-6 object-contain" loading="lazy" decoding="async" />
                              </div>
                              <div class="text-sm font-semibold text-primary-dark group-hover/item:text-primary transition-colors">Architectural BIPV &amp; Integrated Solar Solutions</div>
                            </a>
                          </div>
                        </div>
                      </div>
                    </div>

                    {/* Footer Row */}
                    <div class="mt-6 pt-4 border-t border-primary/5 flex justify-end">
                      <a href="/solutions" class="inline-flex items-center gap-1.5 text-xs font-semibold text-primary hover:text-accent transition-colors">
                        View All Solutions
                        <svg viewBox="0 0 20 20" class="h-3.5 w-3.5" fill="none">
                          <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    </div>
                  </Container>
                ) : (
                  <Container class="py-8">
                    <div class="grid gap-4 grid-cols-[repeat(auto-fit,minmax(220px,1fr))]">
                      {item.children.map((c) => (
                        <a
                          href={c.href}
                          class="block rounded-lg px-4 py-3 hover:bg-primary-50 transition-colors"
                          role="menuitem"
                        >
                          <div class="text-base font-semibold text-primary-dark">{c.label}</div>
                          {c.desc && <div class="text-sm text-muted mt-1">{c.desc}</div>}
                        </a>
                      ))}
                    </div>
                  </Container>
                )}
              </div>
            </div>
          )}
        </div>
      ))}
    </nav>

    <div class="hidden lg:flex items-center">
      <a
        href="/contact"
        class="nav-consult group/consult inline-flex min-h-[42px] items-center gap-3 rounded-full border border-primary/25 bg-transparent py-1 pl-5 pr-1 text-sm font-medium text-primary-dark transition-all duration-200 hover:border-primary/50 hover:bg-primary/5"
      >
        Request Consultation
        <span class="nav-consult-arrow inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-white transition-all duration-200 group-hover/consult:rotate-45" aria-hidden="true">
          <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none">
            <path d="M4 12 12 4m0 0H6.25M12 4v5.75" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
      </a>
    </div>

    <button
      type="button"
      class="lg:hidden inline-flex items-center justify-center h-11 w-11 rounded-lg text-ink hover:bg-primary-50 transition-colors"
      aria-label="Open menu"
      aria-controls="mobile-drawer"
      aria-expanded="false"
      data-drawer-toggle
    >
      <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </Container>
</header>

<!-- Keep the mobile drawer outside the fixed header so it remains independently viewport-positioned. -->
<div
  class="lg:hidden fixed inset-0 z-[85] pointer-events-none opacity-0 transition-opacity duration-200"
  data-drawer-backdrop
  aria-hidden="true"
>
  <div class="absolute inset-0 bg-primary-dark/50"></div>
</div>

<aside
  id="mobile-drawer"
  class="lg:hidden fixed top-0 right-0 z-[90] h-[100dvh] w-[88vw] max-w-sm bg-white text-ink translate-x-full transition-transform duration-250 ease-out shadow-2xl flex flex-col"
  data-drawer
  aria-hidden="true"
>
  <div class="flex items-center justify-between p-5 border-b border-primary/10">
    <img src="/logo.svg" alt="" class="h-8 w-auto" />
    <button
      type="button"
      class="inline-flex items-center justify-center h-11 w-11 rounded-lg text-ink hover:bg-primary-50"
      aria-label="Close menu"
      data-drawer-close
    >
      <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <nav class="flex-1 overflow-y-auto p-3" aria-label="Mobile primary">
    {nav.map((item) => item.children ? (
      <details class="group border-b border-primary/5 last:border-b-0">
        <summary class="flex items-center justify-between px-3 py-3.5 rounded-lg text-base font-semibold text-ink cursor-pointer list-none">
          <a href={item.href} data-drawer-link>{item.label}</a>
          <svg viewBox="0 0 12 12" class="h-3 w-3 text-muted transition-transform group-open:rotate-180" fill="none" aria-hidden="true">
            <path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <div class="pb-2 pl-3">
          {item.label === "Solutions" ? (
            <>
              <div class="px-3 py-1.5 text-xs font-bold uppercase tracking-[0.1em] text-muted">How We Deliver</div>
              {item.children.slice(0, 3).map((c) => (
                <a
                  href={c.href}
                  class="flex items-center gap-3 rounded-md px-4 py-2 text-sm text-muted hover:text-primary hover:bg-primary-50"
                  data-drawer-link
                >
                  <img src={solutionNavIcons[c.href]} alt="" class="h-7 w-7 shrink-0 object-contain" loading="lazy" decoding="async" aria-hidden="true" />
                  <span>{c.label}</span>
                </a>
              ))}
              <div class="mt-2 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.1em] text-muted">Core Solutions</div>
              {item.children.slice(3).map((c) => (
                <a
                  href={c.href}
                  class="flex items-center gap-3 rounded-md px-4 py-2 text-sm text-muted hover:text-primary hover:bg-primary-50"
                  data-drawer-link
                >
                  <img src={solutionNavIcons[c.href]} alt="" class="h-7 w-7 shrink-0 object-contain" loading="lazy" decoding="async" aria-hidden="true" />
                  <span>{c.label}</span>
                </a>
              ))}
            </>
          ) : (
            item.children.map((c) => (
              <a
                href={c.href}
                class="block rounded-md px-3 py-2 text-sm text-muted hover:text-primary hover:bg-primary-50"
                data-drawer-link
              >{c.label}</a>
            ))
          )}
        </div>
      </details>
    ) : (
      <div class="border-b border-primary/5 last:border-b-0">
        <a
          href={item.href}
          class="block px-3 py-3.5 rounded-lg text-base font-semibold text-ink hover:text-primary hover:bg-primary-50 transition-colors"
          data-drawer-link
        >
          {item.label}
        </a>
      </div>
    ))}
  </nav>
  <div class="p-4 border-t border-primary/10">
    <a
      href="/contact"
      class="nav-consult group/consult flex min-h-[48px] w-full items-center justify-between gap-3 rounded-full border border-primary/20 bg-white py-1 pl-5 pr-1 text-sm font-semibold text-primary-dark shadow-sm transition-all duration-200 hover:border-primary/40 hover:bg-primary/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
      data-drawer-link
    >
      Request Consultation
      <span class="nav-consult-arrow inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary text-white transition-all duration-200" aria-hidden="true">
        <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none">
          <path d="M4 12 12 4m0 0H6.25M12 4v5.75" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </a>
  </div>
</aside>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-drawer-toggle]");
  const drawer = document.querySelector<HTMLElement>("[data-drawer]");
  const backdrop = document.querySelector<HTMLElement>("[data-drawer-backdrop]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-drawer-close]");
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-drawer-link]");

  let scrollLockY = 0;

  const open = () => {
    if (!drawer || !backdrop || !toggle) return;
    drawer.classList.remove("translate-x-full");
    drawer.setAttribute("aria-hidden", "false");
    backdrop.classList.remove("opacity-0", "pointer-events-none");
    toggle.setAttribute("aria-expanded", "true");

    // Lock page scroll — pin body at current scroll so iOS Safari can't rubber-band either.
    scrollLockY = window.scrollY;
    document.documentElement.style.overflow = "hidden";
    document.body.style.overflow = "hidden";
    document.body.style.position = "fixed";
    document.body.style.top = `-${scrollLockY}px`;
    document.body.style.left = "0";
    document.body.style.right = "0";
    document.body.style.width = "100%";
  };

  const close = () => {
    if (!drawer || !backdrop || !toggle) return;
    drawer.classList.add("translate-x-full");
    drawer.setAttribute("aria-hidden", "true");
    backdrop.classList.add("opacity-0", "pointer-events-none");
    toggle.setAttribute("aria-expanded", "false");

    // Unlock scroll and restore the exact position the user was on.
    document.documentElement.style.overflow = "";
    document.body.style.overflow = "";
    document.body.style.position = "";
    document.body.style.top = "";
    document.body.style.left = "";
    document.body.style.right = "";
    document.body.style.width = "";
    // Explicit "instant" bypasses the global `scroll-behavior: smooth`,
    // which otherwise animates the restore over several seconds on long
    // pages and makes the page feel frozen right after closing the drawer.
    window.scrollTo({ top: scrollLockY, left: 0, behavior: "instant" });
  };

  toggle?.addEventListener("click", open);
  closeBtn?.addEventListener("click", close);
  backdrop?.addEventListener("click", close);
  links.forEach((l) => l.addEventListener("click", close));
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });

  const header = document.querySelector<HTMLElement>("[data-header]");
  // Keep the header transparent at the top of every page, then switch to a
  // solid white navigation bar once the visitor starts scrolling.
  const updateHeader = () => {
    if (!header) return;
    const scrolled = window.scrollY > 40;
    header.classList.toggle("is-transparent", !scrolled);
    header.classList.toggle("shadow-sm", scrolled);
  };
  // Coalesce scroll updates into one per animation frame — an unthrottled
  // listener on a sticky, blurred header is a common source of scroll jank.
  let ticking = false;
  window.addEventListener(
    "scroll",
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        updateHeader();
        ticking = false;
      });
    },
    { passive: true }
  );
  updateHeader();
</script>

<style>
  /* Default header logo behavior: dark wordmark visible, light one hidden */
  [data-header] .logo-light { display: none; }
  [data-header] .logo-dark  { display: block; }

  /* Smooth transitions when flipping between transparent and solid states */
  [data-header] {
    transition: background-color 0.28s ease, border-color 0.28s ease, backdrop-filter 0.28s ease;
  }
  [data-header] [data-drawer-toggle] {
    transition: color 0.28s ease, background-color 0.28s ease;
  }

  /* Transparent state over every page hero at the top of the page */
  [data-header].is-transparent {
    background: transparent !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    border-bottom-color: transparent !important;
  }
  [data-header].is-transparent .logo-dark  { display: none; }
  [data-header].is-transparent .logo-light { display: block; }
  [data-header].is-transparent [data-drawer-toggle] {
    color: #ffffff;
  }
  [data-header].is-transparent [data-drawer-toggle]:hover {
    background-color: rgba(255, 255, 255, 0.12);
  }
  [data-header].is-transparent [data-primary-nav] > [data-nav-item] > a,
  [data-header].is-transparent [data-primary-nav] > [data-nav-item] > button {
    color: rgba(255, 255, 255, 0.9);
  }
  [data-header].is-transparent [data-primary-nav] > [data-nav-item] > a:hover,
  [data-header].is-transparent [data-primary-nav] > [data-nav-item] > button:hover {
    color: #ffffff;
  }
  [data-header].is-transparent .nav-consult {
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.52);
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  [data-header].is-transparent .nav-consult:hover {
    border-color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.14);
  }
  [data-header].is-transparent .nav-consult-arrow {
    color: #003b64;
