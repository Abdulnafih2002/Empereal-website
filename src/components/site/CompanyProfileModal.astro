<div
  id="company-profile-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-6"
  role="dialog"
  aria-modal="true"
  aria-labelledby="company-profile-modal-title"
  aria-hidden="true"
  data-company-profile-modal
>
  <button
    type="button"
    class="absolute inset-0 bg-primary-dark/75 backdrop-blur-sm"
    aria-label="Close company profile form"
    data-company-profile-close
  ></button>

  <div class="relative z-10 max-h-[92dvh] w-full max-w-xl overflow-y-auto rounded-2xl bg-white p-5 shadow-2xl sm:p-8">
    <div class="flex items-start justify-between gap-5">
      <div class="min-w-0">
        <p class="eyebrow">Company Profile</p>
        <h2 id="company-profile-modal-title" class="mt-2 font-display text-2xl font-semibold text-primary-dark sm:text-3xl">
          Download Empereal’s Company Profile
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-muted">
          Please share your contact details. Once your enquiry is saved, the company profile will download automatically.
        </p>
      </div>
      <button
        type="button"
        class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-primary/10 text-primary-dark transition-colors hover:bg-primary/5"
        aria-label="Close company profile form"
        data-company-profile-close
      >
        <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
          <path d="M5 5l10 10M15 5 5 15" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <form class="mt-6 space-y-5" data-company-profile-form novalidate>
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="profile-name" class="mb-1.5 block text-sm font-medium text-ink">Full Name <span class="text-red-500" aria-hidden="true">*</span></label>
          <input id="profile-name" name="name" type="text" required autocomplete="name" class="min-h-[48px] w-full rounded-lg border border-primary/20 bg-white px-4 py-3 text-sm text-ink placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Your full name" />
        </div>
        <div>
          <label for="profile-company" class="mb-1.5 block text-sm font-medium text-ink">Company <span class="text-red-500" aria-hidden="true">*</span></label>
          <input id="profile-company" name="company" type="text" required autocomplete="organization" class="min-h-[48px] w-full rounded-lg border border-primary/20 bg-white px-4 py-3 text-sm text-ink placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Company name" />
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="profile-email" class="mb-1.5 block text-sm font-medium text-ink">Email Address <span class="text-red-500" aria-hidden="true">*</span></label>
          <input id="profile-email" name="email" type="email" required autocomplete="email" class="min-h-[48px] w-full rounded-lg border border-primary/20 bg-white px-4 py-3 text-sm text-ink placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="you@company.com" />
        </div>
        <div>
          <label for="profile-phone" class="mb-1.5 block text-sm font-medium text-ink">Phone Number <span class="text-red-500" aria-hidden="true">*</span></label>
          <input id="profile-phone" name="phone" type="tel" required autocomplete="tel" class="min-h-[48px] w-full rounded-lg border border-primary/20 bg-white px-4 py-3 text-sm text-ink placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="+971 50 000 0000" />
        </div>
      </div>

      <p class="hidden text-sm" aria-live="polite" data-company-profile-status></p>

      <div class="flex flex-col gap-3 border-t border-primary/10 pt-5 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-xs leading-relaxed text-muted">
          Your details will be handled according to our <a href="/privacy-policy" class="font-semibold text-primary hover:text-accent-dark">Privacy Policy</a>.
        </p>
        <button type="submit" class="site-cta site-cta-solid shrink-0" data-company-profile-submit>
          Submit &amp; Download
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  const modal = document.querySelector<HTMLElement>("[data-company-profile-modal]");
  const form = modal?.querySelector<HTMLFormElement>("[data-company-profile-form]");
  const submit = modal?.querySelector<HTMLButtonElement>("[data-company-profile-submit]");
  const status = modal?.querySelector<HTMLElement>("[data-company-profile-status]");
  const closeButtons = modal?.querySelectorAll<HTMLButtonElement>("[data-company-profile-close]");
  const triggers = document.querySelectorAll<HTMLElement>("[data-company-profile-download]");
  const pdfUrl = "/empereal-company-profile.pdf";
  const pdfFilename = "Empereal-Energy-Services-Company-Profile.pdf";
  let returnFocus: HTMLElement | null = null;

  const openModal = (trigger: HTMLElement) => {
    if (!modal) return;
    returnFocus = trigger;
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    modal.setAttribute("aria-hidden", "false");
    document.documentElement.style.overflow = "hidden";
    requestAnimationFrame(() => modal.querySelector<HTMLInputElement>("input")?.focus());
  };

  const closeModal = () => {
    if (!modal || submit?.disabled) return;
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    modal.setAttribute("aria-hidden", "true");
    document.documentElement.style.overflow = "";
    returnFocus?.focus();
  };

  triggers.forEach((trigger) => {
    trigger.addEventListener("click", (event) => {
      event.preventDefault();
      openModal(trigger);
    });
  });
  closeButtons?.forEach((button) => button.addEventListener("click", closeModal));
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && modal?.getAttribute("aria-hidden") === "false") closeModal();
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form || !submit || !status) return;

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const values = Object.fromEntries(new FormData(form)) as Record<string, string>;
    submit.disabled = true;
    submit.textContent = "Saving…";
    status.className = "hidden text-sm";

    try {
      const response = await fetch("/api/enquiries/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          ...values,
          interest: "Company Profile Download",
          message: "Downloaded the Empereal company profile through the website.",
        }),
      });
      const result = await response.json() as { error?: string };
      if (!response.ok) throw new Error(result.error || "Unable to save your details.");

      status.textContent = "Thank you. Your download is starting…";
      status.className = "text-sm font-medium text-success";
      const analyticsWindow = window as Window & {
        emperealTrack?: (name: string, params?: Record<string, string | number | boolean>) => void;
      };
      analyticsWindow.emperealTrack?.("generate_lead", {
        lead_source: "company_profile_download",
        form_name: "company_profile_download",
      });

      const download = document.createElement("a");
      download.href = pdfUrl;
      download.download = pdfFilename;
      document.body.appendChild(download);
      download.click();
      download.remove();
      form.reset();
      window.setTimeout(() => {
        submit.disabled = false;
        submit.textContent = "Submit & Download";
        closeModal();
        status.className = "hidden text-sm";
      }, 900);
    } catch (error) {
      status.textContent = error instanceof Error ? error.message : "Unable to save your details. Please try again.";
      status.className = "text-sm font-medium text-red-600";
      submit.disabled = false;
      submit.textContent = "Submit & Download";
    }
  });
</script>
