---
import Container from "../primitives/Container.astro";

const year = new Date().getFullYear();

const cols = [
  {
    title: "Quick Links",
    links: [
      { label: "About Empereal", href: "#about" },
      { label: "Solutions", href: "#experience" },
      { label: "Projects", href: "#projects" },
      { label: "News & Insights", href: "#news" },
    ],
  },
  {
    title: "Support",
    links: [
      { label: "FAQ", href: "#" },
      { label: "Help Center", href: "#" },
      { label: "Get a Quote", href: "#" },
      { label: "Talk to an Expert", href: "#" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Privacy Policy", href: "#" },
      { label: "Terms & Conditions", href: "#" },
      { label: "Cookie Policy", href: "#" },
    ],
  },
];
---
<footer id="footer" class="relative isolate overflow-hidden bg-primary-dark text-white/80">
  <!-- Background visual -->
  <div class="absolute inset-0 -z-10">
    <img
      src="/images/footer-bg.jpg"
      alt=""
      class="absolute inset-0 h-full w-full object-cover opacity-45"
      loading="lazy"
      decoding="async"
      onerror="this.remove()"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-primary-dark/75 via-primary-dark/65 to-ink/85" aria-hidden="true"></div>
  </div>

  <!-- Newsletter + WhatsApp row -->
  <div class="border-b border-white/10">
    <Container class="py-10 lg:py-14">
      <div class="grid gap-8 lg:grid-cols-[1.3fr_1fr] lg:items-center">
        <div>
          <h3 class="font-display text-xl sm:text-2xl font-semibold text-white">
            Subscribe to Our Newsletter
          </h3>
          <p class="mt-2 text-sm text-white/70 max-w-md">
            Get the latest updates and insights delivered to your inbox.
          </p>
          <form class="mt-5 flex flex-col sm:flex-row items-stretch gap-3 max-w-xl" data-newsletter novalidate>
            <label class="sr-only" for="footer-email">Email address</label>
            <input
              id="footer-email"
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="Enter your email"
              class="w-full rounded-md border border-white/20 bg-white/95 px-4 py-3 text-base text-ink placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-success focus:border-transparent min-h-[48px]"
            />
            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 rounded-md bg-success hover:bg-success-dark px-6 py-3 text-sm font-semibold text-white transition-colors min-h-[48px] shadow-sm"
            >
              Subscribe
            </button>
          </form>
          <p class="mt-2 text-xs text-white/60" data-newsletter-status aria-live="polite"></p>
        </div>

        <!-- WhatsApp assistance -->
        <div class="rounded-xl bg-white/5 ring-1 ring-white/10 p-5 lg:p-6 backdrop-blur-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Need Instant Assistance?</p>
          <p class="mt-2 text-sm text-white/80">
            Chat with a senior engineer on WhatsApp for a same-day response.
          </p>
          <a
            href="https://wa.me/971501234567"
            target="_blank"
            rel="noopener"
            class="mt-4 inline-flex items-center gap-2 rounded-md bg-success hover:bg-success-dark px-5 py-2.5 text-sm font-semibold text-white transition-colors min-h-[44px] shadow-sm"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2s-.8.9-1 1.1c-.2.2-.4.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5H8c-.2 0-.5.1-.7.3-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3.2 5 4.4.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.3-.7.3-1.2.2-1.4-.1-.2-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.4c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/>
            </svg>
            Chat on WhatsApp
          </a>
        </div>
      </div>
    </Container>
  </div>

  <!-- Link columns -->
  <Container class="py-12 lg:py-16">
    <div class="grid grid-cols-2 gap-x-6 gap-y-10 sm:gap-10 lg:grid-cols-[1.3fr_repeat(4,1fr)]">
      <div class="col-span-2 lg:col-span-1 max-w-sm">
        <img src="/logo-light.svg" alt="Empereal — Energizing Communities" class="h-10 w-auto" />
        <p class="mt-5 text-sm leading-relaxed text-white/70">
          Empereal is a global solar energy solutions provider delivering high-performance, future-ready EPC projects across commercial, industrial, and utility sectors.
        </p>
      </div>

      {cols.map((col) => (
        <div>
          <h4 class="text-white text-sm font-semibold uppercase tracking-[0.14em]">{col.title}</h4>
          <ul class="mt-4 space-y-2.5 text-sm">
            {col.links.map((l) => (
              <li>
                <a href={l.href} class="text-white/70 hover:text-white transition-colors">{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div>
        <h4 class="text-white text-sm font-semibold uppercase tracking-[0.14em]">Contact</h4>
        <ul class="mt-4 space-y-2.5 text-sm text-white/70">
          <li class="flex items-start gap-2">
            <svg viewBox="0 0 20 20" class="h-4 w-4 mt-0.5 text-accent shrink-0" fill="none" aria-hidden="true">
              <path d="M10 2c3.3 0 6 2.7 6 6 0 4.5-6 10-6 10S4 12.5 4 8c0-3.3 2.7-6 6-6z" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="10" cy="8" r="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
            </svg>
            Dubai, United Arab Emirates
          </li>
          <li class="flex items-start gap-2">
            <svg viewBox="0 0 20 20" class="h-4 w-4 mt-0.5 text-accent shrink-0" fill="none" aria-hidden="true">
              <rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 6l8 6 8-6" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <a href="mailto:info@empereal.com" class="hover:text-white">info@empereal.com</a>
          </li>
          <li class="flex items-start gap-2">
            <svg viewBox="0 0 20 20" class="h-4 w-4 mt-0.5 text-accent shrink-0" fill="none" aria-hidden="true">
              <path d="M4 5c0-.5.4-1 1-1h2l1.5 3.5L7 9c.8 1.5 2 2.7 3.5 3.5L12 11l3.5 1.5V15c0 .5-.4 1-1 1C9 16 4 11 4 5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
            +971 50 123 4567
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-white/10 pt-6 text-xs text-white/60 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} Empereal Energy Solutions. All rights reserved.</p>
      <div class="flex items-center gap-5">
        <a href="#" class="hover:text-white">Privacy</a>
        <a href="#" class="hover:text-white">Terms</a>
        <a href="#" class="hover:text-white">Cookies</a>
      </div>
    </div>
  </Container>
</footer>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-newsletter]");
  const status = document.querySelector<HTMLElement>("[data-newsletter-status]");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = form.querySelector<HTMLInputElement>('input[name="email"]');
    const email = input?.value.trim() ?? "";
    const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    if (!status || !input) return;
    if (!valid) {
      status.textContent = "Please enter a valid email address.";
      status.classList.remove("text-white/80");
      status.classList.add("text-orange");
      return;
    }
    console.log("[newsletter] subscribe", email);
    status.textContent = "Thanks — you're on the list.";
    status.classList.remove("text-orange");
    status.classList.add("text-white/80");
    form.reset();
  });
</script>
