---
const year = new Date().getFullYear();

interface FooterLink {
  label: string;
  href: string;
  profileDownload?: boolean;
}

const quickLinks: FooterLink[] = [
  { label: "Home", href: "/" },
  { label: "About Empereal", href: "/about" },
  { label: "Leadership", href: "/leadership" },
  { label: "Projects", href: "/projects" },
  { label: "News & Insights", href: "/blog" },
  { label: "Contact", href: "/contact" },
  { label: "Admin Panel", href: "/crm" },
  { label: "Company Profile", href: "#company-profile-download", profileDownload: true },
];

---
<footer id="footer" class="relative isolate overflow-hidden bg-primary-dark text-white/80">
  <div class="relative">

    <!-- TOP: image-backed row with logo/desc LEFT + newsletter RIGHT -->
    <div class="relative isolate">
      <div class="absolute inset-0 -z-10">
        <img
          src="/images/footer-bg.jpg"
          alt=""
          class="absolute inset-0 h-full w-full object-cover opacity-60"
          loading="lazy"
          decoding="async"
          onerror="this.remove()"
        />
        <!-- Gradient: slightly darker at top for text legibility, blends into the solid bottom half -->
        <div class="absolute inset-0 bg-gradient-to-b from-primary-dark/70 via-primary-dark/50 to-primary-dark" aria-hidden="true"></div>
      </div>

      <div class="relative mx-auto w-full max-w-7xl px-5 py-10 sm:px-8 sm:py-12 lg:px-10 lg:py-14 xl:px-6">
        <div class="grid gap-10 lg:grid-cols-[1.3fr_1fr] lg:items-center">
          <!-- Logo + company description -->
          <div>
            <img src="/logo-light.svg" alt="Empereal — Energizing Communities" class="h-10 w-auto" />
            <p class="mt-5 text-sm sm:text-base leading-relaxed text-white/85 max-w-md">
              Empereal is a global solar energy solutions provider delivering high-performance, future-ready EPC projects across commercial, industrial, and utility sectors.
            </p>
          </div>

          <!-- Newsletter -->
          <div>
            <h3 class="font-display text-xl sm:text-2xl font-semibold text-white">
              Subscribe to Our Newsletter
            </h3>
            <p class="mt-2 text-sm text-white/75">
              Get the latest updates and insights delivered to your inbox.
            </p>
            <form class="mt-5 flex max-w-md flex-col gap-2 sm:flex-row sm:items-center sm:gap-0 sm:rounded-full sm:bg-white/95 sm:p-1" data-newsletter novalidate>
              <label class="sr-only" for="footer-email">Email address</label>
              <input
                id="footer-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="Enter your email"
                class="min-h-[48px] w-full rounded-full bg-white px-5 py-3 text-base text-ink placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary/25 sm:min-w-0 sm:flex-1 sm:bg-transparent sm:focus:ring-0"
              />
              <button
                type="submit"
                class="group inline-flex min-h-[50px] w-[70%] max-w-[15rem] self-start items-center justify-between rounded-full border border-white/15 bg-gradient-to-r from-primary-dark to-primary-light py-1 pl-5 pr-1 text-sm font-semibold text-white shadow-lg shadow-black/20 transition-all duration-200 hover:-translate-y-0.5 hover:border-orange/60 hover:shadow-xl hover:shadow-black/25 sm:min-h-[44px] sm:w-auto sm:max-w-none sm:shrink-0 sm:self-auto"
              >
                <span class="pr-4 tracking-[0.01em]">Subscribe</span>
                <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-orange text-primary-dark shadow-sm ring-1 ring-white/25 transition-transform duration-200 group-hover:rotate-45 sm:h-9 sm:w-9" aria-hidden="true">
                  <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none">
                    <path d="M4 12 12 4m0 0H6.25M12 4v5.75" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </button>
            </form>
            <p class="mt-2 text-xs text-white/70" data-newsletter-status aria-live="polite"></p>
          </div>
        </div>
      </div>
    </div>

    <!-- DIVIDER between image-top and solid-bottom -->
    <div class="border-t border-white/10"></div>

    <!-- BOTTOM: useful links and complete office details -->
    <div class="relative bg-primary-dark">
      <div class="mx-auto w-full max-w-7xl px-5 py-9 sm:px-8 sm:py-10 lg:px-10 xl:px-6">
        <div class="grid grid-cols-2 gap-x-4 gap-y-8 sm:gap-x-10 lg:grid-cols-[1.3fr_1fr] lg:gap-x-16">
          <nav aria-label="Footer navigation">
            <h4 class="text-base font-semibold text-white">Quick Links</h4>
            <ul class="mt-4 space-y-2.5 text-sm sm:grid sm:grid-cols-2 sm:gap-x-8 sm:gap-y-2.5 sm:space-y-0 lg:grid-cols-3">
              {quickLinks.map((link) => (
                <li>
                  <a href={link.href} data-company-profile-download={link.profileDownload || undefined} class="inline-flex min-h-6 items-center text-white/70 transition-colors hover:text-white">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>

          <section aria-labelledby="footer-contact-title">
            <h4 id="footer-contact-title" class="text-base font-semibold text-white">Contact</h4>
            <address class="mt-4 text-sm not-italic text-white/70">
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg viewBox="0 0 20 20" class="mt-0.5 h-4 w-4 shrink-0 text-orange" fill="none" aria-hidden="true">
                    <path d="M10 2.5a5.5 5.5 0 0 0-5.5 5.5c0 4.1 5.5 9.5 5.5 9.5s5.5-5.4 5.5-9.5A5.5 5.5 0 0 0 10 2.5Z" stroke="currentColor" stroke-width="1.5"/>
                    <circle cx="10" cy="8" r="1.8" stroke="currentColor" stroke-width="1.5"/>
                  </svg>
                  <span>Dubai, United Arab Emirates</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg viewBox="0 0 20 20" class="mt-0.5 h-4 w-4 shrink-0 text-orange" fill="none" aria-hidden="true">
                    <rect x="2.5" y="4" width="15" height="12" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                    <path d="m3.5 5.5 6.5 5 6.5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <a href="mailto:info@emperealenergy.com" class="break-all transition-colors hover:text-white">info@emperealenergy.com</a>
                </li>
                <li class="flex items-start gap-3">
                  <svg viewBox="0 0 20 20" class="mt-0.5 h-4 w-4 shrink-0 text-orange" fill="none" aria-hidden="true">
                    <path d="M5 3.5h2.2l1.3 3.3-1.6 1.4a11 11 0 0 0 4.9 4.9l1.4-1.6 3.3 1.3V15c0 .8-.7 1.5-1.5 1.5A11.5 11.5 0 0 1 3.5 5C3.5 4.2 4.2 3.5 5 3.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <a href="tel:+97148835515" class="transition-colors hover:text-white">+971 4 883 5515</a>
                </li>
                <li class="flex items-start gap-3">
                  <svg viewBox="0 0 20 20" class="mt-0.5 h-4 w-4 shrink-0 text-orange" fill="currentColor" aria-hidden="true">
                    <path d="M10 2.5a7 7 0 0 0-6 10.6L3 17.5l4.5-1.1A7 7 0 1 0 10 2.5Z"/>
                  </svg>
                  <a href="https://wa.me/971563762386" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">Chat on WhatsApp</a>
                </li>
              </ul>
            </address>
          </section>
        </div>

        <!-- Copyright strip -->
        <div class="mt-8 flex flex-col gap-4 border-t border-white/10 pt-5 text-xs text-white/60 lg:flex-row lg:items-center lg:justify-between">
          <p class="leading-5">© {year} <span class="font-semibold text-white/85">Empereal Energy Solutions</span>. All rights reserved.</p>
          <nav aria-label="Legal" class="flex flex-wrap items-center gap-x-3 gap-y-2">
            <a href="/privacy-policy" class="hover:text-white">Privacy</a>
            <span class="text-white/20" aria-hidden="true">|</span>
            <a href="/terms-of-service" class="hover:text-white">Terms</a>
            <span class="text-white/20" aria-hidden="true">|</span>
            <a href="/cookie-policy" class="hover:text-white">Cookies</a>
            <span class="text-white/20" aria-hidden="true">|</span>
            <a href="#cookie-settings" class="hover:text-white">Cookie Settings</a>
          </nav>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-newsletter]");
  const status = document.querySelector<HTMLElement>("[data-newsletter-status]");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = form.querySelector<HTMLInputElement>('input[name="email"]');
    const email = input?.value.trim() ?? "";
    const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    if (!status || !input) return;
    if (!valid) {
      status.textContent = "Please enter a valid email address.";
      status.classList.remove("text-white/70");
      status.classList.add("text-orange");
      return;
    }
    console.log("[newsletter] subscribe", email);
    status.textContent = "Thanks — you're on the list.";
    status.classList.remove("text-orange");
    status.classList.add("text-white/70");
    form.reset();
  });

  // "Cookie Settings" footer link opens the consent modal
  document.querySelectorAll<HTMLAnchorElement>('a[href="#cookie-settings"]').forEach((a) => {
    a.addEventListener("click", (e) => {
      e.preventDefault();
      const open = (window as unknown as { openCookieSettings?: () => void }).openCookieSettings;
      if (typeof open === "function") open();
    });
  });
</script>
