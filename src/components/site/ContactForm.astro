---
// No props needed — all state managed client-side
---
<form
  id="contact-form"
  class="space-y-5"
  novalidate
  aria-label="Contact enquiry form"
>
  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="cf-name" class="block text-sm font-medium text-ink mb-1.5">Full Name <span class="text-red-500" aria-hidden="true">*</span></label>
      <input
        id="cf-name" name="name" type="text" required autocomplete="name"
        placeholder="John Smith"
        class="w-full rounded-lg border border-primary/20 bg-white px-4 py-3 text-sm text-ink placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 min-h-[48px]"
      />
    </div>
    <div>
      <label for="cf-company" class="block text-sm font-medium text-ink mb-1.5">Company / Organisation</label>
      <input
        id="cf-company" name="company" type="text" autocomplete="organization"
        placeholder="Acme Corp"
        class="w-full rounded-lg border border-primary/20 bg-white px-4 py-3 text-sm text-ink placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 min-h-[48px]"
      />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="cf-email" class="block text-sm font-medium text-ink mb-1.5">Email Address <span class="text-red-500" aria-hidden="true">*</span></label>
      <input
        id="cf-email" name="email" type="email" required autocomplete="email"
        placeholder="you@company.com"
        class="w-full rounded-lg border border-primary/20 bg-white px-4 py-3 text-sm text-ink placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 min-h-[48px]"
      />
    </div>
    <div>
      <label for="cf-phone" class="block text-sm font-medium text-ink mb-1.5">Phone Number</label>
      <input
        id="cf-phone" name="phone" type="tel" autocomplete="tel"
        placeholder="+971 50 000 0000"
        class="w-full rounded-lg border border-primary/20 bg-white px-4 py-3 text-sm text-ink placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 min-h-[48px]"
      />
    </div>
  </div>

  <div>
    <label for="cf-interest" class="block text-sm font-medium text-ink mb-1.5">Area of Interest</label>
    <select
      id="cf-interest" name="interest"
      class="w-full rounded-lg border border-primary/20 bg-white px-4 py-3 text-sm text-ink focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 min-h-[48px]"
    >
      <option value="">— Select a solution —</option>
      <option>Solar Power Systems</option>
      <option>Water &amp; Desalination</option>
      <option>Energy Storage Systems</option>
      <option>Architectural BIPV &amp; Integrated Solar Solutions</option>
      <option>Green Hydrogen Systems</option>
      <option>General Enquiry</option>
    </select>
  </div>

  <div>
    <label for="cf-message" class="block text-sm font-medium text-ink mb-1.5">Message <span class="text-red-500" aria-hidden="true">*</span></label>
    <textarea
      id="cf-message" name="message" required rows="5"
      placeholder="Briefly describe your project or enquiry..."
      class="w-full rounded-lg border border-primary/20 bg-white px-4 py-3 text-sm text-ink placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-none"
    ></textarea>
  </div>

  <p id="cf-status" class="text-sm hidden" aria-live="polite"></p>

  <button
    type="submit"
    id="cf-submit"
    class="inline-flex items-center justify-center gap-2 rounded-lg bg-cta hover:bg-cta-dark px-8 py-3.5 text-sm font-semibold text-primary-dark transition-colors min-h-[48px] shadow-sm disabled:opacity-60 disabled:cursor-not-allowed"
  >
    Send Enquiry
  </button>
</form>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("cf-status") as HTMLParagraphElement | null;
  const submit = document.getElementById("cf-submit") as HTMLButtonElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !status || !submit) return;

    status.classList.add("hidden");
    submit.disabled = true;
    submit.textContent = "Sending…";

    try {
      const res = await fetch("/api/enquiries/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      });
      const data = await res.json() as { error?: string };
      if (res.ok) {
        form.reset();
        status.textContent = "Thank you — we'll be in touch shortly.";
        status.className = "text-sm text-success font-medium";
        status.classList.remove("hidden");
      } else {
        status.textContent = data.error ?? "Something went wrong. Please try again.";
        status.className = "text-sm text-red-600";
        status.classList.remove("hidden");
      }
    } catch {
      status.textContent = "Network error. Please try again.";
      status.className = "text-sm text-red-600";
      status.classList.remove("hidden");
    } finally {
      submit.disabled = false;
      submit.textContent = "Send Enquiry";
    }
  });
</script>
