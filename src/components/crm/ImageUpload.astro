---
interface Props {
  name: string;
  value?: string;
  label?: string;
}
const { name, value = "", label = "Image" } = Astro.props;
const uid = `img-${name}`;
---

<div class="image-upload-field" data-uid={uid}>
  <p class="block text-sm font-medium text-slate-700 mb-2">{label}</p>
  <input type="hidden" name={name} id={`${uid}-url`} value={value} />

  <!-- Preview (shown when a URL is set) -->
  <div
    id={`${uid}-preview-wrap`}
    class={`relative mb-3 overflow-hidden rounded-lg ring-1 ring-slate-200${value ? "" : " hidden"}`}
  >
    <img id={`${uid}-preview`} src={value || ""} alt="" class="h-44 w-full object-cover" />
    <button
      type="button"
      id={`${uid}-remove`}
      class="absolute right-2 top-2 flex h-7 w-7 items-center justify-center rounded-full bg-black/50 text-white hover:bg-black/70 transition-colors"
      aria-label="Remove image"
    >
      <svg class="h-3.5 w-3.5" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M2 10L10 2M2 2l8 8"/>
      </svg>
    </button>
  </div>

  <!-- Placeholder drop zone (shown when no URL) -->
  <div
    id={`${uid}-placeholder`}
    class={`flex h-44 w-full cursor-pointer flex-col items-center justify-center rounded-lg border-2 border-dashed border-slate-200 bg-slate-50 mb-3 hover:border-orange hover:bg-orange/5 transition-colors${value ? " hidden" : ""}`}
  >
    <svg class="h-10 w-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
    </svg>
    <p class="mt-2 text-sm text-slate-400">Click to browse or drag &amp; drop</p>
    <p class="mt-0.5 text-xs text-slate-300">PNG, JPG, WebP &middot; max 4 MB</p>
  </div>

  <!-- Controls row -->
  <div class="flex items-center gap-3">
    <label
      for={`${uid}-file`}
      class="cursor-pointer inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50 transition-colors"
    >
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
      </svg>
      Choose file
    </label>
    <input id={`${uid}-file`} type="file" accept="image/jpeg,image/png,image/webp,image/gif" class="sr-only" />
    <span id={`${uid}-status`} class="text-xs text-slate-400"></span>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>(".image-upload-field").forEach((field) => {
    const uid = field.dataset.uid!;

    const fileInput  = document.getElementById(`${uid}-file`)         as HTMLInputElement | null;
    const urlInput   = document.getElementById(`${uid}-url`)          as HTMLInputElement | null;
    const preview    = document.getElementById(`${uid}-preview`)      as HTMLImageElement | null;
    const previewWrap= document.getElementById(`${uid}-preview-wrap`) as HTMLElement | null;
    const placeholder= document.getElementById(`${uid}-placeholder`)  as HTMLElement | null;
    const status     = document.getElementById(`${uid}-status`)       as HTMLElement | null;
    const removeBtn  = document.getElementById(`${uid}-remove`)       as HTMLButtonElement | null;

    function showPreview(url: string) {
      if (preview) preview.src = url;
      previewWrap?.classList.remove("hidden");
      placeholder?.classList.add("hidden");
    }

    function showPlaceholder() {
      previewWrap?.classList.add("hidden");
      placeholder?.classList.remove("hidden");
      if (preview) preview.src = "";
    }

    placeholder?.addEventListener("click", () => fileInput?.click());

    removeBtn?.addEventListener("click", () => {
      if (urlInput) urlInput.value = "";
      showPlaceholder();
    });

    fileInput?.addEventListener("change", async () => {
      const file = fileInput?.files?.[0];
      if (!file) return;

      if (!file.type.startsWith("image/")) {
        if (status) { status.textContent = "Only image files allowed"; status.className = "text-xs text-red-500"; }
        return;
      }

      if (file.size > 4 * 1024 * 1024) {
        if (status) { status.textContent = "Max 4 MB"; status.className = "text-xs text-red-500"; }
        return;
      }

      if (status) { status.textContent = "Uploading…"; status.className = "text-xs text-slate-400"; }

      // Optimistic local preview while uploading
      const objectUrl = URL.createObjectURL(file);
      showPreview(objectUrl);

      const fd = new FormData();
      fd.append("image", file);

      try {
        const res = await fetch("/api/crm/upload", { method: "POST", body: fd });
        const data = await res.json() as { url?: string; error?: string };

        if (res.ok && data.url) {
          if (urlInput) urlInput.value = data.url;
          showPreview(data.url);
          URL.revokeObjectURL(objectUrl);
          if (status) { status.textContent = "✓ Uploaded"; status.className = "text-xs text-green-600"; }
          setTimeout(() => { if (status) status.textContent = ""; }, 2500);
        } else {
          if (urlInput) urlInput.value = "";
          showPlaceholder();
          URL.revokeObjectURL(objectUrl);
          if (status) { status.textContent = data.error ?? "Upload failed"; status.className = "text-xs text-red-500"; }
        }
      } catch {
        if (urlInput) urlInput.value = "";
        showPlaceholder();
        URL.revokeObjectURL(objectUrl);
        if (status) { status.textContent = "Upload failed"; status.className = "text-xs text-red-500"; }
      }

      if (fileInput) fileInput.value = "";
    });
  });
</script>
