---
interface Props {
  src?: string;
  alt?: string;
  aspect?: string;
  label?: string;
  tone?: "navy" | "ocean" | "forest" | "sunset" | "mineral";
  rounded?: string;
  class?: string;
  eager?: boolean;
}

const {
  src,
  alt = "",
  aspect = "16/9",
  label = "Image",
  tone = "navy",
  rounded = "rounded-2xl",
  class: className = "",
  eager = false,
} = Astro.props;

const tones: Record<string, string> = {
  navy: "from-primary-dark via-primary to-primary-dark",
  ocean: "from-[#003B64] via-[#0d3555] to-[#0B1A2E]",
  forest: "from-[#0B2E1A] via-[#1a4d2e] to-[#003B64]",
  sunset: "from-[#2e1a0b] via-[#4d2e1a] to-[#003B64]",
  mineral: "from-[#1a2e0b] via-[#2a4a1a] to-[#003B64]",
};

const toneClass = tones[tone] ?? tones.navy;
---
<figure
  class={`relative overflow-hidden ${rounded} ${className}`}
  style={`aspect-ratio:${aspect};`}
>
  {src ? (
    <>
      <img
        src={src}
        alt={alt}
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 will-change-transform group-hover:scale-[1.04]"
        loading={eager ? "eager" : "lazy"}
        decoding="async"
        onerror="const f=this.nextElementSibling; if(f) f.removeAttribute('hidden'); this.remove();"
      />
      <div
        hidden
        class={`absolute inset-0 bg-gradient-to-br ${toneClass}`}
        aria-hidden="true"
      >
        <div class="absolute inset-0 opacity-[0.06]" aria-hidden="true">
          <svg width="100%" height="100%" viewBox="0 0 200 200" preserveAspectRatio="none">
            <defs>
              <pattern id="ph-grid" width="20" height="20" patternUnits="userSpaceOnUse">
                <path d="M20 0H0V20" fill="none" stroke="#F2994A" stroke-width=".5"/>
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#ph-grid)" />
          </svg>
        </div>
        <div class="absolute inset-x-0 bottom-0 px-4 py-3 flex items-center gap-2 text-[10px] uppercase tracking-[0.14em] text-white/55">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent"></span>
          <span>{label}</span>
        </div>
      </div>
    </>
  ) : (
    <div
      class={`absolute inset-0 bg-gradient-to-br ${toneClass}`}
      aria-label={alt || label}
      role="img"
    >
      <div class="absolute inset-0 opacity-[0.06]" aria-hidden="true">
        <svg width="100%" height="100%" viewBox="0 0 200 200" preserveAspectRatio="none">
          <defs>
            <pattern id={`ph-grid-${label.replace(/\W/g,"")}`} width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M20 0H0V20" fill="none" stroke="#F2994A" stroke-width=".5"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill={`url(#ph-grid-${label.replace(/\W/g,"")})`} />
        </svg>
      </div>
      <div class="absolute inset-x-0 bottom-0 px-4 py-3 flex items-center gap-2 text-[10px] uppercase tracking-[0.14em] text-white/55">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent animate-pulse-glow"></span>
        <span>{label}</span>
      </div>
    </div>
  )}
  <slot />
</figure>
