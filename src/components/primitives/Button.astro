---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost" | "accent";
  size?: "md" | "lg";
  class?: string;
  type?: "button" | "submit";
  id?: string;
  ariaLabel?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  class: className = "",
  type = "button",
  id,
  ariaLabel,
} = Astro.props;

const base = "site-cta select-none";
const sizes: Record<string, string> = {
  md: "",
  lg: "min-h-[48px] text-base",
};
const variants: Record<string, string> = {
  primary: "site-cta-solid",
  accent: "site-cta-solid",
  secondary: "",
  ghost: "site-cta-on-dark",
};

const classes = `${base} ${sizes[size]} ${variants[variant]} ${className}`;
const Tag = href ? "a" : "button";
---
<Tag
  class={classes}
  href={href}
  type={href ? undefined : type}
  id={id}
  aria-label={ariaLabel}
>
  <slot />
</Tag>
