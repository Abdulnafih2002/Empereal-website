---
import Container from "../../primitives/Container.astro";
import ImagePlaceholder from "../../primitives/ImagePlaceholder.astro";
import { projects, categoryLabels, type ProjectCategory } from "../../../data/projects.ts";

const filters: { key: "all" | ProjectCategory; label: string }[] = [
  { key: "all", label: "All" },
  { key: "bipv", label: "BIPV" },
  { key: "solar-pv", label: "Solar PV" },
  { key: "solar-thermal", label: "Solar Thermal" },
  { key: "desalination", label: "Desalination" },
  { key: "storage", label: "Energy Storage" },
  { key: "integrated", label: "Integrated" },
  { key: "utility", label: "Utility-Scale" },
];

const total = projects.length;
---
<section id="projects-grid" aria-labelledby="projects-grid-title">
  <h2 id="projects-grid-title" class="sr-only">Project portfolio</h2>

  {/* Sticky filter bar */}
  <div class="sticky top-16 lg:top-20 z-20 bg-white/95 backdrop-blur-md border-y border-primary/10">
    <Container class="py-4">
      <div class="flex items-center justify-between mb-3">
        <p class="text-sm text-muted">
          Showing <strong id="projects-count" class="text-primary-dark">{total} projects</strong>
          <span id="projects-filter-suffix" class="text-muted"> — click a filter to narrow by category</span>
        </p>
      </div>
      <ul class="flex gap-2 flex-wrap" role="tablist" aria-label="Filter projects by category">
        {filters.map((f) => (
          <li>
            <button
              type="button"
              data-filter={f.key}
              class="filter-pill press inline-flex items-center text-sm font-medium px-4 py-2 rounded-full border transition-all min-h-[36px]"
              role="tab"
              aria-selected={f.key === "all" ? "true" : "false"}
            >
              {f.label}
            </button>
          </li>
        ))}
      </ul>
    </Container>
  </div>

  <Container class="py-10 lg:py-12">
    <ul id="projects-list" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 reveal-stagger">
      {projects.map((p) => (
        <li
          class="project-card group flex flex-col rounded-2xl bg-white ring-1 ring-primary/10 overflow-hidden hover:-translate-y-1 hover:shadow-card-lg hover:ring-accent/40 transition-all"
          data-cats={p.categories.join(" ")}
        >
          <a href={`#${p.slug}`} class="block">
            <ImagePlaceholder
              src={p.image}
              alt={p.imageAlt ?? p.title}
              aspect="4/2.5"
              tone={p.tone}
              label={`${p.title} — ${p.location}`}
              rounded="rounded-none"
            >
              <span class="absolute left-3 top-3 inline-flex items-center gap-1.5 rounded-full bg-primary-dark/85 backdrop-blur-sm px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.05em] text-white">
                {p.country}
              </span>
            </ImagePlaceholder>
          </a>

          <div class="p-4 flex flex-col flex-1">
            <ul class="flex flex-wrap gap-1 mb-2">
              {p.categories.map((c) => (
                <li class="text-[10px] font-semibold uppercase tracking-[0.06em] px-2 py-0.5 rounded border border-accent/30 text-accent-dark bg-accent-soft">
                  {categoryLabels[c]}
                </li>
              ))}
            </ul>
            <h3 class="text-sm font-semibold text-primary-dark flex items-start justify-between gap-2">
              <span class="min-w-0 flex-1">{p.title}</span>
              <span class="text-muted shrink-0 group-hover:text-accent transition-colors" aria-hidden="true">
                <svg viewBox="0 0 20 20" class="h-3.5 w-3.5 arrow-slide" fill="none">
                  <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </h3>
            {p.scale !== "—" && (
              <p class="mt-1 text-xs font-semibold text-accent-dark">{p.scale}</p>
            )}
            <p class="mt-1.5 text-[12.5px] text-muted leading-relaxed">{p.summary}</p>
          </div>
        </li>
      ))}
    </ul>

    <p id="empty-state" hidden class="mt-12 text-center text-muted">No projects match this filter yet.</p>

    <p class="mt-10 text-center text-sm text-muted">
      Showing <span id="projects-count-bottom">{total}</span> of {total} projects —
      <a href="/contact" class="text-accent-dark font-semibold hover:text-accent transition-colors">
        Request the full project portfolio →
      </a>
    </p>
  </Container>
</section>

<style>
  .filter-pill {
    background: #fff;
    color: theme('colors.muted');
    border-color: rgba(31, 60, 92, 0.18);
  }
  .filter-pill:hover {
    border-color: rgba(245, 184, 46, 0.5);
    color: theme('colors.accent.dark');
  }
  .filter-pill[aria-selected="true"] {
    background: theme('colors.primary.dark');
    color: #fff;
    border-color: theme('colors.primary.dark');
  }
  .project-card.is-hidden {
    display: none;
  }
</style>

<script is:inline>
  (function () {
    const pills = Array.from(document.querySelectorAll('.filter-pill'));
    const cards = Array.from(document.querySelectorAll('.project-card'));
    const countTop = document.getElementById('projects-count');
    const countBottom = document.getElementById('projects-count-bottom');
    const suffix = document.getElementById('projects-filter-suffix');
    const empty = document.getElementById('empty-state');
    if (!pills.length || !cards.length) return;

    function applyFilter(key) {
      let visible = 0;
      let activeLabel = '';
      pills.forEach((p) => {
        const isActive = p.dataset.filter === key;
        p.setAttribute('aria-selected', isActive ? 'true' : 'false');
        if (isActive) activeLabel = p.textContent ? p.textContent.trim() : '';
      });
      cards.forEach((c) => {
        const cats = (c.dataset.cats || '').split(' ');
        const show = key === 'all' || cats.indexOf(key) !== -1;
        c.classList.toggle('is-hidden', !show);
        if (show) visible++;
      });
      const noun = visible === 1 ? 'project' : 'projects';
      if (countTop) countTop.textContent = visible + ' ' + noun;
      if (countBottom) countBottom.textContent = String(visible);
      if (suffix) {
        suffix.textContent =
          key === 'all'
            ? ' — click a filter to narrow by category'
            : ' in ' + activeLabel;
      }
      if (empty) empty.hidden = visible !== 0;
    }

    pills.forEach((p) => {
      p.addEventListener('click', () => applyFilter(p.dataset.filter || 'all'));
    });

    // Read ?filter= from URL on first load
    try {
      const params = new URLSearchParams(window.location.search);
      const initial = params.get('filter');
      if (initial && pills.some((p) => p.dataset.filter === initial)) {
        applyFilter(initial);
      }
    } catch {}
  })();
</script>
