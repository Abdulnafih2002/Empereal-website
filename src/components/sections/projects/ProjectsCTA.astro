---
import Container from "../../primitives/Container.astro";
---
<section class="bg-primary-dark text-white border-t border-accent/15" aria-labelledby="projects-cta-title">
  <Container>
    <div class="py-16 sm:py-20 text-center max-w-2xl mx-auto reveal">
      <h2 id="projects-cta-title" class="fluid-h2 text-white">Every project is a commitment to engineering excellence.</h2>
      <p class="mt-4 fluid-lead text-white/70 max-w-lg mx-auto">
        Talk to our engineering team about your energy and water infrastructure requirements.
      </p>
      <a
        href="/contact"
        class="site-cta site-cta-on-dark press mt-8"
      >
        Discuss Your Project
      </a>
    </div>
  </Container>
</section>
