---
import Container from "../../primitives/Container.astro";

const capabilities = [
  "Alkaline Electrolyser Systems",
  "Solar PV + Desalination Integration",
  "Green Hydrogen Production",
  "Full EPC & O&M",
];
---
<section
  class="page-hero relative isolate overflow-hidden bg-primary-dark text-white flex flex-col"
  aria-labelledby="hydrogen-hero-title"
>
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <img
      src="/images/feature-epc.jpg"
      alt=""
      class="h-full w-full object-cover"
      loading="eager"
      decoding="async"
      onerror="this.remove()"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/95 via-primary-dark/70 to-primary-dark/30"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/70 via-transparent to-transparent"></div>
    <div class="absolute -bottom-32 -right-32 h-[520px] w-[520px] rounded-full bg-accent/15 blur-[140px] animate-pulse-glow"></div>

  </div>

  <Container class="relative flex-1 flex items-start pt-32 sm:items-center sm:pt-0">
    <div class="pb-16 sm:py-20 lg:py-24 max-w-3xl">
      <p class="eyebrow !text-accent hero-enter hero-enter-1">Green Hydrogen</p>
      <h1 id="hydrogen-hero-title" class="fluid-display mt-4 text-white hero-enter hero-enter-2">
        High-quality solutions,<br/>
        <span class="text-accent">engineered to perform.</span>
      </h1>
      <p class="fluid-lead mt-6 text-white/80 max-w-2xl hero-enter hero-enter-3">
        Electrolyzer integration and fuel-switching solutions that turn surplus renewable energy into green hydrogen — powering industry, transport, and the wider energy transition.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row flex-wrap gap-3 hero-enter hero-enter-4">
        <a
          href="/projects"
          class="hero-home-pill"
        >
          View Projects
        </a>
      </div>

      <ul class="mt-10 flex flex-wrap gap-2 hero-enter hero-enter-4">
        {capabilities.map((capability) => (
          <li class="inline-flex items-center gap-2 rounded-md bg-white/[0.05] border border-white/10 px-3 py-2 text-[11px] text-white/70">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
            {capability}
          </li>
        ))}
      </ul>
    </div>
  </Container>
</section>

<style>
  .page-hero {
    min-height: calc(100vh - 6rem);
    min-height: calc(100svh - 6rem);
    min-height: calc(100dvh - 6rem);
  }
  @media (min-width: 1024px) {
    .page-hero {
      min-height: calc(100vh - 7rem);
      min-height: calc(100svh - 7rem);
      min-height: calc(100dvh - 7rem);
    }
  }
</style>
