---
import Container from "../../primitives/Container.astro";

const items = [
  {
    title: "Turnkey electrolyzer design & supply",
    desc: "End-to-end electrolyzer design, supply, and commissioning — sized to available renewable capacity and hydrogen demand.",
  },
  {
    title: "Containerized deployment",
    desc: "Containerized systems for rapid deployment and scalability across industrial and remote sites.",
  },
  {
    title: "Advanced gas treatment & purification",
    desc: "Gas treatment and purification to 99.999% purity for industrial and fuel-cell applications.",
  },
  {
    title: "Compression & storage integration",
    desc: "High-pressure compression and storage integration for downstream distribution and use.",
  },
  {
    title: "Renewable coupling",
    desc: "Direct coupling with solar PV and wind generation for genuinely renewable hydrogen production.",
  },
  {
    title: "Safety & compliance",
    desc: "Safety systems and compliance with international hydrogen standards across every installation.",
  },
  {
    title: "Fuel-switching solutions",
    desc: "Fuel-switching integration for industrial decarbonization and hydrogen fuel cell applications.",
  },
  {
    title: "Design, integration & commissioning",
    desc: "Full EPC scope from feasibility and balance-of-plant design through commissioning and certification.",
  },
];
---
<section class="section-pad bg-surface" aria-labelledby="hydrogen-scope-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow">Scope of services</p>
      <h2 id="hydrogen-scope-title" class="fluid-h2 mt-3">What we deliver</h2>
      <p class="fluid-lead mt-5 text-muted">
        Electrolyzer Integration · Fuel-Switching Solutions · Industrial Decarbonization · Hydrogen Fuel Cells — Empereal's green hydrogen scope spans the full project lifecycle from feasibility through long-term operations.
      </p>
    </div>

    <ul class="mt-10 grid gap-3 sm:grid-cols-2 reveal-stagger">
      {items.map((it) => (
        <li class="flex gap-3 rounded-xl bg-white ring-1 ring-primary/10 p-4 sm:p-5 hover:ring-accent/40 hover:shadow-card transition-all">
          <span class="mt-2 inline-block h-[2px] w-4 bg-accent rounded-full shrink-0" aria-hidden="true"></span>
          <div class="min-w-0">
            <h3 class="text-sm sm:text-[15px] font-semibold text-primary-dark">{it.title}</h3>
            <p class="mt-1.5 text-sm text-muted leading-relaxed">{it.desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </Container>
</section>
