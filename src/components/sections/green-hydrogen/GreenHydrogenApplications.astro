---
import Container from "../../primitives/Container.astro";

const cases = [
  {
    title: "Industrial decarbonization",
    desc: "Steel, cement, and chemicals manufacturers replacing fossil fuel feedstocks with green hydrogen to meet emissions targets.",
    icon: "factory",
  },
  {
    title: "Heavy transport & shipping fuel",
    desc: "Hydrogen fuel supply for heavy vehicles, shipping, and other hard-to-electrify transport applications.",
    icon: "transport",
  },
  {
    title: "Ammonia & fertilizer production",
    desc: "Green hydrogen feedstock for ammonia and fertilizer manufacturing — displacing fossil-derived hydrogen.",
    icon: "flask",
  },
  {
    title: "Power-to-gas & energy storage",
    desc: "Converting surplus renewable generation into storable, dispatchable hydrogen for long-duration energy storage.",
    icon: "battery",
  },
  {
    title: "Hydrogen refueling stations",
    desc: "Refueling infrastructure supporting the transition to hydrogen-powered fleets and public transport.",
    icon: "station",
  },
  {
    title: "Export & trade",
    desc: "Production infrastructure designed for the export and trade of green hydrogen to international markets.",
    icon: "globe",
  },
];
---
<section class="section-pad bg-[#0F2238] text-white" aria-labelledby="hydrogen-cases-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow !text-accent">Applications &amp; Industries</p>
      <h2 id="hydrogen-cases-title" class="fluid-h2 mt-3 text-white">Six green hydrogen application sectors</h2>
      <p class="fluid-lead mt-5 text-white/60">
        Empereal's green hydrogen systems serve industrial, transport, and energy-market clients seeking to decarbonize hard-to-abate sectors.
      </p>
    </div>

    <ul class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 reveal-stagger">
      {cases.map((c) => (
        <li class="group rounded-xl bg-white/[0.04] border border-white/10 p-5 hover:bg-white/[0.07] hover:border-accent/30 transition-all">
          <div class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent/15 ring-1 ring-accent/25 text-accent icon-lift">
            {c.icon === "factory" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <rect x="3" y="6" width="14" height="11" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <line x1="6" y1="6" x2="6" y2="3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                <line x1="14" y1="6" x2="14" y2="3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
            )}
            {c.icon === "transport" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <rect x="3" y="11" width="14" height="6" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <path d="M5 11V8c0-2 2-4 5-4s5 2 5 4v3" stroke="currentColor" stroke-width="1.4"/>
              </svg>
            )}
            {c.icon === "flask" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <path d="M8 2v5.5L3.5 16a1.5 1.5 0 0 0 1.3 2.2h10.4a1.5 1.5 0 0 0 1.3-2.2L12 7.5V2" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                <path d="M6 13h8" stroke="currentColor" stroke-width="1.1" opacity=".6"/>
              </svg>
            )}
            {c.icon === "battery" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <rect x="3" y="6" width="13" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                <rect x="16" y="9" width="2" height="4" rx=".5" fill="currentColor"/>
              </svg>
            )}
            {c.icon === "station" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="6" stroke="currentColor" stroke-width="1.4"/>
                <text x="10" y="13" text-anchor="middle" font-size="7" fill="currentColor" font-weight="600">H₂</text>
              </svg>
            )}
            {c.icon === "globe" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.4"/>
                <line x1="3" y1="10" x2="17" y2="10" stroke="currentColor" stroke-width="1" opacity=".6"/>
                <path d="M7 4 Q10 10 7 16" stroke="currentColor" stroke-width="1" opacity=".6"/>
                <path d="M13 4 Q10 10 13 16" stroke="currentColor" stroke-width="1" opacity=".6"/>
              </svg>
            )}
          </div>
          <h3 class="mt-4 text-base font-semibold text-white">{c.title}</h3>
          <p class="mt-1.5 text-sm text-white/55 leading-relaxed">{c.desc}</p>
        </li>
      ))}
    </ul>
  </Container>
</section>
