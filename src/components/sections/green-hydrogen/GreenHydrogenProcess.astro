---
import Container from "../../primitives/Container.astro";

const steps = [
  {
    n: "1",
    title: "Feasibility & resource assessment",
    desc: "Renewable energy availability and hydrogen demand analysis.",
  },
  {
    n: "2",
    title: "Electrolyzer sizing & selection",
    desc: "Technology selection based on scale, purity, and integration needs.",
  },
  {
    n: "3",
    title: "System design & integration",
    desc: "Complete balance-of-plant design including gas treatment and storage.",
  },
  {
    n: "4",
    title: "Installation & commissioning",
    desc: "Safe deployment with performance testing and certification.",
  },
  {
    n: "5",
    title: "Operations & optimization",
    desc: "Continuous monitoring and efficiency optimization.",
  },
];
---
<section class="section-pad bg-[#003B64] text-white" aria-labelledby="hydrogen-delivery-title">
  <Container>
    <div class="text-center max-w-2xl mx-auto reveal">
      <p class="eyebrow !text-accent">How we deliver</p>
      <h2 id="hydrogen-delivery-title" class="fluid-h2 mt-3 text-white">Our process</h2>
      <p class="fluid-lead mt-5 text-white/60">
        Every green hydrogen project follows a rigorous, phased delivery process — from renewable resource assessment through to long-term efficiency optimization.
      </p>
    </div>

    <ol class="mt-12 grid gap-8 sm:gap-6 sm:grid-cols-2 lg:grid-cols-5 relative reveal-stagger">
      <span aria-hidden="true" class="hidden lg:block absolute top-[18px] left-[10%] right-[10%] h-px bg-accent/25"></span>
      {steps.map((s) => (
        <li class="flex flex-col items-center text-center px-2 relative">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-accent text-primary-dark font-semibold shadow-md shadow-accent/30 ring-4 ring-[#003B64]">
            {s.n}
          </span>
          <h3 class="mt-4 text-sm font-semibold text-white">{s.title}</h3>
          <p class="mt-1.5 text-xs text-white/50 leading-relaxed">{s.desc}</p>
        </li>
      ))}
    </ol>
  </Container>
</section>
