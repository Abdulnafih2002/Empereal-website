---
import Container from "../../primitives/Container.astro";
import ProjectCard from "../projects/ProjectCard.astro";
import { projects } from "../../../data/projects.ts";

const slugs = ["green-hydrogen-dewa"];
const featured = slugs
  .map((s) => projects.find((p) => p.slug === s))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

---
<section class="section-pad bg-white" aria-labelledby="hydrogen-projects-title">
  <Container>
    <div class="mx-auto max-w-2xl text-center reveal">
      <p class="eyebrow">Related Projects</p>
      <h2 id="hydrogen-projects-title" class="fluid-h2 mt-3">Selected experience</h2>
      <p class="fluid-lead mt-5 text-muted">
        Empereal's green hydrogen work in action — from feasibility through to operational electrolyzer systems.
      </p>
    </div>

    <ul class="mx-auto mt-10 flex max-w-4xl flex-wrap justify-center gap-6 reveal-stagger">
      {featured.map((p) => (
        <li class="flex w-full max-w-sm sm:w-[calc(50%-12px)]">
          <ProjectCard project={p} class="w-full" />
        </li>
      ))}
    </ul>
  </Container>
</section>
