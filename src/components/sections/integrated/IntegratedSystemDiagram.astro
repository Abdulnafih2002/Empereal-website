---
import Container from "../../primitives/Container.astro";

const pillars = [
  {
    title: "Generation layer",
    desc: "Solar PV, solar thermal LFR, and backup generation — sized and configured for the site's load profile and solar resource.",
    icon: "gen",
  },
  {
    title: "Storage layer",
    desc: "Battery BESS and patented PCM thermal storage — matched to the energy type, duration requirement, and dispatch strategy.",
    icon: "store",
  },
  {
    title: "Water layer",
    desc: "Solar-powered desalination — LFR-MED or PV-RO — integrated with thermal storage for continuous fresh water production.",
    icon: "water",
  },
  {
    title: "Control & management layer",
    desc: "Intelligent EMS coordinating all systems — monitoring, dispatch optimisation, fault management, and performance reporting.",
    icon: "control",
  },
];
---
<section class="bg-primary-dark text-white border-t border-b border-accent/10 py-14" aria-labelledby="integrated-arch-title">
  <Container>
    <div class="text-center max-w-2xl mx-auto reveal">
      <p class="eyebrow !text-accent">System architecture</p>
      <h2 id="integrated-arch-title" class="fluid-h2 mt-3 text-white">How Empereal integrates multiple systems</h2>
      <p class="mt-4 text-sm text-white/55">
        Each discipline is engineered to work together — not independently procured and assembled on site.
      </p>
    </div>

    <ol class="mt-10 grid gap-8 sm:gap-4 sm:grid-cols-2 lg:grid-cols-4 relative reveal-stagger">
      <span aria-hidden="true" class="hidden lg:block absolute top-7 left-[16.7%] right-[16.7%] h-px bg-accent/25"></span>
      {pillars.map((p) => (
        <li class="flex flex-col items-center text-center px-3 relative">
          <span class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-accent/15 border border-accent/30 ring-4 ring-primary-dark text-accent icon-lift">
            {p.icon === "gen" && (
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" aria-hidden="true">
                <rect x="2" y="10" width="20" height="5" rx="1" fill="currentColor" opacity=".7"/>
                <rect x="2" y="16" width="20" height="5" rx="1" fill="currentColor" opacity=".45"/>
                <circle cx="12" cy="5" r="3" stroke="currentColor" stroke-width="1.4"/>
              </svg>
            )}
            {p.icon === "store" && (
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" aria-hidden="true">
                <rect x="4" y="6" width="16" height="13" rx="2" stroke="currentColor" stroke-width="1.4"/>
                <rect x="9" y="3" width="6" height="3" rx="1" fill="currentColor" opacity=".6"/>
                <path d="M12 9 L10 13 L13 13 L11 17" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {p.icon === "water" && (
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" aria-hidden="true">
                <path d="M12 3 Q17 8 17 14 A5 5 0 0 1 7 14 Q7 8 12 3Z" stroke="currentColor" stroke-width="1.4" fill="none"/>
                <line x1="8" y1="14" x2="16" y2="14" stroke="currentColor" stroke-width="1" opacity=".5"/>
              </svg>
            )}
            {p.icon === "control" && (
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="7" stroke="currentColor" stroke-width="1.4"/>
                <line x1="4" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width=".8" opacity=".5"/>
                <line x1="8" y1="6" x2="8" y2="18" stroke="currentColor" stroke-width=".8" opacity=".5"/>
                <line x1="16" y1="6" x2="16" y2="18" stroke="currentColor" stroke-width=".8" opacity=".5"/>
              </svg>
            )}
          </span>
          <h3 class="mt-4 text-base font-semibold text-white">{p.title}</h3>
          <p class="mt-1.5 text-xs text-white/55 leading-relaxed">{p.desc}</p>
        </li>
      ))}
    </ol>
  </Container>
</section>
