---
import Container from "../../primitives/Container.astro";

const cases = [
  {
    title: "Off-grid resorts & islands",
    desc: "Fully renewable power and water systems for hospitality — eliminating diesel supply chains and providing guests a genuinely net-zero experience.",
    icon: "island",
  },
  {
    title: "Industrial co-generation",
    desc: "Simultaneous electricity, process heat, and ultra-pure water production — replacing fossil-fuel-powered utilities in manufacturing and processing.",
    icon: "factory",
  },
  {
    title: "Net-zero buildings",
    desc: "BIPV generation integrated with battery storage and intelligent building energy management — turning the building envelope into a unified system.",
    icon: "building",
  },
  {
    title: "Rural electrification",
    desc: "Decentralised community-scale power and water infrastructure for villages and communities beyond the reach of national grids and supply networks.",
    icon: "rural",
  },
  {
    title: "Critical infrastructure",
    desc: "Reliable hybrid systems for hospitals, data centres, emergency services, and public facilities — where power continuity is non-negotiable.",
    icon: "critical",
  },
  {
    title: "Remote mining & exploration",
    desc: "Standalone energy and water systems for off-grid mining and exploration — reducing diesel logistics, lowering operating costs, meeting reporting requirements.",
    icon: "mining",
  },
];
---
<section class="section-pad bg-[#0F2238] text-white" aria-labelledby="integrated-cases-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow !text-accent">Applications</p>
      <h2 id="integrated-cases-title" class="fluid-h2 mt-3 text-white">Six integrated infrastructure sectors</h2>
      <p class="fluid-lead mt-5 text-white/60">
        Empereal's integrated energy and water systems serve clients who require continuous, reliable supply from renewable sources — across hospitality, industrial, municipal, and critical infrastructure sectors.
      </p>
    </div>

    <ul class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 reveal-stagger">
      {cases.map((c) => (
        <li class="group rounded-xl bg-white/[0.04] border border-white/10 p-5 hover:bg-white/[0.07] hover:border-accent/30 transition-all">
          <div class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent/15 ring-1 ring-accent/25 text-accent icon-lift">
            {c.icon === "island" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <path d="M3 14 Q4 10 6 10 L10 5 L14 10 Q16 10 17 14Z" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linejoin="round"/>
                <line x1="2" y1="17" x2="18" y2="17" stroke="currentColor" stroke-width="1"/>
              </svg>
            )}
            {c.icon === "factory" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <rect x="3" y="6" width="14" height="11" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <line x1="6" y1="6" x2="6" y2="3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                <line x1="14" y1="6" x2="14" y2="3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
            )}
            {c.icon === "building" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <rect x="2" y="6" width="16" height="11" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <path d="M5 6V4a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.4"/>
              </svg>
            )}
            {c.icon === "rural" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <circle cx="10" cy="6" r="3" stroke="currentColor" stroke-width="1.4"/>
                <path d="M3 17 Q10 12 17 17" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
            )}
            {c.icon === "critical" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <rect x="2" y="11" width="16" height="6" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <path d="M5 11V8c0-2 2-3 5-3s5 1 5 3v3" stroke="currentColor" stroke-width="1.4"/>
                <circle cx="10" cy="14" r="1.5" fill="currentColor" opacity=".7"/>
              </svg>
            )}
            {c.icon === "mining" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <polygon points="10,2 18,6 18,14 10,18 2,14 2,6" stroke="currentColor" stroke-width="1.3"/>
                <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1"/>
              </svg>
            )}
          </div>
          <h3 class="mt-4 text-base font-semibold text-white">{c.title}</h3>
          <p class="mt-1.5 text-sm text-white/55 leading-relaxed">{c.desc}</p>
        </li>
      ))}
    </ul>
  </Container>
</section>
