---
import Container from "../../primitives/Container.astro";

const items = [
  {
    title: "Architectural BIPV & Solar Façade Systems",
    desc: "Custom-designed building-integrated photovoltaics, solar façades, canopies, and railings — IEC-certified and SHAMS/D33 compliant.",
  },
  {
    title: "Hybrid Solar PV + Storage + Backup Systems",
    desc: "Solar PV combined with BESS and controlled backup — designed for peak shaving, load shifting, and reliable power.",
  },
  {
    title: "Solar Thermal + Storage + Desalination",
    desc: "Integrated LFR thermal fields with PCM storage driving MED desalination — 24/7 power and water from a unified plant.",
  },
  {
    title: "Grid-Connected & Off-Grid System Design",
    desc: "Both utility grid-tied and fully standalone off-grid system architectures optimised for site conditions.",
  },
  {
    title: "Electrical & Mechanical System Integration",
    desc: "Full integration of electrical, mechanical, and control systems across generation, storage, and consumption.",
  },
  {
    title: "Complete EPC & Long-term O&M",
    desc: "End-to-end engineering, procurement, construction, commissioning, and long-term performance management from a single partner.",
  },
];
---
<section class="section-pad bg-surface" aria-labelledby="integrated-scope-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow">Scope of services</p>
      <h2 id="integrated-scope-title" class="fluid-h2 mt-3">What we deliver</h2>
      <p class="fluid-lead mt-5 text-muted">
        Empereal’s Architectural BIPV &amp; Integrated Solar Solutions scope covers complete engineering and delivery — from system architecture and feasibility through construction, commissioning, and long-term asset management.
      </p>
    </div>

    <ul class="mt-10 grid gap-3 sm:grid-cols-2 reveal-stagger">
      {items.map((it) => (
        <li class="flex gap-3 rounded-xl bg-white ring-1 ring-primary/10 p-4 sm:p-5 hover:ring-accent/40 hover:shadow-card transition-all">
          <span class="mt-2 inline-block h-[2px] w-4 bg-accent rounded-full shrink-0" aria-hidden="true"></span>
          <div class="min-w-0">
            <h3 class="text-sm sm:text-[15px] font-semibold text-primary-dark">{it.title}</h3>
            <p class="mt-1.5 text-sm text-muted leading-relaxed">{it.desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </Container>
</section>
