---
import Container from "../../primitives/Container.astro";
---
<section
  class="page-hero relative isolate overflow-hidden bg-primary-dark text-white flex flex-col"
  aria-labelledby="integrated-hero-title"
>
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <img
      src="/images/french-pavilion-hero.webp"
      alt=""
      class="h-full w-full object-cover opacity-90"
      loading="eager"
      decoding="async"
      onerror="this.remove()"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/95 via-primary-dark/80 to-primary-dark/40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-primary-dark/30 via-transparent to-primary-dark/70"></div>
    <div class="absolute -bottom-24 -right-24 h-[460px] w-[460px] rounded-full bg-cta/15 blur-[140px] animate-pulse-glow"></div>
    <div class="absolute -top-24 -left-24 h-[360px] w-[360px] rounded-full bg-accent/10 blur-[120px] animate-pulse-glow delay-600"></div>

    <div class="hidden lg:block absolute right-2 top-1/2 -translate-y-1/2 w-[440px] h-[420px] opacity-[0.10] animate-float">
      <svg width="100%" height="100%" viewBox="0 0 260 230" fill="none" preserveAspectRatio="xMidYMid meet">
        <circle cx="130" cy="115" r="28" stroke="#F2994A" stroke-width="1"/>
        <circle cx="130" cy="115" r="10" fill="#F2994A" opacity=".3"/>
        <line x1="130" y1="87" x2="130" y2="48" stroke="#F2994A" stroke-width=".6"/>
        <line x1="154" y1="99" x2="185" y2="68" stroke="#F2994A" stroke-width=".6"/>
        <line x1="154" y1="131" x2="185" y2="162" stroke="#F2994A" stroke-width=".6"/>
        <line x1="130" y1="143" x2="130" y2="182" stroke="#F2994A" stroke-width=".6"/>
        <line x1="106" y1="131" x2="75" y2="162" stroke="#F2994A" stroke-width=".6"/>
        <line x1="106" y1="99" x2="75" y2="68" stroke="#F2994A" stroke-width=".6"/>
        <circle cx="130" cy="38" r="16" stroke="#F2994A" stroke-width=".8"/>
        <circle cx="198" cy="58" r="16" stroke="#F2994A" stroke-width=".8"/>
        <circle cx="198" cy="172" r="16" stroke="#F2994A" stroke-width=".8"/>
        <circle cx="130" cy="192" r="16" stroke="#F2994A" stroke-width=".8"/>
        <circle cx="62" cy="172" r="16" stroke="#F2994A" stroke-width=".8"/>
        <circle cx="62" cy="58" r="16" stroke="#F2994A" stroke-width=".8"/>
        <circle cx="130" cy="115" r="72" stroke="#F2994A" stroke-width=".4" stroke-dasharray="3 4"/>
      </svg>
    </div>
  </div>

  <Container class="relative flex-1 flex items-center">
    <div class="py-16 sm:py-20 lg:py-24 max-w-3xl">
      <p class="eyebrow !text-white hero-enter hero-enter-1">Architectural BIPV &amp; Integrated Solar Solutions</p>
      <h1 id="integrated-hero-title" class="fluid-display mt-4 text-white hero-enter hero-enter-2">
        One partner. One system.<br/>
        <span class="text-accent">Complete integration.</span>
      </h1>
      <p class="fluid-lead mt-6 text-white/80 max-w-2xl hero-enter hero-enter-3">
        Architectural BIPV façades, solar-integrated building systems, microgrids, and smart energy solutions — designed as unified, high-performance infrastructure for modern developments.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row flex-wrap gap-3 hero-enter hero-enter-4">
        <a
          href="/projects?filter=integrated"
          class="hero-home-pill"
        >
          View Integrated Projects
        </a>
      </div>

    </div>
  </Container>
</section>

<style>
  .page-hero {
    min-height: calc(100vh - 6rem);
    min-height: calc(100svh - 6rem);
    min-height: calc(100dvh - 6rem);
  }
  @media (min-width: 1024px) {
    .page-hero {
      min-height: calc(100vh - 7rem);
      min-height: calc(100svh - 7rem);
      min-height: calc(100dvh - 7rem);
    }
  }
</style>
