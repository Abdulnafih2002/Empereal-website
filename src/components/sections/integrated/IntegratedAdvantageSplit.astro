---
import Container from "../../primitives/Container.astro";
import ImagePlaceholder from "../../primitives/ImagePlaceholder.astro";

const checks = [
  "Single point of accountability across all system components",
  "Systems sized together — not individually, then assembled",
  "Unified EMS coordinating generation, storage, and loads",
  "Proven in operational off-grid resorts, industrial sites, and desalination plants",
  "ISO 9001, 14001, and 45001 certified across the entire delivery scope",
];
---
<section class="section-pad bg-white" aria-labelledby="integrated-advantage-title">
  <Container>
    <div class="grid gap-10 lg:gap-14 lg:grid-cols-2 lg:items-center">
      <div class="group order-2 lg:order-1 reveal-left">
        <ImagePlaceholder
          src="/images/zamani-island-1.jpg"
          alt="Zamani Islands Resort — Maldives — fully renewable-powered resort"
          aspect="4/3"
          tone="navy"
          label="Zamani Islands Resort — Maldives"
          class="shadow-card-lg"
        >
          <div class="absolute inset-x-0 bottom-0 p-5 lg:p-6 bg-gradient-to-t from-primary-dark/90 via-primary-dark/45 to-transparent pointer-events-none">
            <p class="text-xs text-white/70 uppercase tracking-[0.14em]">Featured project</p>
            <p class="mt-1 text-base lg:text-lg font-semibold text-white">Zamani Islands Resort — Fully renewable-powered resort</p>
          </div>
        </ImagePlaceholder>
      </div>

      <div class="order-1 lg:order-2 reveal-right">
        <p class="eyebrow">The Empereal advantage</p>
        <h2 id="integrated-advantage-title" class="fluid-h2 mt-3">Why integrated delivery matters.</h2>
        <p class="fluid-lead mt-5 text-muted">
          When solar PV, thermal, storage, and desalination systems are procured separately and assembled on site, the result is often suboptimal — mismatched sizing, interface conflicts, duplicated controls, and no single party accountable for overall performance.
        </p>
        <p class="mt-4 text-muted leading-relaxed">
          Empereal designs the entire system from a single set of inputs — site load profile, water demand, solar resource, and budget — then engineers every subsystem to work together. One design. One contract. One performance guarantee.
        </p>

        <p class="mt-7 text-sm font-semibold text-primary-dark">Key Benefits:</p>
        <ul class="mt-3 space-y-3">
          {checks.map((c) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent shrink-0">
                <svg viewBox="0 0 10 10" class="h-2.5 w-2.5" fill="none" aria-hidden="true">
                  <path d="M2 5l2 2 4-4" stroke="#003B64" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="text-[15px] text-ink/80 leading-relaxed">{c}</span>
            </li>
          ))}
        </ul>

      </div>
    </div>
  </Container>
</section>
