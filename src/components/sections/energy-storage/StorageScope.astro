---
import Container from "../../primitives/Container.astro";

const items = [
  {
    title: "Battery Energy Storage Systems (BESS)",
    desc: "Design, integration, and commissioning of BESS paired with solar PV for peak shaving, load shifting, and grid stability — grid-connected and off-grid.",
  },
  {
    title: "PCM Thermal Storage",
    desc: "Phase-change material thermal storage providing 4+ hours of heat for desalination, process heat, and continuous solar thermal operation.",
  },
  {
    title: "Molten Salt & Accumulator Thermal Storage",
    desc: "High-temperature molten salt and pressurised accumulator systems for extended thermal storage in CSP and industrial applications.",
  },
  {
    title: "Intelligent Energy Management Systems (EMS)",
    desc: "Real-time monitoring and optimisation of generation, storage, and demand to ensure maximum efficiency and uninterrupted supply.",
  },
  {
    title: "Off-Grid & Hybrid System Design",
    desc: "Complete solar PV + BESS + diesel hybrid solutions engineered for remote sites with minimal or zero diesel consumption.",
  },
  {
    title: "Full Design, Integration & O&M",
    desc: "Complete EPC scope including system sizing, integration, commissioning, testing, and long-term performance monitoring.",
  },
];
---
<section class="section-pad bg-surface" aria-labelledby="storage-scope-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow">Scope of services</p>
      <h2 id="storage-scope-title" class="fluid-h2 mt-3">What we deliver</h2>
      <p class="fluid-lead mt-5 text-muted">
        Empereal’s energy storage scope spans both electrical and thermal systems — from concept design through integration, commissioning, and long-term O&amp;M.
      </p>
    </div>

    <ul class="mt-10 grid gap-3 sm:grid-cols-2 reveal-stagger">
      {items.map((it) => (
        <li class="flex gap-3 rounded-xl bg-white ring-1 ring-primary/10 p-4 sm:p-5 hover:ring-accent/40 hover:shadow-card transition-all">
          <span class="mt-2 inline-block h-[2px] w-4 bg-accent rounded-full shrink-0" aria-hidden="true"></span>
          <div class="min-w-0">
            <h3 class="text-sm sm:text-[15px] font-semibold text-primary-dark">{it.title}</h3>
            <p class="mt-1.5 text-sm text-muted leading-relaxed">{it.desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </Container>
</section>
