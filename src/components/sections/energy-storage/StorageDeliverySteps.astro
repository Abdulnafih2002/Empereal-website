---
import Container from "../../primitives/Container.astro";

const steps = [
  {
    n: "1",
    title: "Load & resource analysis",
    desc: "Demand profiling, solar resource assessment, and storage duration requirement modelling.",
  },
  {
    n: "2",
    title: "Technology selection & sizing",
    desc: "BESS vs thermal storage selection, capacity sizing, EMS specification, and system architecture design.",
  },
  {
    n: "3",
    title: "Integration & commissioning",
    desc: "Storage integration with solar generation, grid or off-grid connection, controls programming, and performance testing.",
  },
  {
    n: "4",
    title: "Monitoring & optimisation",
    desc: "Real-time EMS monitoring, storage performance reporting, degradation management, and system optimisation.",
  },
];
---
<section class="section-pad bg-[#003B64] text-white" aria-labelledby="storage-delivery-title">
  <Container>
    <div class="text-center max-w-2xl mx-auto reveal">
      <p class="eyebrow !text-accent">How we deliver</p>
      <h2 id="storage-delivery-title" class="fluid-h2 mt-3 text-white">Our storage system delivery process</h2>
      <p class="fluid-lead mt-5 text-white/60">
        Storage system design begins with the load — not the technology. Every Empereal storage project is scoped to match the specific energy demand, solar resource, and operational requirements of the site.
      </p>
    </div>

    <ol class="mt-12 grid gap-8 sm:gap-4 sm:grid-cols-2 lg:grid-cols-4 relative reveal-stagger">
      <span aria-hidden="true" class="hidden lg:block absolute top-[18px] left-[12.5%] right-[12.5%] h-px bg-accent/25"></span>
      {steps.map((s) => (
        <li class="flex flex-col items-center text-center px-2 relative">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-accent text-primary-dark font-semibold shadow-md shadow-accent/30 ring-4 ring-[#003B64]">
            {s.n}
          </span>
          <h3 class="mt-4 text-sm font-semibold text-white">{s.title}</h3>
          <p class="mt-1.5 text-xs text-white/50 leading-relaxed">{s.desc}</p>
        </li>
      ))}
    </ol>
  </Container>
</section>
