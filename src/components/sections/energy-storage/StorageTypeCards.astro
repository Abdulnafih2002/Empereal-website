---
import Container from "../../primitives/Container.astro";

const cards = [
  {
    eyebrow: "Electrical Storage",
    title: "Battery Energy Storage Systems (BESS)",
    body: "Battery storage integrated directly with solar PV — enabling peak shaving, load shifting, off-grid operation, and grid stability support. Paired with intelligent energy management that monitors generation, storage state, and demand in real time.",
    specs: [
      { k: "Application", v: "Electrical power storage & dispatch" },
      { k: "Configuration", v: "Grid-connected or off-grid" },
      { k: "Management", v: "Intelligent EMS — real-time optimisation" },
      { k: "Integration", v: "Solar PV + BESS + backup (diesel/grid)" },
    ],
    icon: "battery",
  },
  {
    eyebrow: "Thermal Storage",
    title: "Phase-Change Material (PCM) Thermal Storage",
    body: "Thermal energy storage using phase-change materials that absorb, store, and release heat at precisely controlled temperatures. Enables continuous operation of solar thermal — including desalination and power generation — independent of solar intermittency.",
    specs: [
      { k: "Application", v: "Thermal energy storage for heat loads" },
      { k: "Technology", v: "Phase-change materials (PCM)" },
      { k: "Duration", v: "4+ hour storage capability" },
      { k: "Status", v: "Operational thermal storage technology" },
    ],
    icon: "pcm",
  },
];
---
<section class="section-pad bg-surface" aria-labelledby="storage-types-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow">Two storage technologies</p>
      <h2 id="storage-types-title" class="fluid-h2 mt-3">Electrical and thermal — matched to the application</h2>
      <p class="fluid-lead mt-5 text-muted">
        Empereal designs storage systems as an integral part of the overall energy system — not as an afterthought. Technology selection is driven by the specific application, load profile, and whether the storage function is electrical or thermal.
      </p>
    </div>

    <ul class="mt-10 grid gap-4 md:grid-cols-2 reveal-stagger">
      {cards.map((c) => (
        <li class="group relative rounded-2xl bg-white ring-1 ring-primary/10 p-6 lg:p-8 hover:ring-accent/40 hover:shadow-card-lg transition-all overflow-hidden">
          <span aria-hidden="true" class="absolute inset-x-0 top-0 h-1 bg-accent rounded-t-2xl"></span>
          <div class="absolute top-5 right-5 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent/15 text-accent-dark icon-lift">
            {c.icon === "battery" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none" aria-hidden="true">
                <rect x="3" y="6" width="13" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                <rect x="16" y="9" width="2" height="4" rx=".5" fill="currentColor"/>
                <path d="M10 9v5m-2.5-2.5h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
            {c.icon === "pcm" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.4"/>
                <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width=".8" opacity=".5"/>
                <path d="M10 3 Q14 6 14 10" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
              </svg>
            )}
          </div>

          <p class="text-[10px] font-semibold uppercase tracking-[0.08em] text-accent-dark">{c.eyebrow}</p>
          <h3 class="mt-2 text-base font-semibold text-primary-dark">{c.title}</h3>
          <p class="mt-3 text-sm text-muted leading-relaxed">{c.body}</p>

          <dl class="mt-5 grid gap-2.5 pt-5 border-t border-primary/10">
            {c.specs.map((s) => (
              <div class="flex items-baseline gap-3 text-sm">
                <dt class="text-xs font-medium text-muted min-w-[96px] shrink-0">{s.k}</dt>
                <dd class="text-[13px] font-medium text-primary-dark">{s.v}</dd>
              </div>
            ))}
          </dl>
        </li>
      ))}
    </ul>
  </Container>
</section>
