---
import Container from "../../primitives/Container.astro";
---
<section
  class="page-hero relative isolate overflow-hidden bg-primary-dark text-white flex flex-col"
  aria-labelledby="leadership-hero-title"
>
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <img
      src="/images/masdar-22.jpg"
      alt=""
      class="h-full w-full object-cover"
      loading="eager"
      decoding="async"
      onerror="this.remove()"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary-dark/85 via-primary-dark/55 to-primary-dark/20"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/60 via-transparent to-transparent"></div>
    <div class="absolute -bottom-32 -right-32 h-[520px] w-[520px] rounded-full bg-accent/15 blur-[140px] animate-pulse-glow"></div>
    <svg class="absolute inset-0 w-full h-full opacity-[0.05]" viewBox="0 0 1440 800" preserveAspectRatio="xMidYMid slice">
      <defs>
        <pattern id="leaderGrid" x="0" y="0" width="48" height="48" patternUnits="userSpaceOnUse">
          <path d="M48 0H0v48" fill="none" stroke="#fff" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="1440" height="800" fill="url(#leaderGrid)"/>
    </svg>
    <div class="hidden md:block absolute right-4 lg:right-12 top-1/2 -translate-y-1/2 w-[340px] h-[340px] opacity-[0.09]">
      <svg width="100%" height="100%" viewBox="0 0 200 200" fill="none">
        <circle cx="100" cy="100" r="80" stroke="#F2994A" stroke-width=".6"/>
        <circle cx="100" cy="100" r="55" stroke="#F2994A" stroke-width=".6"/>
        <circle cx="100" cy="100" r="30" stroke="#F2994A" stroke-width=".6"/>
        <circle cx="100" cy="20" r="5" fill="#F2994A" opacity=".7"/>
        <circle cx="168" cy="60" r="5" fill="#F2994A" opacity=".6"/>
        <circle cx="168" cy="140" r="5" fill="#F2994A" opacity=".5"/>
        <circle cx="100" cy="180" r="5" fill="#F2994A" opacity=".5"/>
        <circle cx="32" cy="140" r="5" fill="#F2994A" opacity=".6"/>
        <circle cx="32" cy="60" r="5" fill="#F2994A" opacity=".7"/>
        <line x1="100" y1="20" x2="168" y2="60" stroke="#F2994A" stroke-width=".4"/>
        <line x1="168" y1="60" x2="168" y2="140" stroke="#F2994A" stroke-width=".4"/>
        <line x1="168" y1="140" x2="100" y2="180" stroke="#F2994A" stroke-width=".4"/>
        <line x1="100" y1="180" x2="32" y2="140" stroke="#F2994A" stroke-width=".4"/>
        <line x1="32" y1="140" x2="32" y2="60" stroke="#F2994A" stroke-width=".4"/>
        <line x1="32" y1="60" x2="100" y2="20" stroke="#F2994A" stroke-width=".4"/>
        <line x1="100" y1="20" x2="100" y2="100" stroke="#F2994A" stroke-width=".3" opacity=".5"/>
        <line x1="168" y1="60" x2="100" y2="100" stroke="#F2994A" stroke-width=".3" opacity=".5"/>
        <line x1="168" y1="140" x2="100" y2="100" stroke="#F2994A" stroke-width=".3" opacity=".5"/>
        <line x1="100" y1="180" x2="100" y2="100" stroke="#F2994A" stroke-width=".3" opacity=".5"/>
        <line x1="32" y1="140" x2="100" y2="100" stroke="#F2994A" stroke-width=".3" opacity=".5"/>
        <line x1="32" y1="60" x2="100" y2="100" stroke="#F2994A" stroke-width=".3" opacity=".5"/>
        <circle cx="100" cy="100" r="7" fill="#F2994A" opacity=".5"/>
      </svg>
    </div>
  </div>

  <Container class="relative flex-1 flex items-center">
    <div class="py-16 sm:py-20 lg:py-24 max-w-2xl">
      <p class="eyebrow !text-white hero-enter hero-enter-1">Governance & Strategic Direction</p>
      <h1 id="leadership-hero-title" class="fluid-display mt-4 text-white hero-enter hero-enter-2">
        Led by founders. <span class="text-accent">Driven by technical expertise.</span>
      </h1>
      <p class="fluid-lead mt-6 text-white/85 max-w-xl hero-enter hero-enter-3">
        Empereal is guided by a founding team with deep hands-on experience across renewable energy, Architectural BIPV, water desalination, and large-scale infrastructure delivery. Our leadership combines strong technical capability with strategic oversight to deliver complex, high-performance clean energy and water projects.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3 hero-enter hero-enter-4">
        <a
          href="/#projects"
          class="hero-home-pill"
        >
          View Our Projects
        </a>
      </div>
    </div>
  </Container>
</section>

<style>
  .page-hero {
    min-height: calc(100vh - 6rem);
    min-height: calc(100svh - 6rem);
    min-height: calc(100dvh - 6rem);
  }
  @media (min-width: 1024px) {
    .page-hero {
      min-height: calc(100vh - 7rem);
      min-height: calc(100svh - 7rem);
      min-height: calc(100dvh - 7rem);
    }
  }
</style>
