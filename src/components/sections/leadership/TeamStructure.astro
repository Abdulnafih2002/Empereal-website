---
import Container from "../../primitives/Container.astro";

const layers = [
  {
    title: "Board-level leadership",
    body: "Strategic oversight and governance for the Empereal group of companies, addressing global infrastructure challenges in renewable energy and fresh water.",
    items: [
      "Group strategy & governance",
      "Capital allocation & partnerships",
      "Market entry & expansion",
      "Corporate sustainability direction",
    ],
    icon: "board",
  },
  {
    title: "Regional operations",
    body: "Operational management teams embedded in each primary market, accountable for client relationships, project delivery, and local business development.",
    items: [
      "Singapore — HQ & global coordination",
      "UAE / Middle East — Primary market",
      "India — R&D, manufacturing & EPC",
      "United States — Market development",
      "Central Asia — Expansion markets",
    ],
    icon: "globe",
  },
  {
    title: "Technical leadership",
    body: "Senior engineers and project directors with specialist depth across each of Empereal's solution disciplines — responsible for design quality, innovation, and performance accountability.",
    items: [
      "Solar PV & CSP design",
      "Architectural BIPV engineering",
      "Solar thermal desalination",
      "Energy storage systems",
      "Project finance & structuring",
    ],
    icon: "star",
  },
];
---
<section class="section-pad bg-[#0F2238] text-white" aria-labelledby="team-structure-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow !text-accent">Team Structure</p>
      <h2 id="team-structure-title" class="fluid-h2 mt-3 text-white">Three layers of leadership</h2>
      <p class="fluid-lead mt-5 text-white/75">
        Strategic oversight, regional operations, and deep technical leadership — aligned across every project Empereal delivers.
      </p>
    </div>

    <div class="mt-10 grid gap-5 lg:grid-cols-3 reveal-stagger">
      {layers.map((layer) => (
        <article class="rounded-xl bg-white/[0.04] border border-white/10 p-6">
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-lg bg-accent/15 text-accent" aria-hidden="true">
            {layer.icon === "board" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <rect x="2" y="8" width="16" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                <path d="M6 8V5a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                <circle cx="10" cy="13" r="1.5" fill="currentColor"/>
              </svg>
            )}
            {layer.icon === "globe" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.4"/>
                <line x1="3" y1="10" x2="17" y2="10" stroke="currentColor" stroke-width="1" opacity=".6"/>
                <path d="M7 4 Q10 10 7 16" stroke="currentColor" stroke-width="1" opacity=".6"/>
                <path d="M13 4 Q10 10 13 16" stroke="currentColor" stroke-width="1" opacity=".6"/>
              </svg>
            )}
            {layer.icon === "star" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <path d="M10 2 L12.5 7.5 L18 8 L14 12 L15 17.5 L10 15 L5 17.5 L6 12 L2 8 L7.5 7.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
          <h3 class="mt-4 text-base font-semibold text-white">{layer.title}</h3>
          <p class="mt-2 text-sm text-white/75 leading-relaxed">{layer.body}</p>
          <ul class="mt-5 space-y-2.5">
            {layer.items.map((item) => (
              <li class="flex items-center gap-3 text-sm text-white/60">
                <span class="inline-block h-px w-3 bg-accent shrink-0" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </Container>
</section>
