---
import Container from "../../primitives/Container.astro";

const founderVideo = {
  id: "iT87iVJYUC0",
  title: "Empereal founder Manoj Divakaran shares the company’s story",
};
---
<section class="section-pad bg-white" aria-labelledby="leadership-intro-title">
  <Container>
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
      <div class="relative order-1 overflow-hidden rounded-2xl bg-primary-dark shadow-card-lg ring-1 ring-primary/5 reveal-left lg:order-1">
        <div class="aspect-video">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${founderVideo.id}?rel=0`}
            title={founderVideo.title}
            class="h-full w-full"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <div class="order-2 lg:order-2 reveal-right">
        <p class="eyebrow">About Our Leadership</p>
        <h2 id="leadership-intro-title" class="fluid-h2 mt-3">Founder-led. Experience-driven.</h2>
        <p class="fluid-lead mt-6 text-muted">
          Empereal is led by Founder Directors Manoj Divakaran and Arun Subramony, who bring deep technical and strategic expertise in renewable energy, Architectural BIPV, and large-scale infrastructure delivery.
        </p>
        <p class="mt-4 text-muted">
          They are supported by a Strategic Advisory Board of senior industry leaders with extensive experience across technology development, corporate governance, and international project execution. This combination of founder-led direction and world-class independent counsel ensures both technical excellence and strong strategic oversight.
        </p>
      </div>
    </div>
  </Container>
</section>
