---
import Container from "../../primitives/Container.astro";
---
<section class="bg-primary-dark text-white border-t border-accent/15" aria-labelledby="leadership-cta-title">
  <Container>
    <div class="py-16 sm:py-20 text-center max-w-2xl mx-auto reveal">
      <h2 id="leadership-cta-title" class="fluid-h2 text-white">Built by engineers. Led by experience.</h2>
      <p class="mt-4 fluid-lead text-white/75 max-w-lg mx-auto">
        Connect with the Empereal team to discuss your energy and water infrastructure requirements.
      </p>
      <a
        href="/contact"
        class="site-cta site-cta-on-dark press mt-8"
      >
        Connect With Us
      </a>
    </div>
  </Container>
</section>
