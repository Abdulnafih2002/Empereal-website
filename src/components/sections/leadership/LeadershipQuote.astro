---
import Container from "../../primitives/Container.astro";
---
<section class="bg-[#0F2238] text-white border-t border-accent/10 border-b border-accent/10" aria-label="Leadership philosophy quote">
  <Container>
    <figure class="py-16 sm:py-20 max-w-2xl mx-auto text-center reveal">
      <div class="font-display text-5xl leading-none text-accent" aria-hidden="true">&ldquo;</div>
      <blockquote class="mt-4 text-lg sm:text-xl leading-relaxed text-white italic">
        A fearless culture that fosters imagination and innovation, embracing change, conflicts, and crisis as opportunities.
      </blockquote>
      <figcaption class="mt-6 text-sm text-white/65">
        — <strong class="font-semibold text-white/90 not-italic">Empereal leadership philosophy</strong>
      </figcaption>
    </figure>
  </Container>
</section>
