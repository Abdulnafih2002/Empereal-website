---
import Container from "../../primitives/Container.astro";

const regions = [
  {
    name: "Singapore",
    role: "Headquarters",
    tags: ["Corporate HQ", "Global strategy", "Finance & legal"],
    icon: "globe",
  },
  {
    name: "UAE & Middle East",
    role: "Primary market",
    tags: ["Solar EPC & BIPV", "Desalination", "Green hydrogen"],
    icon: "pin",
  },
  {
    name: "India",
    role: "R&D & EPC",
    tags: ["Solar thermal R&D", "Utility-scale EPC", "Manufacturing"],
    icon: "factory",
  },
  {
    name: "United States",
    role: "Market development",
    tags: ["Project origination", "BIPV expansion", "Partnerships"],
    icon: "hq",
  },
  {
    name: "Central Asia",
    role: "Expansion markets",
    tags: ["Uzbekistan", "Kazakhstan", "Kyrgyzstan"],
    icon: "hex",
  },
];
---
<section class="section-pad bg-primary-dark text-white relative overflow-hidden" aria-labelledby="regional-title">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-24 right-0 h-[380px] w-[380px] rounded-full bg-accent/10 blur-[120px] animate-pulse-glow animate-drift"></div>
  </div>

  <Container class="relative">
    <div class="max-w-3xl reveal">
      <p class="eyebrow !text-accent">Where We Operate</p>
      <h2 id="regional-title" class="fluid-h2 mt-4 text-white font-semibold tracking-tight">
        Five-market operating footprint
      </h2>
      <p class="mt-6 text-base sm:text-lg leading-relaxed text-white/65 max-w-2xl">
        Empereal's operational leadership is embedded in each geography — enabling rapid client response, local regulatory expertise, and in-market project execution.
      </p>
    </div>

    <ul class="mt-12 lg:mt-16 grid gap-5 sm:gap-6 grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 reveal-stagger">
      {regions.map((r) => (
        <li class="group relative flex flex-col rounded-2xl bg-gradient-to-b from-white/[0.06] to-white/[0.02] ring-1 ring-inset ring-white/10 p-6 lg:p-7 transition-all duration-300 hover:ring-accent/40 hover:-translate-y-1 hover:shadow-2xl hover:shadow-accent/5">
          <div
            class="absolute inset-x-10 -top-px h-px bg-gradient-to-r from-transparent via-accent/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            aria-hidden="true"
          ></div>

          <div class="relative mx-auto">
            <div
              class="absolute inset-0 -z-10 rounded-full bg-accent/30 blur-xl opacity-40 group-hover:opacity-80 transition-opacity duration-300"
              aria-hidden="true"
            ></div>
            <div class="relative inline-flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-accent/30 via-accent/15 to-accent/[0.05] ring-1 ring-accent/40 text-accent shadow-[inset_0_1px_0_rgba(255,255,255,0.1)] transition-transform duration-300 group-hover:scale-105">
              {r.icon === "globe" && (
                <svg viewBox="0 0 20 20" class="h-6 w-6" fill="none">
                  <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.4"/>
                  <line x1="3" y1="10" x2="17" y2="10" stroke="currentColor" stroke-width="1" opacity=".6"/>
                  <path d="M7 4 Q10 10 7 16" stroke="currentColor" stroke-width="1" opacity=".6"/>
                  <path d="M13 4 Q10 10 13 16" stroke="currentColor" stroke-width="1" opacity=".6"/>
                </svg>
              )}
              {r.icon === "pin" && (
                <svg viewBox="0 0 20 20" class="h-6 w-6" fill="none">
                  <path d="M10 2 C10 2 16 7 16 12 A6 6 0 0 1 4 12 C4 7 10 2 10 2Z" stroke="currentColor" stroke-width="1.4"/>
                  <circle cx="10" cy="12" r="2.5" stroke="currentColor" stroke-width="1"/>
                </svg>
              )}
              {r.icon === "factory" && (
                <svg viewBox="0 0 20 20" class="h-6 w-6" fill="none">
                  <rect x="3" y="9" width="14" height="9" rx="1" stroke="currentColor" stroke-width="1.4"/>
                  <path d="M6 9V6a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.4"/>
                  <circle cx="10" cy="13.5" r="1.5" fill="currentColor" opacity=".7"/>
                </svg>
              )}
              {r.icon === "hq" && (
                <svg viewBox="0 0 20 20" class="h-6 w-6" fill="none">
                  <rect x="2" y="6" width="16" height="11" rx="1" stroke="currentColor" stroke-width="1.4"/>
                  <line x1="7" y1="6" x2="7" y2="2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                  <line x1="13" y1="6" x2="13" y2="2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                  <line x1="2" y1="11" x2="18" y2="11" stroke="currentColor" stroke-width=".8" opacity=".5"/>
                </svg>
              )}
              {r.icon === "hex" && (
                <svg viewBox="0 0 20 20" class="h-6 w-6" fill="none">
                  <polygon points="10,2 17,6 17,12 10,16 3,12 3,6" stroke="currentColor" stroke-width="1.4"/>
                  <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1"/>
                </svg>
              )}
            </div>
          </div>

          <div class="mt-6 text-center">
            <h3 class="font-display text-lg lg:text-xl font-semibold text-white tracking-tight leading-tight">
              {r.name}
            </h3>
            <p class="mt-2 text-[10px] uppercase tracking-[0.18em] text-white/50 font-semibold">
              {r.role}
            </p>
          </div>

          <div class="my-5 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent" aria-hidden="true"></div>

          <ul class="flex flex-col gap-2">
            {r.tags.map((tag) => (
              <li class="flex items-center gap-2.5 rounded-lg bg-white/[0.03] ring-1 ring-inset ring-white/[0.06] px-3 py-2.5 text-xs font-medium text-white/75 transition-colors hover:bg-white/[0.07] hover:text-white hover:ring-white/[0.12]">
                <span class="h-1.5 w-1.5 rounded-full bg-accent/80 shrink-0" aria-hidden="true"></span>
                <span class="truncate">{tag}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </Container>
</section>
