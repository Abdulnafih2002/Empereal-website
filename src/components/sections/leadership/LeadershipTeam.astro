---
import Container from "../../primitives/Container.astro";

const founders = [
  {
    name: "Manoj Divakaran",
    title: "Founder Director — Middle East & India Operations, Product & Service Strategy",
    image: "/images/leader-1.jpg",
    initials: "MD",
    bio: "Manoj Divakaran is the Founder Director responsible for Empereal’s operations across the Middle East and India, as well as product and service strategy. With over 31 years of experience spanning technology, consulting, customer service, and renewable energy, he is a recognized thought leader in clean energy and open innovation.\n\nPrior to founding Empereal, Manoj held senior leadership roles at Thomson Reuters, where he led regional and global teams and drove significant growth across emerging markets. He brings a unique combination of deep technical understanding and strategic business acumen to the clean energy sector.\n\nManoj holds a Bachelor’s degree in Electronics and Instrumentation Engineering from the University of Kerala, a Master’s in Energy Management from the Bauer College of Business (Houston, USA), and a Master’s in Innovation and Change from the University of York, United Kingdom.",
  },
  {
    name: "Arun Subramony",
    title: "Founder Director — Organizational Strategy, Corporate Governance, M&A & Deal Structuring",
    image: "/images/leader-2.jpg",
    initials: "AS",
    bio: "Arun Subramony is the Founder Director responsible for organizational strategy, corporate governance, mergers & acquisitions, and deal structuring at Empereal. With over 30 years of experience building and scaling businesses across the Americas and Asia, he has a strong track record in investing, incubating, and growing new ventures.\n\nPrior to Empereal, Arun held leadership roles at several global organizations, including Wipro, Microsoft, IMC, UST Global, and August. He has successfully led strategic alliances with firms such as PwC, SAP, and GE, and has executed multiple mergers and acquisitions. His expertise spans corporate strategy, governance frameworks, and cross-border business development.\n\nArun holds an undergraduate degree in Mechanical Engineering from the University of Kerala, an MBA from the University of Madras, and an MBA from the Kellogg School of Management, USA. He also completed his Ph.D. research requirements at IIT Madras. He is an active mentor and career coach.",
  },
];

const advisors = [
  {
    name: "Dr. S.P. Viswanathan",
    title: "Technology Development & Product Strategy",
    image: "/images/advisor-1.jpg",
    initials: "SV",
    bio: "Dr. S.P. Viswanathan leads technology development and product strategy at Empereal. With over 40 years of experience in aerospace R&D in the USA and more than 6 years in renewable energy, he brings deep expertise in concentrated solar power (CSP), hybrid renewable systems, and thermal desalination technologies.\n\nHe has designed and developed key process technologies and intellectual property, particularly in integrating solar thermal systems with freshwater production. His work focuses on advancing high-efficiency, sustainable solutions for energy and water challenges.\n\nDr. Viswanathan holds a Bachelor’s degree in Mechanical Engineering from IIT Madras and both a Master’s and PhD from the Georgia Institute of Technology, USA.",
  },
  {
    name: "Erich Kreidler",
    title: "Board Member",
    image: "/images/advisor-2.jpg",
    initials: "EK",
    bio: "Erich Kreidler serves on Empereal’s Board of Directors. He is the President of SprintRay Inc. and Co-Founder of KRE Consulting, LLC. With extensive leadership experience across technology and manufacturing sectors, Erich brings strong strategic insight and operational expertise to the board.\n\nHe is recognized for his ability to build effective relationships and drive alignment across diverse teams and stakeholders. Erich holds a Master of Business Administration from the University of California, Irvine, and a Bachelor of Science in Industrial Engineering from California State Polytechnic University, Pomona.",
  },
  {
    name: "Ricky Husaini",
    title: "Investment & Treasury Strategy",
    image: "/images/advisor-3.jpg",
    initials: "RH",
    bio: "Ricky Husaini leads investment and treasury strategy at Empereal. With over 20 years of experience in multi-asset class investment and treasury management, he has a strong track record of managing sizable portfolios and supporting business growth across both emerging and established industries.\n\nHis expertise spans asset allocation, treasury operations, risk management, and identifying strategic investment opportunities in global markets. Ricky brings a disciplined, forward-looking approach to financial strategy and capital allocation.",
  },
  {
    name: "Stephanie Scarborough",
    title: "Legal & Advisory",
    image: "/images/advisor-4.jpg",
    initials: "SS",
    bio: "Stephanie Scarborough serves as legal counsel and advisor to Empereal. She is the founder of Scarborough Law, L.L.C. and brings over 12 years of experience as a practicing attorney. She advises clients across a range of areas, including corporate and commercial matters, estate planning, and immigration law.\n\nKnown for her practical and client-focused approach, Stephanie provides strategic legal guidance that supports sound decision-making and long-term business objectives. She holds a Bachelor of Arts from Excelsior College and a Juris Doctor (J.D.) from the University of Buffalo, USA.",
  },
  {
    name: "Sandeep Jain",
    title: "Strategic Growth & Investment",
    image: "/images/advisor-5.jpg",
    initials: "SJ",
    bio: "Sandeep Jain serves on Empereal’s Strategic Advisory Board, focusing on strategic growth and investment. With an extensive executive career in the software and technology sectors, he has built and led high-performing divisions serving Fortune 500 clients globally.\n\nHe brings deep expertise in deal structuring, global business development, market expansion, and strategic relationship management. As an early-stage investor through his family office, Sandeep has supported Empereal since its inception and continues to contribute to its long-term growth strategy.",
  },
  {
    name: "Dr. Jagdish Sheth",
    title: "Marketing & Strategy",
    image: "/images/advisor-6.jpg",
    initials: "JS",
    bio: "Dr. Jagdish Sheth serves on Empereal’s Strategic Advisory Board, providing strategic guidance on marketing and business strategy. He is a globally recognized scholar and thought leader in consumer behavior, competitive strategy, and relationship marketing.\n\nDr. Sheth is a Fellow of the American Psychological Association, the American Marketing Association, and the Academy of Marketing Science. He previously served as President of the Association for Consumer Research and has authored over 350 research papers and books that have significantly influenced marketing theory and practice worldwide.\n\nHe holds a Bachelor of Commerce from the University of Madras, India, and both an MBA and PhD from the University of Pittsburgh, USA.",
  },
  {
    name: "Patricia M. Loui",
    title: "International Business & Policy",
    image: "/images/advisor-7.jpg",
    initials: "PL",
    bio: "Patricia M. Loui serves on Empereal’s Strategic Advisory Board, providing strategic guidance on international business development and policy. She is an accomplished executive with extensive experience across both the private and public sectors.\n\nPatricia is the Chair and CEO of Omnitrax Group Inc., a strategic marketing, research, and planning consultancy she founded over 30 years ago. She previously served as a Board Member of the Export-Import Bank of the United States (EXIM), following her nomination by former President Barack Obama. Her deep expertise in global trade, economic development, and international policy adds valuable perspective to Empereal’s growth strategy.",
  },
];
---
<section class="section-pad bg-surface" aria-labelledby="leadership-team-title">
  <Container>
    <div class="max-w-2xl mx-auto text-center reveal">
      <p class="eyebrow">Our People</p>
      <h2 id="leadership-team-title" class="fluid-h2 mt-3">Founder Directors & Strategic Advisory Board</h2>
      <p class="fluid-lead mt-5 text-muted">
        Empereal is led by its Founder Directors and supported by a Strategic Advisory Board of senior industry leaders. Together, they bring deep expertise across renewable energy, Architectural BIPV, technology development, corporate governance, and large-scale infrastructure delivery.
      </p>
      <p class="mt-4 text-muted leading-relaxed">
        This combination of founder-led technical direction and world-class strategic counsel enables Empereal to deliver complex, high-performance clean energy and water solutions with both innovation and disciplined execution.
      </p>
    </div>

    <h3 class="mt-12 text-sm font-semibold uppercase tracking-[0.15em] text-accent-dark text-center">Founder Directors</h3>
    <div class="mt-5 grid gap-5 sm:grid-cols-2 reveal-stagger">
      {founders.map((p) => (
        <article 
          class="group flex flex-col sm:flex-row rounded-2xl bg-white ring-1 ring-primary/10 overflow-hidden hover:ring-accent/40 hover:shadow-card-lg hover:-translate-y-0.5 transition-all duration-300 h-full cursor-pointer focus:outline-none focus:ring-2 focus:ring-accent/50"
          role="button"
          tabindex="0"
          data-leader-card
          data-name={p.name}
          data-title={p.title}
          data-bio={p.bio}
          data-image={p.image}
          data-initials={p.initials}
          aria-label={`View bio of ${p.name}`}
        >
          <!-- Left/Top: Full-Height Portrait Photo -->
          <div class="relative w-full sm:w-[38%] min-h-[280px] sm:min-h-full bg-primary-50 overflow-hidden shrink-0">
            <span class="absolute inset-0 flex items-center justify-center text-2xl font-semibold text-primary-dark">
              {p.initials}
            </span>
            <img
              src={p.image}
              alt={p.name}
              class="absolute inset-0 h-full w-full object-cover object-[center_20%] transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
              onerror="this.remove()"
            />
          </div>
          
          <!-- Right: Text Content -->
          <div class="min-w-0 flex-1 flex flex-col justify-between p-6 sm:p-7">
            <div>
              <h4 class="text-base sm:text-lg font-semibold text-primary-dark text-center">{p.name}</h4>
              <p class="mt-1 text-xs sm:text-sm font-medium text-accent-dark leading-snug text-center">{p.title}</p>
              <p class="mt-3 text-sm text-muted leading-relaxed line-clamp-3 text-center">{p.bio}</p>
            </div>
            
            <div class="mt-5 flex items-center justify-center gap-1.5 text-[10px] sm:text-xs font-semibold uppercase tracking-[0.08em] text-muted group-hover:text-accent-dark transition-colors">
              <span>Click to view profile</span>
              <svg class="h-3 w-3 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </div>
        </article>
      ))}
    </div>

    <h3 class="mt-12 text-sm font-semibold uppercase tracking-[0.15em] text-accent-dark text-center">Strategic Advisory Board</h3>
    <div class="mt-5 flex flex-wrap justify-center gap-4 reveal-stagger">
      {advisors.map((p) => (
        <article 
          class="group relative flex flex-col w-[calc(50%-8px)] lg:w-[calc(25%-12px)] rounded-xl bg-white ring-1 ring-primary/10 overflow-hidden hover:ring-accent/40 hover:shadow-card-lg hover:-translate-y-0.5 transition-all duration-300 cursor-pointer focus:outline-none focus:ring-2 focus:ring-accent/50"
          role="button"
          tabindex="0"
          data-leader-card
          data-name={p.name}
          data-title={p.title}
          data-bio={p.bio}
          data-image={p.image}
          data-initials={p.initials}
          aria-label={`View bio of ${p.name}`}
        >
          <!-- Full-height background photo -->
          <div class="absolute inset-0 w-full h-full bg-primary-50">
            <span class="absolute inset-0 flex items-center justify-center text-xl font-semibold text-primary-dark">
              {p.initials}
            </span>
            <img
              src={p.image}
              alt={p.name}
              class="absolute inset-0 h-full w-full object-cover object-[center_20%] transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
              onerror="this.remove()"
            />
          </div>

          <!-- Spacer to expose top of photo -->
          <div class="relative w-full aspect-[4/3.5] pointer-events-none"></div>

          <!-- Overlay text container at the bottom -->
          <div class="relative z-10 flex flex-col p-3.5 items-center text-center justify-between bg-white/85 backdrop-blur-md border-t border-primary/5 flex-grow">
            <div class="min-w-0 w-full">
              <h4 class="text-sm font-semibold text-primary-dark leading-snug">{p.name}</h4>
              <p class="mt-0.5 text-[11px] font-medium text-accent-dark leading-snug">{p.title}</p>
            </div>
            <div class="mt-3 flex items-center justify-center gap-1 text-[10px] font-semibold uppercase tracking-[0.08em] text-muted group-hover:text-accent-dark transition-colors">
              <span>View profile</span>
              <svg class="h-2.5 w-2.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </div>
        </article>
      ))}
    </div>
  </Container>

  <!-- Professional Modal overlay -->
  <div 
    id="leader-modal" 
    class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 sm:p-6" 
    role="dialog" 
    aria-modal="true"
  >
    <!-- Modal Backdrop -->
    <div 
      class="absolute inset-0 bg-primary-dark/50 backdrop-blur-sm transition-opacity duration-300" 
      id="modal-backdrop"
    ></div>

    <!-- Modal Content Wrapper -->
    <div 
      class="relative w-full max-w-2xl transform rounded-3xl bg-white p-6 sm:p-8 shadow-2xl border border-primary/10 flex flex-col sm:flex-row gap-6 max-h-[90vh] overflow-y-auto animate-fade-up z-10"
    >
      <!-- Close button -->
      <button 
        type="button" 
        class="absolute top-4 right-4 text-muted hover:text-primary-dark focus:outline-none p-2 rounded-full hover:bg-surface transition-colors" 
        id="modal-close" 
        aria-label="Close modal"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Photo Column -->
      <div class="flex-shrink-0 mx-auto sm:mx-0">
        <div class="relative h-28 w-28 sm:h-36 sm:w-36 rounded-2xl bg-primary-50 ring-4 ring-white shadow-md overflow-hidden">
          <span id="modal-initials" class="absolute inset-0 flex items-center justify-center text-3xl font-semibold text-primary-dark"></span>
          <img 
            id="modal-image" 
            src="" 
            alt="" 
            class="absolute inset-0 h-full w-full object-cover object-[center_20%]"
          />
        </div>
      </div>

      <!-- Details Column -->
      <div class="flex-1 min-w-0 text-center sm:text-left">
        <h3 id="modal-name" class="text-xl sm:text-2xl font-semibold text-primary-dark"></h3>
        <p id="modal-title" class="mt-2 text-xs sm:text-sm font-medium text-accent-dark leading-snug"></p>
        <div class="my-4 h-px bg-gradient-to-r from-transparent via-primary/10 to-transparent sm:via-primary/10 sm:to-transparent" aria-hidden="true"></div>
        <p id="modal-bio" class="text-sm sm:text-base text-muted leading-relaxed text-left whitespace-pre-line"></p>
      </div>
    </div>
  </div>
</section>

<script>
  const modal = document.getElementById('leader-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const closeBtn = document.getElementById('modal-close');
  const modalName = document.getElementById('modal-name');
  const modalTitle = document.getElementById('modal-title');
  const modalBio = document.getElementById('modal-bio');
  const modalImage = document.getElementById('modal-image') as HTMLImageElement;
  const modalInitials = document.getElementById('modal-initials');
  const cards = document.querySelectorAll('[data-leader-card]');

  function openModal(card: Element) {
    if (!modal || !modalName || !modalTitle || !modalBio || !modalImage || !modalInitials) return;
    
    const name = card.getAttribute('data-name') || '';
    const title = card.getAttribute('data-title') || '';
    const bio = card.getAttribute('data-bio') || '';
    const image = card.getAttribute('data-image') || '';
    const initials = card.getAttribute('data-initials') || '';

    modalName.textContent = name;
    modalTitle.textContent = title;
    modalBio.textContent = bio;
    modalInitials.textContent = initials;
    
    if (image) {
      modalImage.src = image;
      modalImage.alt = name;
      modalImage.style.display = 'block';
    } else {
      modalImage.style.display = 'none';
    }

    modal.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }

  cards.forEach(card => {
    card.addEventListener('click', () => openModal(card));
    card.addEventListener('keydown', (e: any) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openModal(card);
      }
    });
  });

  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (backdrop) backdrop.addEventListener('click', closeModal);
  
  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
