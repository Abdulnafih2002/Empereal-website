---
import Container from "../../primitives/Container.astro";

const values = [
  {
    title: "Technical rigour",
    desc: "Every decision is grounded in engineering analysis and verified performance data — not assumptions or vendor claims.",
  },
  {
    title: "Innovation accountability",
    desc: "Patented technologies developed and brought to operational scale — innovation with measurable outcomes, not patents on paper.",
  },
  {
    title: "Collaborative problem-solving",
    desc: "Working alongside global architects, developers, utilities, and governments — where the best answer comes from the collaboration, not a single firm.",
  },
  {
    title: "Long-term thinking",
    desc: "Projects designed for 25+ year operational life require forward-looking engineering decisions — our culture reflects this reality at every level.",
  },
];
---
<section class="section-pad bg-[#0F2238] text-white" aria-labelledby="culture-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow !text-accent">How We Work Together</p>
      <h2 id="culture-title" class="fluid-h2 mt-3 text-white">Our organisational culture</h2>
      <p class="fluid-lead mt-5 text-white/75">
        Empereal's culture has been built deliberately — to attract engineers who want to solve hard problems and stay accountable for the outcomes.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 reveal-stagger">
      {values.map((v) => (
        <div class="flex items-start gap-4 rounded-xl bg-white/[0.04] border border-white/10 p-5 sm:p-6">
          <span class="mt-0.5 inline-flex h-7 w-7 items-center justify-center rounded-full bg-accent/20 text-accent shrink-0" aria-hidden="true">
            <svg viewBox="0 0 14 14" class="h-3.5 w-3.5" fill="none">
              <path d="M3 7l3 3 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <div>
            <h3 class="text-base font-semibold text-white">{v.title}</h3>
            <p class="mt-1.5 text-sm text-white/75 leading-relaxed">{v.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
