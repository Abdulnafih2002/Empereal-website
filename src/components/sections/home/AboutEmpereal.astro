---
import Container from "../../primitives/Container.astro";

const benefits = [
  {
    title: "Environmentally Friendly",
    description: "Our renewable energy systems cut carbon emissions and help build a cleaner, more sustainable future.",
    icon: "/images/Service%20icons/How%20we%20serve/environmentally-friendly-icon.webp",
  },
  {
    title: "Built to Last",
    description: "Engineered for long-term reliability, our systems require minimal upkeep and deliver lower operational costs over time.",
    icon: "/images/Service%20icons/How%20we%20serve/built-to-last-icon.webp",
  },
];
---
<section id="about" class="section-pad bg-white" aria-labelledby="about-title">
  <Container>
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center xl:gap-16">
      <div class="reveal-left">
        <p class="inline-flex rounded-full border border-primary/15 bg-white px-3 py-1 text-[11px] font-medium text-primary-dark shadow-sm">
          Who Are We?
        </p>
        <h2 id="about-title" class="mt-4 max-w-xl font-display text-[clamp(2.35rem,4.2vw,4.5rem)] font-semibold leading-[0.98] tracking-[-0.045em] text-primary-dark">
          Experts in the World of Clean Energy
        </h2>
        <p class="mt-6 max-w-xl text-base leading-relaxed text-muted sm:text-lg">
          Empereal delivers solar, energy storage, desalination, and green hydrogen solutions across Asia and the Middle East — backed by deep engineering expertise and a track record of reliable execution.
        </p>

        <div class="mt-9 grid gap-7 sm:grid-cols-2 sm:gap-8">
          {benefits.map((benefit) => (
            <article class="max-w-xs">
              <img
                src={benefit.icon}
                alt=""
                class="h-11 w-11 object-contain mix-blend-multiply"
                loading="lazy"
                decoding="async"
                aria-hidden="true"
              />
              <h3 class="mt-4 text-base font-semibold text-primary-dark">{benefit.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{benefit.description}</p>
            </article>
          ))}
        </div>
      </div>

      <figure class="relative reveal-right">
        <div class="relative aspect-[16/10] overflow-hidden bg-white">
          <img
            src="/images/logos/About%20Us%20Section%20Map.png"
            alt="Map showing Empereal's global presence across the United States, Saudi Arabia, United Arab Emirates, India, Maldives, and Singapore"
            class="absolute inset-0 h-full w-full object-contain object-center"
            loading="lazy"
            decoding="async"
          />
        </div>
      </figure>
    </div>
  </Container>
</section>
