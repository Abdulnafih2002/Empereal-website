---
import Container from "../../primitives/Container.astro";

const metrics = [
  { value: "18+", label: "Years of Experience" },
  { value: "695 MW", label: "of Solar Commissioned" },
  { value: "140+", label: "Projects Delivered" },
];
---

<section
  class="home-hero relative isolate flex min-h-[100svh] overflow-hidden rounded-b-xl bg-primary-dark text-white"
  aria-label="Empereal Energy — Smart Solar Solutions"
  data-hero
  data-hero-backdrop
>
  <div class="absolute inset-0 -z-10">
    <img
      src="/images/uae-pavilion-1.jpg"
      alt="UAE Pavilion with integrated solar architecture"
      class="h-full w-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(8,22,37,.88)_0%,rgba(8,22,37,.68)_38%,rgba(8,22,37,.22)_72%,rgba(8,22,37,.08)_100%)]" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(5,17,29,.35)_0%,transparent_28%,transparent_64%,rgba(5,17,29,.42)_100%)]" aria-hidden="true"></div>
  </div>

  <Container class="hero-content-shell relative flex w-full flex-1 items-center pb-32 pt-28 sm:pb-36 sm:pt-32 lg:pb-40 lg:pt-36">
    <div class="hero-copy max-w-[46rem]">
      <h1 class="hero-title fluid-display hero-enter hero-enter-1 text-white">
        Engineering High-Performance Clean Energy Systems
      </h1>
      <p class="hero-enter hero-enter-2 mt-5 max-w-2xl text-base leading-relaxed text-white/85 sm:text-lg">
        Empereal designs and delivers complex Architectural BIPV &amp; Solar Facade, Solar PV Systems, Energy Storage, Green Hydrogen, and Water Desalination projects across Asia and the Middle East — with full technical accountability from concept to long-term operation.
      </p>

      <div class="hero-enter hero-enter-3 mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="/projects" class="hero-home-pill">
          Explore Our Projects
        </a>
      </div>
    </div>
  </Container>

  <div class="stats-wrap absolute bottom-0 left-0 z-10 w-full sm:w-[54%] sm:max-w-[48rem] 2xl:left-1/2 2xl:max-w-[64rem] 2xl:-translate-x-1/2">
    <dl class="stats-card grid grid-cols-3 bg-white text-ink shadow-2xl">
      {metrics.map((metric) => (
        <div class="relative px-3 py-5 text-center sm:px-6 sm:py-6 lg:px-8 lg:py-7">
          <dd class="font-display text-xl font-semibold leading-none text-black sm:text-3xl lg:text-4xl">{metric.value}</dd>
          <dt class="mx-auto mt-2 max-w-[8rem] text-[10px] font-medium leading-[1.15] text-black/75 sm:text-xs">{metric.label}</dt>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .hero-title {
    max-width: 13ch;
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.22);
  }

  .stats-card {
    --shape-radius: 3.5rem;
    position: relative;
    overflow: visible;
    border-radius: 0 var(--shape-radius) 0 0;
    /* Keeps the curved transition crisp against the photograph in Safari. */
    isolation: isolate;
    transform: translateZ(0);
  }

  .stats-card::after {
    content: "";
    position: absolute;
    z-index: -1;
    right: calc(var(--shape-radius) * -1);
    bottom: 0;
    width: var(--shape-radius);
    height: var(--shape-radius);
    background: radial-gradient(
      circle at 100% 0,
      transparent calc(var(--shape-radius) - 0.5px),
      #fff var(--shape-radius)
    );
    pointer-events: none;
  }

  .stats-card::before {
    content: "";
    position: absolute;
    z-index: -1;
    left: calc(var(--shape-radius) * -1);
    bottom: 0;
    width: var(--shape-radius);
    height: var(--shape-radius);
    background: radial-gradient(
      circle at 0 0,
      transparent calc(var(--shape-radius) - 0.5px),
      #fff var(--shape-radius)
    );
    pointer-events: none;
    display: none;
  }

  @media (max-width: 639px) {
    .home-hero { min-height: 47rem; }
    .stats-card { --shape-radius: 2.5rem; }
    .stats-card::before,
    .stats-card::after { display: none; }
  }

  @media (min-width: 1536px) {
    .hero-content-shell {
      max-width: 100rem;
      padding-left: clamp(4rem, 6vw, 7rem);
      padding-right: clamp(4rem, 6vw, 7rem);
    }
    .hero-copy {
      max-width: 64rem;
    }
    .hero-title {
      max-width: 16ch;
    }
    .stats-card {
      border-radius: var(--shape-radius) var(--shape-radius) 0 0;
    }
    .stats-card::before {
      display: block;
    }
  }
</style>
