---
import Container from "../../primitives/Container.astro";
import ProjectCard from "../projects/ProjectCard.astro";
import { projects as projectData } from "../../../data/projects.ts";

const featuredSlugs = ["dewa-hq", "masdar-mc2", "uae-pavilion-expo"];
const projects = featuredSlugs
  .map((slug) => projectData.find((project) => project.slug === slug))
  .filter((project): project is NonNullable<typeof project> => Boolean(project));

---
<section id="projects" class="section-pad bg-white" aria-labelledby="projects-title">
  <Container>
    <div class="text-center max-w-2xl mx-auto reveal-stagger">
      <p class="eyebrow">Our Work</p>
      <h2 id="projects-title" class="fluid-h2 mt-3">Featured Projects</h2>
      <p class="mt-4 text-muted fluid-lead">
        Explore how Empereal delivers landmark solar infrastructure — from architectural BIPV façades to utility-scale installations — across the Middle East and beyond.
      </p>
    </div>

    <div class="mt-12 lg:mt-16 grid gap-5 md:grid-cols-2 lg:grid-cols-3 reveal-stagger">
      {projects.map((p) => (
        <ProjectCard project={p} />
      ))}
    </div>

    <div class="mt-10 text-center reveal">
      <a
        href="/projects"
        class="inline-flex items-center gap-2 rounded-md border border-primary/20 bg-white hover:border-primary hover:bg-primary-50 px-6 py-3 text-sm font-semibold text-primary transition-colors min-h-[44px]"
      >
        Explore All Projects
        <svg viewBox="0 0 20 20" class="h-4 w-4 arrow-slide" fill="none" aria-hidden="true">
          <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </Container>
</section>
