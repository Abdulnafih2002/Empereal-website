---
import Container from "../../primitives/Container.astro";
import type { FeaturesSection } from "../../../lib/types.js";

interface Props {
  data: FeaturesSection;
}
const { data: { highlight, cards } } = Astro.props;

// Gauge: circumference of r=48 circle = 2π×48 ≈ 301.6
const CIRC = 301.6;
const offset = CIRC - (CIRC * Math.min(Math.max(highlight.gaugePercent, 0), 100)) / 100;
---
<section id="experience" class="bg-surface relative overflow-visible" aria-labelledby="experience-title">
  <!-- Desktop / Horizontal Scroll Pin Layout (lg and above) -->
  <div class="hidden lg:block relative lg:h-[220vh]" id="experience-pin-container">
    <div class="sticky top-20 h-[calc(100vh-5rem)] overflow-hidden flex flex-col justify-center bg-surface">
      <Container>
        <div class="text-center max-w-2xl mx-auto">
          <h2 id="experience-title" class="fluid-h2 hero-enter hero-enter-1">Experience the Future of Solar Power.</h2>
          <p class="mt-3 text-muted fluid-lead hero-enter hero-enter-2">
            Reliable solar solutions engineered for performance, savings, and sustainability.
          </p>
        </div>
      </Container>

      <div class="relative w-full max-w-[1268px] mx-auto overflow-hidden mt-12 lg:mt-16 px-6 lg:px-0" id="experience-cards-window">
        <div
          id="experience-scroll-track"
          class="flex gap-6 will-change-transform"
        >
          <!-- Featured card (dark navy) -->
          <article id="featured-card" class="group relative overflow-hidden rounded-2xl bg-primary-dark text-white shadow-card hover:shadow-card-lg hover:-translate-y-1 min-h-[440px] w-[460px] shrink-0" style="transition: transform 0.3s ease, box-shadow 0.3s ease;">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-out pointer-events-none">
              {highlight.imageUrl && (
                <img
                  src={highlight.imageUrl}
                  alt=""
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                  onerror="this.remove()"
                />
              )}
              <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/70 via-primary/50 to-success/30" aria-hidden="true"></div>
              <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/75 via-primary-dark/20 to-transparent" aria-hidden="true"></div>
            </div>

            <div class="relative flex h-full flex-col justify-between p-6 lg:p-8">
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-accent">{highlight.eyebrow}</p>
                <h3 class="mt-2 font-display text-2xl font-semibold leading-tight text-white">
                  {highlight.title}
                </h3>
                <p class="mt-3 text-sm text-white/80 max-w-md">
                  {highlight.description}
                </p>
              </div>

              <div class="mt-6 flex items-end justify-between gap-4">
                <div>
                  <p class="text-[11px] uppercase tracking-[0.2em] text-white/60">{highlight.badgeLabel}</p>
                  <p class="mt-1 font-display text-3xl font-semibold text-white">
                    <span class="text-accent">{highlight.badgeValue}</span>
                  </p>
                  <p class="text-xs text-white/70">{highlight.badgeSuffix}</p>
                </div>

                <svg viewBox="0 0 120 120" class="h-24 w-24 shrink-0" aria-hidden="true">
                  <defs>
                    <linearGradient id="gauge-desktop" x1="0" x2="1" y1="0" y2="0">
                      <stop offset="0" stop-color="#F5B82E"/>
                      <stop offset="1" stop-color="#F27400"/>
                    </linearGradient>
                  </defs>
                  <circle cx="60" cy="60" r="48" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="10"/>
                  <circle
                    cx="60" cy="60" r="48" fill="none"
                    stroke="url(#gauge-desktop)"
                    stroke-width="10"
                    stroke-linecap="round"
                    stroke-dasharray={CIRC}
                    stroke-dashoffset={offset}
                    transform="rotate(-90 60 60)"
                  />
                  <text x="60" y="66" text-anchor="middle" fill="#fff" font-family="Clash Display, sans-serif" font-size="22" font-weight="600">
                    {highlight.gaugePercent}%
                  </text>
                </svg>
              </div>
            </div>
          </article>

          <!-- Dynamic feature cards -->
          {cards.map((f) => (
            <article class="group relative flex flex-col overflow-hidden isolate rounded-2xl bg-white border border-primary/10 shadow-card hover:shadow-card-lg transition-all duration-300 hover:-translate-y-1 hover:border-transparent p-6 lg:p-7 min-h-[440px] w-[380px] shrink-0">
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-out pointer-events-none -z-10">
                {f.imageUrl && (
                  <img
                    src={f.imageUrl}
                    alt=""
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                    onerror="this.remove()"
                  />
                )}
                <!-- Keep the project image visible while giving every text area a consistent dark contrast layer. -->
                <div class="absolute inset-0 bg-primary-dark/35 backdrop-blur-[1px]" aria-hidden="true"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/95 via-primary-dark/85 to-primary-dark/70" aria-hidden="true"></div>
              </div>

              <span class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-accent-soft text-primary-dark ring-1 ring-accent/30 shadow-sm transition-all duration-300 group-hover:bg-white group-hover:ring-white">
                {f.icon ? (
                  <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" set:html={f.icon}></svg>
                ) : (
                  <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="9"/>
                  </svg>
                )}
              </span>
              <h3 class="mt-6 font-display text-lg lg:text-xl font-semibold text-primary-dark group-hover:text-white feature-text transition-colors duration-300">
                {f.title}
              </h3>
              <p class="mt-2 text-sm text-muted group-hover:text-white/95 feature-text leading-relaxed flex-1 transition-colors duration-300">
                {f.description}
              </p>
              <a
                href={f.href ?? "#"}
                class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-primary group-hover:text-accent feature-text-link transition-colors"
              >
                Learn more
                <svg viewBox="0 0 20 20" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" aria-hidden="true">
                  <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile / Vertical Stack Layout (below lg) -->
  <div class="lg:hidden section-pad">
    <Container>
      <div class="text-center max-w-2xl mx-auto reveal-stagger">
        <h2 class="fluid-h2">Experience the Future of Solar Power.</h2>
        <p class="mt-3 text-muted fluid-lead">
          Reliable solar solutions engineered for performance, savings, and sustainability.
        </p>
      </div>

      <div class="mt-12 grid gap-5 reveal-stagger">
        <!-- Featured card (dark navy) -->
        <article class="group relative overflow-hidden rounded-2xl bg-primary-dark text-white shadow-card hover:shadow-card-lg transition-all duration-300 min-h-[360px]">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-out pointer-events-none">
            {highlight.imageUrl && (
              <img
                src={highlight.imageUrl}
                alt=""
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
                decoding="async"
                onerror="this.remove()"
              />
            )}
            <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/70 via-primary/50 to-success/30" aria-hidden="true"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/75 via-primary-dark/20 to-transparent" aria-hidden="true"></div>
          </div>

          <div class="relative flex h-full flex-col justify-between p-6">
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-accent">{highlight.eyebrow}</p>
              <h3 class="mt-2 font-display text-2xl font-semibold leading-tight text-white">
                {highlight.title}
              </h3>
              <p class="mt-3 text-sm text-white/80 max-w-md">
                {highlight.description}
              </p>
            </div>

            <div class="mt-6 flex items-end justify-between gap-4">
              <div>
                <p class="text-[11px] uppercase tracking-[0.2em] text-white/60">{highlight.badgeLabel}</p>
                <p class="mt-1 font-display text-3xl font-semibold text-white">
                  <span class="text-accent">{highlight.badgeValue}</span>
                </p>
                <p class="text-xs text-white/70">{highlight.badgeSuffix}</p>
              </div>

              <svg viewBox="0 0 120 120" class="h-20 w-20 shrink-0" aria-hidden="true">
                <defs>
                  <linearGradient id="gauge-mobile" x1="0" x2="1" y1="0" y2="0">
                    <stop offset="0" stop-color="#F5B82E"/>
                    <stop offset="1" stop-color="#F27400"/>
                  </linearGradient>
                </defs>
                <circle cx="60" cy="60" r="48" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="10"/>
                <circle
                  cx="60" cy="60" r="48" fill="none"
                  stroke="url(#gauge-mobile)"
                  stroke-width="10"
                  stroke-linecap="round"
                  stroke-dasharray={CIRC}
                  stroke-dashoffset={offset}
                  transform="rotate(-90 60 60)"
                />
                <text x="60" y="66" text-anchor="middle" fill="#fff" font-family="Clash Display, sans-serif" font-size="22" font-weight="600">
                  {highlight.gaugePercent}%
                </text>
              </svg>
            </div>
          </div>
        </article>

        <!-- Dynamic feature cards -->
        {cards.map((f) => (
          <article class="group relative flex flex-col overflow-hidden isolate rounded-2xl bg-white border border-primary/10 shadow-card hover:shadow-card-lg transition-all duration-300 p-6 min-h-[360px]">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-out pointer-events-none -z-10">
              {f.imageUrl && (
                <img
                  src={f.imageUrl}
                  alt=""
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                  onerror="this.remove()"
                />
              )}
                <!-- Keep the project image visible while giving every text area a consistent dark contrast layer. -->
                <div class="absolute inset-0 bg-primary-dark/35 backdrop-blur-[1px]" aria-hidden="true"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/95 via-primary-dark/85 to-primary-dark/70" aria-hidden="true"></div>
            </div>

            <span class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-accent-soft text-primary-dark ring-1 ring-accent/30 shadow-sm">
              {f.icon ? (
                <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" set:html={f.icon}></svg>
              ) : (
                <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="9"/>
                </svg>
              )}
            </span>
            <h3 class="mt-6 font-display text-lg font-semibold text-primary-dark group-hover:text-white feature-text transition-colors duration-300">
              {f.title}
            </h3>
            <p class="mt-2 text-sm text-muted group-hover:text-white/95 feature-text leading-relaxed flex-1 transition-colors duration-300">
              {f.description}
            </p>
            <a
              href={f.href ?? "#"}
              class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-primary group-hover:text-accent feature-text-link transition-colors"
            >
              Learn more
              <svg viewBox="0 0 20 20" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" aria-hidden="true">
                <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </article>
        ))}
      </div>
    </Container>
  </div>
</section>

<script>
  function initHorizontalScroll() {
    const track = document.getElementById("experience-pin-container");
    const scrollTrack = document.getElementById("experience-scroll-track");
    const cardsWindow = document.getElementById("experience-cards-window");
    const featuredCard = document.getElementById("featured-card");
    if (!track || !scrollTrack || !cardsWindow) return;

    // Cards start hidden via CSS (opacity:0 / translateY) — animate them in
    // once the section is first reached, regardless of IntersectionObserver.
    let cardsAnimated = false;
    function animateCardsIn() {
      if (cardsAnimated) return;
      cardsAnimated = true;
      const items = scrollTrack.querySelectorAll("article");
      items.forEach((el, i) => {
        (el as HTMLElement).style.transition = `opacity 0.55s cubic-bezier(.22,.7,.3,1) ${i * 0.08}s, transform 0.55s cubic-bezier(.22,.7,.3,1) ${i * 0.08}s`;
        (el as HTMLElement).style.opacity = "1";
        (el as HTMLElement).style.transform = "none";
      });
    }

    // Set initial hidden state on articles (desktop only)
    function setInitialState() {
      if (window.innerWidth < 1024) return;
      const items = scrollTrack.querySelectorAll("article");
      items.forEach((el) => {
        (el as HTMLElement).style.opacity = "0";
        (el as HTMLElement).style.transform = "translateY(18px)";
      });
    }

    const updateScroll = () => {
      if (window.innerWidth < 1024) {
        scrollTrack.style.transform = "";
        if (featuredCard) {
          featuredCard.style.opacity = "";
          featuredCard.style.visibility = "";
        }
        return;
      }

      const rect = track.getBoundingClientRect();
      const header = document.getElementById("site-header");
      const headerHeight = header ? header.offsetHeight : 80;

      // totalScrollRange: how many pixels the page scrolls while section is pinned
      const totalScrollRange = track.offsetHeight - window.innerHeight;
      if (totalScrollRange <= 0) return;

      const offsetTop = rect.top - headerHeight;
      const progress = -offsetTop / totalScrollRange;
      const clampedProgress = Math.max(0, Math.min(1, progress));

      // Animate cards in as soon as section enters view
      if (clampedProgress > 0) animateCardsIn();

      // Horizontal translate of card track
      const maxTranslate = scrollTrack.scrollWidth - cardsWindow.offsetWidth;
      if (maxTranslate > 0) {
        const translateX = clampedProgress * maxTranslate;
        scrollTrack.style.transform = `translateX(-${translateX}px)`;
      } else {
        scrollTrack.style.transform = "";
      }

      // Fade out the featured card as cards scroll away
      if (featuredCard) {
        const opacity = 1 - clampedProgress * 1.8; // fade quicker
        featuredCard.style.opacity = Math.max(0, opacity).toString();
        featuredCard.style.visibility = opacity <= 0 ? "hidden" : "visible";
      }
    };

    let ticking = false;
    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        updateScroll();
        ticking = false;
      });
    };

    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", () => {
      setInitialState();
      requestUpdate();
    }, { passive: true });

    // Defer first run to next rAF after layout is painted (avoids offsetHeight=0 during SSR hydration)
    setInitialState();
    requestAnimationFrame(() => requestAnimationFrame(updateScroll));
  }

  // Guard: run after DOM is ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHorizontalScroll);
  } else {
    initHorizontalScroll();
  }
</script>

<style>
  .group:hover .feature-text {
    text-shadow: 0 1px 2px rgba(15, 23, 42, 0.6), 0 2px 8px rgba(15, 23, 42, 0.35);
  }
  .group:hover .feature-text-link {
    text-shadow: 0 1px 2px rgba(15, 23, 42, 0.55);
  }
  @media (prefers-reduced-motion: reduce) {
    .group:hover .feature-text,
    .group:hover .feature-text-link {
      text-shadow: none;
    }
  }
</style>
