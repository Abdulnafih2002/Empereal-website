---
import Container from "../../primitives/Container.astro";

const stats = [
  { value: "20+", label: "Years of Industry Experience" },
  { value: "1,200 MWp", label: "Solar Capacity Installed" },
  { value: "350+", label: "Projects Successfully Delivered" },
  { value: "15+", label: "Countries with Active Operations" },
];
---
<section class="bg-primary-dark text-white border-t border-accent/15" aria-label="Empereal by the numbers">
  <Container>
    <dl class="grid grid-cols-2 lg:grid-cols-4 divide-y divide-white/10 lg:divide-y-0 lg:divide-x lg:divide-white/10 reveal-stagger">
      {stats.map((s) => (
        <div class="px-4 py-8 lg:py-10 text-center">
          <dd class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-accent leading-none">{s.value}</dd>
          <dt class="mt-2 text-xs uppercase tracking-[0.15em] text-white/65 font-medium">{s.label}</dt>
        </div>
      ))}
    </dl>
  </Container>
</section>
