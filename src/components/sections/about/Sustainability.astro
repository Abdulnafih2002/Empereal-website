---
import Container from "../../primitives/Container.astro";

const items = [
  {
    title: "Renewable Energy First",
    body: "Every project we design prioritizes on-site renewable generation — from utility-scale solar farms to building-integrated photovoltaics that turn facades into power plants.",
    icon: "chart",
  },
  {
    title: "Net-Zero Architecture",
    body: "We design buildings and developments that generate as much energy as they consume — achieving LEED Platinum, net-zero, and positive-energy certifications.",
    icon: "building",
  },
  {
    title: "Water Conservation",
    body: "Our solar-powered desalination and water treatment solutions reduce energy dependency while delivering clean water to communities where it's needed most.",
    icon: "drop",
  },
  {
    title: "Green Hydrogen",
    body: "Turning surplus solar into green hydrogen for industrial decarbonization, heavy transport, and the wider clean fuel ecosystem — powering the next phase of energy transition.",
    icon: "h2",
  },
  {
    title: "Energy Storage & Grid Stability",
    body: "Advanced BESS and thermal storage systems ensure renewable energy is available round-the-clock, enabling genuine grid independence and peak load management.",
    icon: "esg",
  },
  {
    title: "Circular Economy",
    body: "From BIPV modules designed for reuse to zero-waste resort operations, we embed circular principles into every stage of project design and delivery.",
    icon: "globe",
  },
];
---
<section class="section-pad bg-surface" aria-labelledby="sustainability-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow">Our Approach</p>
      <h2 id="sustainability-title" class="fluid-h2 mt-3">Six pillars of sustainable infrastructure.</h2>
      <p class="fluid-lead mt-5 text-muted">
        Every project we deliver is designed around these core sustainability principles — from concept through construction and decades of operation.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 reveal-stagger">
      {items.map((item) => (
        <div class="group flex items-start gap-4 rounded-xl bg-white ring-1 ring-primary/10 p-5 sm:p-6 hover:ring-accent/40 hover:shadow-card hover:-translate-y-0.5 transition-all duration-300">
          <div class="icon-lift inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent/15 text-accent-dark shrink-0" aria-hidden="true">
            {item.icon === "chart" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <path d="M3 14 L7 8 L10 11 L13 6 L17 14Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                <line x1="2" y1="17" x2="18" y2="17" stroke="currentColor" stroke-width="1"/>
              </svg>
            )}
            {item.icon === "building" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <rect x="2" y="7" width="16" height="11" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <path d="M6 7V5a4 4 0 0 1 8 0v2" stroke="currentColor" stroke-width="1.4"/>
              </svg>
            )}
            {item.icon === "drop" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <path d="M10 2 Q14.5 7 14.5 11 A4.5 4.5 0 0 1 5.5 11 Q5.5 7 10 2Z" stroke="currentColor" stroke-width="1.4" fill="none"/>
              </svg>
            )}
            {item.icon === "h2" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <circle cx="10" cy="10" r="6" stroke="currentColor" stroke-width="1.4"/>
                <text x="10" y="13" text-anchor="middle" font-size="7" fill="currentColor" font-weight="600">H₂</text>
              </svg>
            )}
            {item.icon === "esg" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <rect x="3" y="6" width="14" height="10" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <line x1="7" y1="6" x2="7" y2="3" stroke="currentColor" stroke-width="1.4"/>
                <line x1="13" y1="6" x2="13" y2="3" stroke="currentColor" stroke-width="1.4"/>
              </svg>
            )}
            {item.icon === "globe" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.4"/>
                <line x1="3" y1="10" x2="17" y2="10" stroke="currentColor" stroke-width="1" opacity=".6"/>
                <path d="M7 4 Q10 10 7 16" stroke="currentColor" stroke-width="1" opacity=".6"/>
                <path d="M13 4 Q10 10 13 16" stroke="currentColor" stroke-width="1" opacity=".6"/>
              </svg>
            )}
          </div>
          <div>
            <h3 class="text-base font-semibold text-primary-dark">{item.title}</h3>
            <p class="mt-1 text-sm text-muted leading-relaxed">{item.body}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
