---
import Container from "../../primitives/Container.astro";

const principles = [
  {
    title: "Design-first methodology",
    body: "Every project begins with rigorous feasibility, generation studies, and system modelling before a single piece of equipment is specified or procured.",
    icon: "design",
  },
  {
    title: "Quality-certified delivery",
    body: "ISO 9001:2015, ISO 14001:2015, and ISO 45001:2018 certified management systems govern every aspect of project delivery — design, procurement, construction, and O&M.",
    icon: "quality",
  },
  {
    title: "Full-lifecycle responsibility",
    body: "From concept and feasibility through engineering, EPC, commissioning, and long-term O&M — Empereal retains accountability across the full project lifecycle.",
    icon: "lifecycle",
  },
  {
    title: "Innovation with accountability",
    body: "Patented solar thermal and desalination technologies backed by 15+ years of operational track record — innovation tested at scale, not in a laboratory.",
    icon: "innovation",
  },
];
---
<section class="section-pad bg-white" aria-labelledby="philosophy-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow">Our Engineering Philosophy</p>
      <h2 id="philosophy-title" class="fluid-h2 mt-3">Four principles that guide every project</h2>
      <p class="fluid-lead mt-5 text-muted">
        Empereal was modelled to be sustainable without subsidies — a principle established at founding that continues to guide how we select, design, and deliver projects.
      </p>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4 reveal-stagger">
      {principles.map((p) => (
        <article class="group rounded-xl bg-white ring-1 ring-primary/10 shadow-card p-6 sm:p-7 hover:ring-accent/40 hover:shadow-card-lg hover:-translate-y-0.5 transition-all duration-300">
          <div class="icon-lift inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent/15 text-accent-dark" aria-hidden="true">
            {p.icon === "design" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <path d="M3.5 16 L3.5 10 L10 3.5 L16.5 10 L16.5 16" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <rect x="7.5" y="12" width="5" height="4" stroke="currentColor" stroke-width="1.3"/>
              </svg>
            )}
            {p.icon === "quality" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/>
                <path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {p.icon === "lifecycle" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <circle cx="10" cy="6.5" r="3" stroke="currentColor" stroke-width="1.5"/>
                <path d="M3.5 17 Q3.5 12 10 12 Q16.5 12 16.5 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
            {p.icon === "innovation" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none">
                <path d="M10 2 L12.5 7.5 L18 8 L14 12 L15 17.5 L10 15 L5 17.5 L6 12 L2 8 L7.5 7.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
          <h3 class="mt-4 text-base font-semibold text-primary-dark">{p.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{p.body}</p>
        </article>
      ))}
    </div>

    <aside class="mt-10 max-w-3xl bg-accent/5 border-l-4 border-accent px-5 py-4 reveal">
      <p class="text-sm sm:text-base text-ink italic">
        <strong class="not-italic font-semibold">"Sustainable without subsidies"</strong> — a founding principle that continues to guide project selection and business model design at Empereal.
      </p>
    </aside>
  </Container>
</section>
