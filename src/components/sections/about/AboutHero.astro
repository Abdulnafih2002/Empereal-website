---
import Container from "../../primitives/Container.astro";

const metrics = [
  { value: "18+", label: "Years of Experience" },
  { value: "695 MW", label: "of Solar Commissioned" },
  { value: "140+", label: "Projects Delivered" },
];
---

<section
  class="about-hero relative isolate -mt-16 lg:-mt-20 flex min-h-[100svh] overflow-hidden rounded-b-xl bg-primary-dark text-white"
  aria-labelledby="about-hero-title"
  data-hero
  data-hero-backdrop
>
  <div class="absolute inset-0 -z-10">
    <img
      src="/images/dewa-hq-main.jpg"
      alt="Empereal clean-energy engineering at DEWA headquarters"
      class="h-full w-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(8,22,37,.88)_0%,rgba(8,22,37,.68)_38%,rgba(8,22,37,.22)_72%,rgba(8,22,37,.08)_100%)]" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(5,17,29,.35)_0%,transparent_28%,transparent_64%,rgba(5,17,29,.42)_100%)]" aria-hidden="true"></div>
  </div>

  <Container class="relative flex w-full flex-1 items-center pb-32 pt-28 sm:pb-36 sm:pt-32 lg:pb-40 lg:pt-36">
    <div class="max-w-[46rem]">
      <p class="hero-enter hero-enter-1 mb-4 text-xs font-bold uppercase tracking-[0.22em] text-orange sm:text-sm">
        Est. 2008 · Delivering across 15+ countries
      </p>
      <h1 id="about-hero-title" class="about-hero-title hero-enter hero-enter-2 text-white">
        Engineering the future of clean energy and water.
      </h1>
      <p class="hero-enter hero-enter-3 mt-5 max-w-2xl text-base leading-relaxed text-white/85 sm:text-lg">
        Empereal empowers communities through the delivery of clean energy and pure water via innovative, reliable, world-class systems. Our deep expertise in design, fabrication, implementation, and operations enables highly versatile renewable energy solutions.
      </p>

      <div class="hero-enter hero-enter-4 mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="/#projects" class="hero-home-pill">View Our Projects</a>
      </div>
    </div>
  </Container>

  <div class="about-stats-wrap absolute bottom-0 left-0 z-10 w-full sm:w-[54%] sm:max-w-[48rem]">
    <dl class="about-stats-card grid grid-cols-3 bg-white text-ink shadow-2xl">
      {metrics.map((metric) => (
        <div class="relative px-3 py-5 text-center sm:px-6 sm:py-6 lg:px-8 lg:py-7">
          <dd class="font-display text-xl font-semibold leading-none text-black sm:text-3xl lg:text-4xl">{metric.value}</dd>
          <dt class="mx-auto mt-2 max-w-[8rem] text-[10px] font-medium leading-[1.15] text-black/75 sm:text-xs">{metric.label}</dt>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .about-hero-title {
    max-width: 13ch;
    font-size: clamp(2.7rem, 5.6vw, 5.4rem);
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.22);
  }

  .about-stats-card {
    --shape-radius: 3.5rem;
    position: relative;
    overflow: visible;
    border-radius: 0 var(--shape-radius) 0 0;
    isolation: isolate;
    transform: translateZ(0);
  }

  .about-stats-card::after {
    content: "";
    position: absolute;
    z-index: -1;
    right: calc(var(--shape-radius) * -1);
    bottom: 0;
    width: var(--shape-radius);
    height: var(--shape-radius);
    background: radial-gradient(
      circle at 100% 0,
      transparent calc(var(--shape-radius) - 0.5px),
      #fff var(--shape-radius)
    );
    pointer-events: none;
  }

  @media (max-width: 639px) {
    .about-hero { min-height: 47rem; }
    .about-stats-card { --shape-radius: 2.5rem; }
    .about-stats-card::after { display: none; }
  }
</style>
