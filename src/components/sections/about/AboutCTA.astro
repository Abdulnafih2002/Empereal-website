---
import Container from "../../primitives/Container.astro";
---
<section class="bg-primary-dark text-white border-t border-accent/15" aria-labelledby="about-cta-title">
  <Container>
    <div class="py-16 sm:py-20 text-center max-w-2xl mx-auto reveal">
      <h2 id="about-cta-title" class="fluid-h2 text-white">Let's discuss how Empereal can support your next clean energy or water infrastructure project.</h2>
      <p class="mt-4 fluid-lead text-white/75 max-w-lg mx-auto">
        Singapore • Dubai • Abu Dhabi • India • Saudi Arabia • Maldives — wherever you're building, we're ready to help.
      </p>
      <a
        href="/contact"
        class="site-cta site-cta-on-dark press mt-8"
      >
        Get in Touch
      </a>
    </div>
  </Container>
</section>
