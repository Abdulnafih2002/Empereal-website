---
import Container from "../../primitives/Container.astro";

const points = [
  "Trusted EPC expertise across 350+ commissioned projects worldwide",
  "Pioneering architectural solar integration across Asia and the Middle East",
  "ISO 9001, ISO 14001, and ISO 45001 certified operations",
  "Patented solar thermal and solar desalination technologies",
];
---
<section class="section-pad bg-surface" aria-labelledby="our-purpose-title">
  <Container>
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
      <div class="reveal-left reveal-stagger order-2 lg:order-1">
        <p class="eyebrow">Our Purpose</p>
        <h2 id="our-purpose-title" class="fluid-h2 mt-3">Empowering communities through clean energy and pure water</h2>
        <p class="mt-5 text-muted fluid-lead max-w-xl">
          To deliver integrated clean energy and water solutions that perform for decades, respect the environment, and create lasting value for the communities and clients we serve.
        </p>
        <p class="mt-4 text-muted max-w-xl">
          A world where every building generates power, every community has clean water, and every industry runs on renewable energy — decentralized, decarbonized, and democratized.
        </p>

        <ul class="mt-7 space-y-3">
          {points.map((p) => (
            <li class="flex items-start gap-3 text-sm sm:text-base text-ink">
              <span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-accent text-primary-dark shrink-0" aria-hidden="true">
                <svg viewBox="0 0 20 20" class="h-3.5 w-3.5" fill="none">
                  <path d="M4 10.5l3.5 3.5L16 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{p}</span>
            </li>
          ))}
        </ul>

        <a
          href="/solutions"
          class="mt-8 inline-flex items-center gap-2 rounded-md bg-ink hover:bg-primary-dark px-5 py-3 text-sm font-semibold text-white transition-colors min-h-[44px]"
        >
          Learn more about our solutions
          <svg viewBox="0 0 20 20" class="h-4 w-4 arrow-slide" fill="none" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <figure class="group relative order-1 lg:order-2 reveal-right">
        <div class="hover-zoom relative overflow-hidden rounded-2xl aspect-[4/3] shadow-card-lg ring-1 ring-primary/5 bg-gradient-to-br from-primary via-primary-light to-accent/30 transition-shadow duration-500 hover:shadow-2xl hover:shadow-primary-dark/20">
          <img
            src="/images/dewa-hq-1.jpg"
            alt="Architectural solar integration on a Dubai landmark"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
            decoding="async"
            onerror="this.remove()"
          />
          <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-primary-dark/70 to-transparent" aria-hidden="true"></div>
          <figcaption class="absolute left-4 bottom-3 inline-flex items-center rounded-md bg-accent px-3 py-1.5 text-xs font-semibold text-primary-dark shadow">
            DEWA HQ — Al Shera Building, Jaddaf
          </figcaption>
        </div>
      </figure>
    </div>
  </Container>
</section>
