---
import Container from "../../primitives/Container.astro";

const regions = [
  {
    flag: "🇦🇪",
    name: "UAE & GCC",
    badge: "HQ",
    countries: "UAE · Saudi Arabia · Bahrain · Oman · Qatar · Kuwait",
    projects: "180+",
    capacity: "750 MWp+",
    description: "Our largest operational hub, serving government utilities, real estate developers, and industrial clients across the Emirates, Saudi Arabia, and the wider Gulf.",
  },
  {
    flag: "🇮🇳",
    name: "India & South Asia",
    badge: null,
    countries: "India · Bangladesh · Sri Lanka · Nepal",
    projects: "120+",
    capacity: "400 MWp+",
    description: "From utility-scale solar parks to rural microgrids, our India operations deliver cost-effective renewable infrastructure in one of the world's fastest-growing solar markets.",
  },
  {
    flag: "🇸🇬",
    name: "Southeast Asia & Pacific",
    badge: null,
    countries: "Singapore · Malaysia · Indonesia · Philippines · Maldives",
    projects: "50+",
    capacity: "50 MWp+",
    description: "Headquartered in Singapore, we serve island nations, urban developments, and industrial parks across Southeast Asia with tailored solar, storage, and water solutions.",
  },
];
---

<section class="section-pad bg-surface border-t border-primary/8" aria-labelledby="footprint-title">
  <Container>

    <!-- Section header -->
    <div class="max-w-xl mx-auto text-center reveal">
      <p class="eyebrow">Global Footprint</p>
      <h2 id="footprint-title" class="fluid-h2 mt-3 text-primary-dark">Embedded where it matters.</h2>
      <p class="mt-4 text-sm text-muted leading-relaxed max-w-sm mx-auto">
        Operational leadership in key geographies enables rapid response, deep local expertise, and world-class execution.
      </p>
    </div>

    <!-- Cards — unified panel -->
    <div class="mt-12 grid md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-primary/10 rounded-2xl overflow-hidden ring-1 ring-primary/12 bg-white shadow-card reveal-stagger">
      {regions.map((r) => (
        <article class="flex flex-col hover:bg-primary/[0.018] transition-colors duration-300">

          <!-- Zone 1: Identity -->
          <div class="px-6 pt-6 pb-5">
            <div class="flex items-center justify-between gap-2">
              <div class="flex items-center gap-2.5 min-w-0">
                <span class="text-xl leading-none shrink-0" aria-hidden="true">{r.flag}</span>
                <h3 class="font-display text-base font-semibold text-primary-dark leading-tight truncate">
                  {r.name}
                </h3>
              </div>
              {r.badge && (
                <span class="shrink-0 inline-flex items-center rounded bg-primary-dark px-2 py-0.5 text-[9px] font-bold uppercase tracking-[0.14em] text-white">
                  {r.badge}
                </span>
              )}
            </div>
            <p class="mt-2 text-[11px] text-muted tracking-wide leading-snug">
              {r.countries}
            </p>
          </div>

          <!-- Divider -->
          <div class="h-px bg-primary/8 mx-6"></div>

          <!-- Zone 2: Metrics -->
          <div class="px-6 py-5 grid grid-cols-2">
            <div class="pr-5">
              <p class="text-[10px] uppercase tracking-[0.12em] text-muted font-medium">Projects</p>
              <p class="mt-1.5 font-display text-2xl font-bold text-primary-dark tabular-nums leading-none">
                {r.projects}
              </p>
            </div>
            <div class="pl-5 border-l border-primary/10">
              <p class="text-[10px] uppercase tracking-[0.12em] text-muted font-medium">Capacity</p>
              <p class="mt-1.5 font-display text-2xl font-bold text-primary-dark tabular-nums leading-none">
                {r.capacity}
              </p>
            </div>
          </div>

          <!-- Divider -->
          <div class="h-px bg-primary/8 mx-6"></div>

          <!-- Zone 3: Description -->
          <div class="px-6 pt-4 pb-6 flex-1">
            <p class="text-sm text-muted leading-relaxed">{r.description}</p>
          </div>

        </article>
      ))}
    </div>

  </Container>
</section>
