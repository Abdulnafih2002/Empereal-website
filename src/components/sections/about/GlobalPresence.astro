---
import Container from "../../primitives/Container.astro";

const locations = [
  { name: "Singapore", role: "Founding headquarters" },
  { name: "Dubai, UAE", role: "UAE & GCC hub" },
  { name: "Mumbai, India", role: "India & South Asia" },
  { name: "United States", role: "Market development" },
  { name: "Riyadh, Saudi Arabia", role: "Saudi Arabia" },
];
---
<section class="section-pad bg-primary-dark text-white" aria-labelledby="global-presence-title">
  <Container>
    <div class="max-w-2xl mx-auto text-center reveal">
      <p class="eyebrow !text-accent">Where We Operate</p>
      <h2 id="global-presence-title" class="fluid-h2 mt-3 text-white">Global presence, local expertise</h2>
      <p class="fluid-lead mt-5 text-white/75">
        Empereal nurtures and enriches leadership teams in each geography, cultivating practices that work best in each country.
      </p>
    </div>

    <ul class="mt-10 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-3 lg:grid-cols-5 gap-4 reveal-stagger">
      {locations.map((loc) => (
        <li class="rounded-xl bg-white/5 border border-white/10 px-4 py-5 text-center hover:bg-white/[0.08] transition-colors">
          <div class="mx-auto h-5 w-5 rounded-full bg-accent/80" aria-hidden="true"></div>
          <p class="mt-3 text-sm font-semibold text-white">{loc.name}</p>
          <p class="mt-1 text-xs text-white/65">{loc.role}</p>
        </li>
      ))}
    </ul>
  </Container>
</section>
