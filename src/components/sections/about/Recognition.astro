---
import Container from "../../primitives/Container.astro";

const awards = [
  { top: "MESIA Awards", bot: "Commercial & Industrial Project of the Year" },
  { top: "GCC Region", bot: "Multiple Solar & BIPV Project Awards" },
  { top: "Safety Record", bot: "Zero Lost Time Injuries on High-Risk EPC Projects" },
];
---
<section class="bg-primary-dark/95 text-white border-t border-accent/10 py-6 overflow-hidden" aria-label="Recognition and awards">
  <Container class="flex flex-col sm:flex-row sm:items-center gap-4">
    <p class="text-xs font-semibold uppercase tracking-[0.15em] text-white/55 shrink-0">Recognition</p>

    <div class="marquee group relative flex-1 min-w-0 overflow-hidden">
      <ul class="marquee-track flex gap-2 w-max" aria-hidden="false">
        {[...awards, ...awards].map((a, i) => (
          <li
            class="shrink-0 rounded-md bg-white/5 border border-accent/30 px-3.5 py-2"
            aria-hidden={i >= awards.length ? "true" : "false"}
          >
            <p class="text-xs font-semibold text-accent leading-tight whitespace-nowrap">{a.top}</p>
            <p class="text-[11px] text-white/65 mt-0.5 leading-tight whitespace-nowrap">{a.bot}</p>
          </li>
        ))}
      </ul>
      <div class="pointer-events-none absolute inset-y-0 left-0 w-12 bg-gradient-to-r from-primary-dark to-transparent" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 w-12 bg-gradient-to-l from-primary-dark to-transparent" aria-hidden="true"></div>
    </div>
  </Container>
</section>

<style>
  @keyframes marquee-x {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .marquee-track {
    animation: marquee-x 28s linear infinite;
    will-change: transform;
  }
  .marquee:hover .marquee-track {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
