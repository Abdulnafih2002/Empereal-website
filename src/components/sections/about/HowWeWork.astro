---
import Container from "../../primitives/Container.astro";

const principles = [
  {
    num: "01",
    title: "Founder-led strategic direction",
    body: "Long-term vision combined with deep technical and market understanding across every geography we serve.",
  },
  {
    num: "02",
    title: "Local operational leadership",
    body: "Regional teams empowered with global standards and deep local intelligence.",
  },
  {
    num: "03",
    title: "Diversity of thought & collaboration",
    body: "Deliberate inclusion of varied perspectives to solve complex infrastructure challenges.",
  },
  {
    num: "04",
    title: "Innovation with accountability",
    body: "New technologies and methods are rigorously tested before deployment at client sites.",
  },
  {
    num: "05",
    title: "Full-lifecycle responsibility",
    body: "We remain accountable from concept through design, construction, and long-term O&M.",
  },
  {
    num: "06",
    title: "Design-first methodology",
    body: "Every project begins with architectural vision and rigorous engineering — not equipment selection.",
  },
];
---
<section class="section-pad bg-surface" aria-labelledby="how-we-work-title">
  <Container>
    <div class="max-w-2xl mx-auto text-center reveal">
      <p class="eyebrow">How We Work</p>
      <h2 id="how-we-work-title" class="fluid-h2 mt-3">
        Founder-led.<br class="hidden sm:inline" />Expertise-driven.<br class="hidden sm:inline" />Accountable at every level.
      </h2>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3 reveal-stagger">
      {principles.map((p) => (
        <article class="group relative rounded-xl bg-white ring-1 ring-primary/10 p-6 sm:p-7 hover:ring-accent/40 hover:shadow-card-lg hover:-translate-y-0.5 transition-all duration-300">
          <div class="flex items-center gap-3">
            <span class="icon-lift inline-flex items-center justify-center h-9 w-9 rounded-lg bg-accent/15 text-accent-dark font-display text-sm font-semibold tabular-nums" aria-hidden="true">
              {p.num}
            </span>
            <span class="h-px flex-1 bg-primary/10" aria-hidden="true"></span>
          </div>
          <h3 class="mt-5 text-base sm:text-lg font-semibold text-primary-dark">{p.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{p.body}</p>
        </article>
      ))}
    </div>
  </Container>
</section>
