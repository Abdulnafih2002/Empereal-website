---
import Container from "../../primitives/Container.astro";

const principles = [
  {
    num: "01",
    title: "Founder-Led Strategic Direction",
    body: "Strategic decisions are guided by deep technical knowledge and real market experience across every region we operate in.",
  },
  {
    num: "02",
    title: "Regional Expertise with Global Standards",
    body: "Our local teams combine strong on-ground understanding with rigorous international processes and quality benchmarks.",
  },
  {
    num: "03",
    title: "Collaborative Problem Solving",
    body: "We bring together diverse expertise to tackle complex infrastructure challenges with practical, well-engineered solutions.",
  },
  {
    num: "04",
    title: "Tested Innovation",
    body: "New technologies and methods are thoroughly evaluated and proven before being applied on client projects.",
  },
  {
    num: "05",
    title: "Full-Lifecycle Accountability",
    body: "We remain responsible from initial concept through design, construction, and long-term operations and maintenance.",
  },
  {
    num: "06",
    title: "Design-First Approach",
    body: "Every project begins with architectural intent and rigorous engineering — not equipment selection.",
  },
];
---
<section class="section-pad bg-surface" aria-labelledby="how-we-work-title">
  <Container>
    <div class="max-w-2xl mx-auto text-center reveal">
      <p class="eyebrow">How We Work</p>
      <h2 id="how-we-work-title" class="fluid-h2 mt-3 text-balance">
        Founder-Led. Expertise-Driven. Accountable at Every Level.
      </h2>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3 reveal-stagger">
      {principles.map((p) => (
        <article class="group relative rounded-xl bg-white ring-1 ring-primary/10 p-6 sm:p-7 hover:ring-accent/40 hover:shadow-card-lg hover:-translate-y-0.5 transition-all duration-300">
          <div class="flex items-center gap-3">
            <span class="icon-lift inline-flex items-center justify-center h-9 w-9 rounded-lg bg-accent/15 text-accent-dark font-display text-sm font-semibold tabular-nums" aria-hidden="true">
              {p.num}
            </span>
            <span class="h-px flex-1 bg-primary/10" aria-hidden="true"></span>
          </div>
          <h3 class="mt-5 text-base sm:text-lg font-semibold text-primary-dark">{p.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{p.body}</p>
        </article>
      ))}
    </div>
  </Container>
</section>
