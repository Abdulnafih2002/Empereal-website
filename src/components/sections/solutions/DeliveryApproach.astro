---
import Container from "../../primitives/Container.astro";

const engagementModels = [
  {
    num: "1",
    title: "Design & Consultancy Only",
    desc: "Independent engineering, resource assessment, generation studies, and system design — bankable technical work you can take to any contractor, with no construction commitment required.",
    href: "/solutions/design-consultancy",
  },
  {
    num: "2",
    title: "Full End-to-End EPC",
    desc: "Complete project lifecycle delivery under one accountable team — from initial feasibility through construction, commissioning, and long-term O&M. No vendor handoffs, no delivery gaps, one point of contact throughout.",
    href: "/solutions/full-epc",
  },
];
---
<section class="section-pad bg-[#003B64] text-white" aria-labelledby="delivery-approach-title">
  <Container>
    <div class="max-w-2xl mx-auto text-center reveal">
      <p class="eyebrow !text-accent">How You Can Engage Us</p>
      <h2 id="delivery-approach-title" class="fluid-h2 mt-3 text-white">Choose Your Engagement Model</h2>
      <p class="fluid-lead mt-5 text-white/75">
        Every client's starting point is different. Whether you need independent engineering or complete end-to-end ownership, Empereal adapts to how you want to build.
      </p>
    </div>

    <div class="relative mx-auto mt-12 grid max-w-4xl gap-8 md:grid-cols-2 reveal-stagger">
      <div class="hidden md:block absolute top-6 left-1/4 right-1/4 h-px bg-accent/30" aria-hidden="true"></div>

      {engagementModels.map((model) => (
        <a href={model.href} class="group relative flex flex-col items-center rounded-xl px-4 pb-4 text-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-4 focus-visible:ring-offset-[#003B64]">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-accent text-primary-dark font-display text-lg font-semibold shadow-lg shadow-accent/30 relative z-10" aria-hidden="true">
            {model.num}
          </div>
          <h3 class="mt-5 text-base font-semibold text-white transition-colors group-hover:text-accent">{model.title}</h3>
          <p class="mt-2 max-w-sm text-sm leading-relaxed text-white/70">{model.desc}</p>
        </a>
      ))}
    </div>
  </Container>
</section>
