---
import Container from "../../primitives/Container.astro";

const sectors = [
  {
    title: "Government & Municipal",
    desc: "Net-zero public buildings, solar parks, and sustainable water infrastructure for government entities and municipalities.",
    icon: "/images/Who%20we%20serve%20icons/government-municipal.webp",
  },
  {
    title: "Commercial & Industrial",
    desc: "Rooftop solar, energy cost reduction, green building certification, and demand management for factories, warehouses, and offices.",
    icon: "/images/Who%20we%20serve%20icons/commercial-industrial.webp",
  },
  {
    title: "Residential & Hospitality",
    desc: "Solar carports, BIPV façades, off-grid resort solutions, and fully renewable power and water systems for tourism developments.",
    icon: "/images/Who%20we%20serve%20icons/residential-hospitality.webp",
  },
  {
    title: "Utility-Scale Power",
    desc: "Multi-MW solar farms, grid-connected generation assets, and large-scale solar parks for national utilities and independent power producers.",
    icon: "/images/Who%20we%20serve%20icons/utility-scale-power.webp",
  },
  {
    title: "Industrial Water",
    desc: "Effluent recovery, demineralized water production, cooling tower blowdown treatment, and boiler feedwater for industrial facilities.",
    icon: "/images/Who%20we%20serve%20icons/industrial-water.webp",
  },
  {
    title: "Transportation Infrastructure",
    desc: "Solar-powered bus depots, metro facilities, airport energy systems, EV charging infrastructure, and tram operations.",
    icon: "/images/Who%20we%20serve%20icons/transportation-infrastructure.webp",
  },
];
---
<section class="section-pad bg-surface" aria-labelledby="sectors-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow">Who We Serve</p>
      <h2 id="sectors-title" class="fluid-h2 mt-3">Applications & Sectors</h2>
      <p class="fluid-lead mt-5 text-muted">
        Empereal delivers engineered systems across government, commercial, industrial, and infrastructure sectors — from feasibility through lifetime O&M.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 reveal-stagger">
      {sectors.map((s) => (
        <article class="group rounded-xl bg-white ring-1 ring-primary/10 p-5 sm:p-6 hover:ring-accent/40 hover:shadow-card hover:-translate-y-0.5 transition-all duration-300">
          <div class="icon-lift inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent/15" aria-hidden="true">
            <img src={s.icon} alt="" class="h-8 w-8 object-contain" loading="lazy" decoding="async" />
          </div>
          <h3 class="mt-4 text-base font-semibold text-primary-dark">{s.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{s.desc}</p>
        </article>
      ))}
    </div>
  </Container>
</section>
