---
import Container from "../../primitives/Container.astro";
import type { Solution } from "../../../lib/types.js";

interface Props {
  solutions: Solution[];
}
const { solutions } = Astro.props;

const serviceIconRoot = "/images/Service%20icons/Services";
const howWeServeIconRoot = "/images/Service%20icons/How%20we%20serve";
const serviceIcons: Record<string, string> = {
  solar: `${serviceIconRoot}/solar-pv.webp`,
  drop: `${serviceIconRoot}/water-desalination.webp`,
  battery: `${serviceIconRoot}/energy-storage.webp`,
  hub: `${howWeServeIconRoot}/full-epc.webp`,
  bipv: `${serviceIconRoot}/architecture-bipv.webp`,
  h2: `${serviceIconRoot}/green-hydrogen.webp`,
};

const getServiceIcon = (solution: Solution) =>
  serviceIcons[solution.icon ?? ""] ?? `${serviceIconRoot}/solar-pv.webp`;
---
<section class="section-pad bg-white" aria-labelledby="solution-areas-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow">What We Deliver</p>
      <h2 id="solution-areas-title" class="fluid-h2 mt-3">Our Solution Areas</h2>
      <p class="fluid-lead mt-5 text-muted">
        Government entities, developers, industrial operators, and infrastructure stakeholders who require bankable, engineered systems — not just vendor products.
      </p>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2 reveal-stagger">
      {solutions.map((a) => (
        <a
          href={a.href ?? "#"}
          class="group flex gap-4 rounded-xl bg-white ring-1 ring-primary/10 p-5 sm:p-6 hover:ring-accent hover:shadow-card-lg transition-all"
        >
          <div class="shrink-0 inline-flex h-11 w-11 items-center justify-center rounded-lg bg-accent/15" aria-hidden="true">
            <img src={getServiceIcon(a)} alt="" class="h-8 w-8 object-contain" loading="lazy" decoding="async" />
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="flex items-center justify-between gap-3 text-base font-semibold text-primary-dark">
              <span>{a.title}</span>
              <span class="text-muted group-hover:text-accent transition-colors shrink-0" aria-hidden="true">
                <svg viewBox="0 0 20 20" class="h-4 w-4 arrow-slide" fill="none">
                  <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{a.description}</p>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>
