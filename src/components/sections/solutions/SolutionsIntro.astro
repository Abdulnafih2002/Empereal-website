---
import Container from "../../primitives/Container.astro";
---
<section class="section-pad bg-white" aria-labelledby="solutions-intro-title">
  <Container>
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
      <div class="reveal-left">
        <p class="eyebrow">Full-Lifecycle Engineering Services</p>
        <h2 id="solutions-intro-title" class="fluid-h2 mt-3">One Partner. Every Discipline.</h2>
        <p class="fluid-lead mt-6 text-muted max-w-xl">
          Empereal delivers end-to-end solutions across the complete project lifecycle — from architectural and engineering design, through EPC (Engineering, Procurement & Construction), to long-term Operations & Maintenance.
        </p>
        <p class="mt-4 text-muted max-w-xl">
          We provide integrated expertise in Solar Power, Energy Storage, Solar Thermal & Desalination, Green Hydrogen, and Architectural BIPV.
        </p>
        <p class="mt-4 text-muted max-w-xl">
          No vendor handoffs. No delivery gaps. Just one accountable team guiding your project from initial feasibility to 25-year performance optimization.
        </p>
      </div>

      <figure class="group relative reveal-right">
        <div class="hover-zoom relative overflow-hidden rounded-2xl aspect-[4/3] shadow-card-lg ring-1 ring-primary/5 bg-gradient-to-br from-primary via-primary-light to-accent/30 transition-shadow duration-500 hover:shadow-2xl hover:shadow-primary-dark/20">
          <img
            src="/images/masdar-10mw.jpg"
            alt="Empereal engineering team on a solar EPC project site"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
            decoding="async"
            onerror="this.remove()"
          />
          <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-primary-dark/70 to-transparent" aria-hidden="true"></div>
          <figcaption class="absolute left-4 bottom-3 inline-flex items-center rounded-md bg-accent px-3 py-1.5 text-xs font-semibold text-primary-dark shadow">
            Engineering-led EPC delivery
          </figcaption>
        </div>
      </figure>
    </div>
  </Container>
</section>
