---
import Container from "../../primitives/Container.astro";

const cards = [
  {
    title: "Solar Thermal — LFR Desalination",
    body: "Linear Fresnel Reflector (LFR) solar thermal fields generate steam at 98°C to drive multi-effect distillation (MED) desalination. Patented direct saturated steam-generating technology with thermal storage for uninterrupted operation.",
    tag: "Patented Technology",
    icon: "lfr",
  },
  {
    title: "PV-Powered Reverse Osmosis",
    body: "Photovoltaic arrays power reverse osmosis (RO) membranes to produce fresh water from seawater or brackish water. Suitable for off-grid and grid-connected configurations, from 1,000 to 1,000,000+ litres per day.",
    tag: "Grid & Off-Grid",
    icon: "pvro",
  },
  {
    title: "Forward Osmosis & Hybrid Systems",
    body: "Forward osmosis systems for industrial effluent recovery and low-energy desalination. Solar-biomass hybrid configurations for round-the-clock fresh water production without battery storage in remote applications.",
    tag: "Hybrid & Industrial",
    icon: "fo",
  },
];
---
<section class="section-pad bg-surface" aria-labelledby="water-tech-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow">Core technologies</p>
      <h2 id="water-tech-title" class="fluid-h2 mt-3">Three solar desalination pathways</h2>
      <p class="fluid-lead mt-5 text-muted">
        Empereal selects and designs the appropriate desalination technology based on the specific energy source, water quality requirements, and scale of the project.
      </p>
    </div>

    <ul class="mt-10 grid gap-4 md:grid-cols-3 reveal-stagger">
      {cards.map((c) => (
        <li class="group rounded-2xl bg-white ring-1 ring-primary/10 p-6 hover:ring-accent/40 hover:shadow-card-lg hover:-translate-y-0.5 transition-all">
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent/15 text-accent-dark icon-lift">
            {c.icon === "lfr" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none" aria-hidden="true">
                <path d="M3 9 Q5 5 10 5 Q15 5 17 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <rect x="3" y="9" width="14" height="6" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <line x1="10" y1="5" x2="10" y2="9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            )}
            {c.icon === "pvro" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none" aria-hidden="true">
                <rect x="2" y="7" width="16" height="3" rx="1" fill="currentColor" opacity=".7"/>
                <rect x="2" y="11" width="16" height="3" rx="1" fill="currentColor" opacity=".4"/>
                <circle cx="10" cy="3" r="2" stroke="currentColor" stroke-width="1.4"/>
                <line x1="10" y1="1" x2="10" y2="7" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
              </svg>
            )}
            {c.icon === "fo" && (
              <svg viewBox="0 0 20 20" class="h-5 w-5" fill="none" aria-hidden="true">
                <path d="M10 3 Q14 7 14 11 A4 4 0 0 1 6 11 Q6 7 10 3Z" stroke="currentColor" stroke-width="1.4"/>
                <line x1="6" y1="11" x2="14" y2="11" stroke="currentColor" stroke-width=".8" opacity=".5"/>
                <line x1="5" y1="15" x2="15" y2="15" stroke="currentColor" stroke-width=".8" opacity=".4"/>
              </svg>
            )}
          </div>
          <h3 class="mt-5 text-base font-semibold text-primary-dark">{c.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{c.body}</p>
          <span class="mt-4 inline-block text-[10px] font-semibold uppercase tracking-[0.08em] px-2 py-0.5 rounded border border-accent/30 text-accent-dark bg-accent-soft">
            {c.tag}
          </span>
        </li>
      ))}
    </ul>
  </Container>
</section>
