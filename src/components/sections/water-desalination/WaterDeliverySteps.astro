---
import Container from "../../primitives/Container.astro";

const steps = [
  {
    n: "1",
    title: "Water Source Assessment",
    desc: "Analysis of source water quality, volume requirements, and site conditions.",
  },
  {
    n: "2",
    title: "Technology Selection",
    desc: "Choosing optimal solar-thermal, PV-RO, or hybrid configuration.",
  },
  {
    n: "3",
    title: "System Design & Integration",
    desc: "Engineering water treatment with solar energy generation.",
  },
  {
    n: "4",
    title: "Installation & Commissioning",
    desc: "Deploying treatment units with performance verification.",
  },
  {
    n: "5",
    title: "Ongoing Monitoring & Maintenance",
    desc: "Ensuring water quality compliance and system uptime.",
  },
];
---
<section class="section-pad bg-[#003B64] text-white" aria-labelledby="water-delivery-title">
  <Container>
    <div class="text-center max-w-2xl mx-auto reveal">
      <p class="eyebrow !text-accent">How we deliver</p>
      <h2 id="water-delivery-title" class="fluid-h2 mt-3 text-white">Our water project process</h2>
      <p class="fluid-lead mt-5 text-white/60">
        A rigorous, phased approach managed under ISO-certified systems.
      </p>
    </div>

    <ol class="mt-12 grid gap-8 sm:gap-4 sm:grid-cols-2 lg:grid-cols-5 relative reveal-stagger">
      <span aria-hidden="true" class="hidden lg:block absolute top-[18px] left-[10%] right-[10%] h-px bg-accent/25"></span>
      {steps.map((s) => (
        <li class="flex flex-col items-center text-center px-2 relative">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-accent text-primary-dark font-semibold shadow-md shadow-accent/30 ring-4 ring-[#003B64]">
            {s.n}
          </span>
          <h3 class="mt-4 text-sm font-semibold text-white">{s.title}</h3>
          <p class="mt-1.5 text-xs text-white/50 leading-relaxed">{s.desc}</p>
        </li>
      ))}
    </ol>
  </Container>
</section>
