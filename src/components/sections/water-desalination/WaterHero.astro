---
import Container from "../../primitives/Container.astro";

---
<section
  class="page-hero relative isolate overflow-hidden bg-primary-dark text-white flex flex-col"
  aria-labelledby="water-hero-title"
>
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <img
      src="/images/water-desalination.webp"
      alt=""
      class="h-full w-full object-cover opacity-90"
      loading="eager"
      decoding="async"
      onerror="this.remove()"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#003B64] via-[#003B64]/80 to-[#003B64]/40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-primary-dark/30 via-transparent to-primary-dark/70"></div>
    <div class="absolute -bottom-32 -left-32 h-[480px] w-[480px] rounded-full bg-cta/15 blur-[140px] animate-pulse-glow"></div>

  </div>

  <Container class="relative flex-1 flex items-start pt-32 sm:items-center sm:pt-0">
    <div class="pb-16 sm:py-20 lg:py-24 max-w-3xl">
      <p class="eyebrow !text-accent hero-enter hero-enter-1">Water Desalination</p>
      <h1 id="water-hero-title" class="fluid-display mt-4 text-white hero-enter hero-enter-2">
        Sustainable water from<br/>
        <span class="text-accent">clean energy.</span>
      </h1>
      <p class="fluid-lead mt-6 text-white/80 max-w-2xl hero-enter hero-enter-3">
        Solar thermal and photovoltaic-powered desalination systems — delivering fresh water from seawater and brackish sources to ultra-pure industrial process water, without fossil fuels.
      </p>
      <p class="mt-3 max-w-2xl text-base font-medium text-white/85 hero-enter hero-enter-3">
        Proven solar desalination technology, operational since 2013.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row flex-wrap gap-3 hero-enter hero-enter-4">
        <a
          href="/projects?filter=desalination"
          class="hero-home-pill"
        >
          View Desalination Projects
        </a>
      </div>

    </div>
  </Container>
</section>

<style>
  .page-hero {
    min-height: calc(100vh - 6rem);
    min-height: calc(100svh - 6rem);
    min-height: calc(100dvh - 6rem);
  }
  @media (min-width: 1024px) {
    .page-hero {
      min-height: calc(100vh - 7rem);
      min-height: calc(100svh - 7rem);
      min-height: calc(100dvh - 7rem);
    }
  }
</style>
