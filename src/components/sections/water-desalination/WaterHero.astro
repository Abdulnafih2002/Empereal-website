---
import Container from "../../primitives/Container.astro";

const stats = [
  { num: "150,000 L/day", lbl: "Largest single plant" },
  { num: "Since 2013", lbl: "Operational plants" },
  { num: "Patented", lbl: "LFR technology" },
];
---
<section
  class="page-hero relative isolate overflow-hidden bg-primary-dark text-white flex flex-col"
  aria-labelledby="water-hero-title"
>
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <img
      src="/images/jeddah-oceanarium.jpg"
      alt=""
      class="h-full w-full object-cover opacity-90"
      loading="eager"
      decoding="async"
      onerror="this.remove()"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#0B2338] via-[#0B2338]/80 to-[#0B2338]/40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-primary-dark/30 via-transparent to-primary-dark/70"></div>
    <div class="absolute -bottom-32 -left-32 h-[480px] w-[480px] rounded-full bg-cta/15 blur-[140px] animate-pulse-glow"></div>

    <div class="hidden lg:block absolute right-2 top-1/2 -translate-y-1/2 w-[420px] h-[400px] opacity-[0.10] animate-float">
      <svg width="100%" height="100%" viewBox="0 0 240 220" fill="none" preserveAspectRatio="xMidYMid meet">
        <path d="M120 20 Q160 70 160 120 A40 40 0 0 1 80 120 Q80 70 120 20Z" stroke="#F5B82E" stroke-width=".8" fill="none"/>
        <path d="M120 50 Q148 88 148 118 A28 28 0 0 1 92 118 Q92 88 120 50Z" stroke="#F5B82E" stroke-width=".5" fill="none" opacity=".5"/>
        <path d="M40 160 Q70 150 100 160 Q130 170 160 160 Q190 150 220 160" stroke="#F5B82E" stroke-width=".7" fill="none"/>
        <path d="M40 175 Q70 165 100 175 Q130 185 160 175 Q190 165 220 175" stroke="#F5B82E" stroke-width=".6" fill="none" opacity=".6"/>
        <path d="M40 190 Q70 180 100 190 Q130 200 160 190 Q190 180 220 190" stroke="#F5B82E" stroke-width=".5" fill="none" opacity=".4"/>
        <circle cx="50" cy="40" r="14" stroke="#F5B82E" stroke-width=".8"/>
        <line x1="50" y1="20" x2="50" y2="16" stroke="#F5B82E" stroke-width=".8" stroke-linecap="round"/>
        <line x1="30" y1="40" x2="26" y2="40" stroke="#F5B82E" stroke-width=".8" stroke-linecap="round"/>
        <line x1="70" y1="40" x2="74" y2="40" stroke="#F5B82E" stroke-width=".8" stroke-linecap="round"/>
      </svg>
    </div>
  </div>

  <Container class="relative flex-1 flex items-center">
    <div class="py-16 sm:py-20 lg:py-24 max-w-3xl">
      <p class="eyebrow !text-white hero-enter hero-enter-1">Water &amp; Desalination · Solar-Powered Fresh Water</p>
      <h1 id="water-hero-title" class="fluid-display mt-4 text-white hero-enter hero-enter-2">
        Sustainable water from<br/>
        <span class="text-accent">clean energy.</span>
      </h1>
      <p class="fluid-lead mt-6 text-white/80 max-w-2xl hero-enter hero-enter-3">
        Solar thermal and photovoltaic-powered desalination systems — from seawater to ultra-pure process water, without fossil fuel dependency. Patented technology, operational since 2013.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row flex-wrap gap-3 hero-enter hero-enter-4">
        <a
          href="/contact"
          class="hero-cta press group flex items-center gap-2 rounded-md bg-accent hover:bg-accent-dark px-6 py-3.5 text-sm sm:text-base font-semibold text-primary-dark transition-colors min-h-[48px] shadow-lg shadow-accent/20 text-center"
        >
          Request a Consultation
          <svg viewBox="0 0 20 20" class="h-4 w-4 arrow-slide shrink-0" fill="none" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a
          href="/projects?filter=desalination"
          class="hero-cta press flex items-center gap-2 rounded-md border border-white/25 bg-white/5 hover:bg-white/10 px-6 py-3.5 text-sm sm:text-base text-white transition-colors min-h-[48px] text-center"
        >
          View Desalination Projects
        </a>
      </div>

      <dl class="mt-10 grid grid-cols-3 gap-px rounded-xl overflow-hidden border border-white/10 max-w-xl bg-white/[0.04] hero-enter hero-enter-4">
        {stats.map((s) => (
          <div class="bg-primary-dark/60 backdrop-blur-sm px-4 py-4 text-center">
            <dt class="text-sm sm:text-base font-semibold text-accent leading-tight">{s.num}</dt>
            <dd class="mt-1 text-[10px] uppercase tracking-[0.08em] text-white/50">{s.lbl}</dd>
          </div>
        ))}
      </dl>
    </div>
  </Container>
</section>

<style>
  .page-hero {
    min-height: calc(100vh - 6rem);
    min-height: calc(100svh - 6rem);
    min-height: calc(100dvh - 6rem);
  }
  @media (min-width: 1024px) {
    .page-hero {
      min-height: calc(100vh - 7rem);
      min-height: calc(100svh - 7rem);
      min-height: calc(100dvh - 7rem);
    }
  }
</style>
