---
import Container from "../../primitives/Container.astro";
import ProjectCard from "../projects/ProjectCard.astro";
import { projects } from "../../../data/projects.ts";

const slugs = [
  "masdar-10mw",
  "dewa-hq",
  "masdar-mc2",
  "park-hyatt-maldives",
  "dewa-solar-tree",
];

const featured = slugs
  .map((s) => projects.find((p) => p.slug === s))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));
---
<section class="section-pad bg-white" aria-labelledby="solar-exp-title">
  <Container>
    <div class="mx-auto max-w-2xl text-center reveal">
      <p class="eyebrow">Related Projects</p>
      <h2 id="solar-exp-title" class="fluid-h2 mt-3">Selected experience</h2>
      <p class="fluid-lead mt-5 text-muted">
        A selection of Empereal's commissioned solar PV projects across Asia, the Middle East, and beyond — spanning utility-scale farms, distributed rooftops, resort microgrids, and tracking systems.
      </p>
    </div>

    <ul class="mx-auto mt-10 flex flex-wrap justify-center gap-6 reveal-stagger">
      {featured.map((project) => (
        <li class="flex w-full max-w-sm sm:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)]">
          <ProjectCard project={project} class="w-full" />
        </li>
      ))}
    </ul>

    <p class="mt-8 text-center text-sm text-muted">
      Full project portfolio available on the
      <a href="/projects" class="text-accent-dark font-semibold hover:text-accent transition-colors group inline-flex items-center gap-1">
        Projects page
        <svg viewBox="0 0 20 20" class="h-3.5 w-3.5 arrow-slide" fill="none" aria-hidden="true">
          <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </p>
  </Container>
</section>
