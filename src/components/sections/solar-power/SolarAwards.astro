---
import Container from "../../primitives/Container.astro";

const awards = [
  {
    org: "MESIA Awards",
    detail: "Commercial & Industrial Project of the Year",
  },
  {
    org: "GCC Region",
    detail: "Multiple Solar & BIPV Project Awards",
  },
  {
    org: "Safety Record",
    detail: "Zero Lost Time Injuries on High-Risk EPC Projects",
  },
];
---
<section class="bg-primary-dark/95 text-white border-t border-accent/15 py-5" aria-label="Recognition">
  <Container class="flex flex-col sm:flex-row sm:items-center gap-4">
    <p class="text-xs font-semibold uppercase tracking-[0.15em] text-white/55 shrink-0">Recognition</p>
    <ul class="flex flex-wrap gap-2 reveal-stagger">
      {awards.map((a) => (
        <li class="rounded-md bg-white/[0.04] border border-accent/20 px-3 py-2">
          <div class="text-[11px] font-semibold text-accent leading-tight">{a.org}</div>
          <div class="text-[10px] text-white/55 leading-tight mt-0.5">{a.detail}</div>
        </li>
      ))}
    </ul>
  </Container>
</section>
