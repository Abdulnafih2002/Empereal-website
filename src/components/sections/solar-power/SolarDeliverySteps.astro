---
import Container from "../../primitives/Container.astro";

const steps = [
  {
    n: "1",
    title: "Feasibility & design",
    desc: "Site assessment, resource modelling, generation studies, shading analysis, and concept system design.",
  },
  {
    n: "2",
    title: "Engineering & procurement",
    desc: "Detailed electrical and structural engineering, component sourcing from Tier-1 manufacturers with full traceability.",
  },
  {
    n: "3",
    title: "Construction & commissioning",
    desc: "Field installation, testing, grid connection, authority approvals, and handover documentation.",
  },
  {
    n: "4",
    title: "Operations & maintenance",
    desc: "Long-term O&M — performance monitoring, preventive maintenance, fault response, and yield reporting.",
  },
];
---
<section class="section-pad bg-surface text-ink" aria-labelledby="solar-delivery-title">
  <Container>
    <div class="text-center max-w-2xl mx-auto reveal">
      <p class="eyebrow">How we deliver</p>
      <h2 id="solar-delivery-title" class="fluid-h2 mt-3 text-primary-dark">Our solar EPC process</h2>
      <p class="fluid-lead mt-5 text-muted">
        Every solar project follows a rigorous phased process managed under ISO 9001:2015, ISO 14001:2015, and ISO 45001:2018 certified management systems.
      </p>
    </div>

    <ol class="mt-12 grid gap-8 sm:gap-4 sm:grid-cols-2 lg:grid-cols-4 relative reveal-stagger">
      <span aria-hidden="true" class="hidden lg:block absolute top-[18px] left-[12.5%] right-[12.5%] h-px bg-accent/40"></span>
      {steps.map((s) => (
        <li class="flex flex-col items-center text-center px-2 relative">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-accent text-primary-dark font-semibold shadow-md shadow-accent/25 ring-4 ring-surface">
            {s.n}
          </span>
          <h3 class="mt-4 text-sm font-semibold text-primary-dark">{s.title}</h3>
          <p class="mt-1.5 text-xs text-muted leading-relaxed">{s.desc}</p>
        </li>
      ))}
    </ol>
  </Container>
</section>
