---
import Container from "../../primitives/Container.astro";

const cases = [
  {
    title: "Utility-scale generation",
    desc: "Multi-MW solar farms feeding into national grids. Fixed-tilt and tracker configurations. From 1 MW to 110 MWp+ delivered.",
    icon: "utility",
  },
  {
    title: "Commercial & industrial rooftops",
    desc: "Energy cost reduction for factories, warehouses, and offices — optimised for self-consumption with surplus export to the grid.",
    icon: "rooftop",
  },
  {
    title: "Government & public buildings",
    desc: "Net-zero public infrastructure with architectural solar integration — meeting green building standards and public sector targets.",
    icon: "gov",
  },
  {
    title: "Transportation infrastructure",
    desc: "Solar-powered bus depots, metro facilities, tram depots, and airport energy systems — including 11 MW across 12 RTA sites in Dubai.",
    icon: "transport",
  },
  {
    title: "Residential & mixed-use",
    desc: "Solar carports, balcony solar railings, and building-integrated facades for residential towers and master-planned communities.",
    icon: "resi",
  },
  {
    title: "Iconic architecture",
    desc: "Custom-designed solar modules integrated into landmark buildings — from the UAE Pavilion at Expo 2020 to the world's largest net-zero resort.",
    icon: "iconic",
  },
];
---
<section class="section-pad bg-[#0F2238] text-white" aria-labelledby="solar-cases-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow !text-accent">Applications</p>
      <h2 id="solar-cases-title" class="fluid-h2 mt-3 text-white">Six solar application types</h2>
      <p class="fluid-lead mt-5 text-white/60">
        Empereal's solar EPC capability spans the full range — from distributed residential systems to utility-scale assets and iconic architectural integrations.
      </p>
    </div>

    <ul class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 reveal-stagger">
      {cases.map((c) => (
        <li class="group rounded-xl bg-white/[0.04] border border-white/10 p-5 hover:bg-white/[0.07] hover:border-accent/30 transition-all">
          <div class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent/15 ring-1 ring-accent/25 text-accent icon-lift">
            {c.icon === "utility" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <path d="M2 12 L6 5 L9 9 L12 4 L18 12Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                <line x1="1" y1="16" x2="19" y2="16" stroke="currentColor" stroke-width="1.2"/>
              </svg>
            )}
            {c.icon === "rooftop" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <rect x="2" y="8" width="16" height="9" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <line x1="6" y1="8" x2="6" y2="3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                <line x1="14" y1="8" x2="14" y2="3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            )}
            {c.icon === "gov" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <rect x="2" y="6" width="16" height="11" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <path d="M4 6 L10 2 L16 6" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
              </svg>
            )}
            {c.icon === "transport" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <rect x="3" y="11" width="14" height="6" rx="1" stroke="currentColor" stroke-width="1.4"/>
                <path d="M5 11V8c0-2 2-4 5-4s5 2 5 4v3" stroke="currentColor" stroke-width="1.4"/>
              </svg>
            )}
            {c.icon === "resi" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <path d="M3 16 Q4 10 7 10 L10 5 L13 10 Q16 10 17 16Z" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linejoin="round"/>
                <line x1="2" y1="17" x2="18" y2="17" stroke="currentColor" stroke-width="1"/>
              </svg>
            )}
            {c.icon === "iconic" && (
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" aria-hidden="true">
                <path d="M10 2 L12 7 L17 8 L13 12 L14 17 L10 14 L6 17 L7 12 L3 8 L8 7Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
          <h3 class="mt-4 text-base font-semibold text-white">{c.title}</h3>
          <p class="mt-1.5 text-sm text-white/55 leading-relaxed">{c.desc}</p>
        </li>
      ))}
    </ul>
  </Container>
</section>
