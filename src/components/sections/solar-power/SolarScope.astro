---
import Container from "../../primitives/Container.astro";

const items = [
  {
    title: "Utility-scale solar PV farms",
    desc: "Development and full EPC delivery of large-scale ground-mounted solar farms, including tracker systems, civil infrastructure, and grid interconnection.",
  },
  {
    title: "Commercial & industrial rooftops",
    desc: "High-yield rooftop solar systems for factories, warehouses, and commercial buildings, optimised for maximum self-consumption and grid export.",
  },
  {
    title: "Solar carports & parking structures",
    desc: "Integrated solar carport and canopy solutions that combine clean energy generation with functional vehicle shading and premium structural design.",
  },
  {
    title: "Ground-mounted & tracking systems",
    desc: "Fixed-tilt and single-axis tracker PV systems engineered for optimal energy yield, efficient land utilisation, and long-term reliability.",
  },
  {
    title: "Feasibility & generation modelling",
    desc: "Bankable pre-development studies including solar resource assessment, P50/P90 yield modelling, shading analysis, and financial viability.",
  },
  {
    title: "Authority approvals, interconnection & O&M",
    desc: "Full regulatory management, utility interconnection, commissioning approvals, and long-term operations & maintenance services with advanced monitoring and desert-optimised cleaning systems.",
  },
];
---
<section class="section-pad bg-surface" aria-labelledby="solar-scope-title">
  <Container>
    <div class="max-w-2xl reveal">
      <p class="eyebrow">Scope of Service</p>
      <h2 id="solar-scope-title" class="fluid-h2 mt-3">What We Deliver</h2>
      <p class="fluid-lead mt-5 text-muted">
        Empereal's solar EPC scope spans the full project lifecycle — from early-stage feasibility through to long-term asset operations and performance optimisation.
      </p>
    </div>

    <ul class="mt-10 grid gap-3 sm:grid-cols-2 reveal-stagger">
      {items.map((it) => (
        <li class="flex gap-3 rounded-xl bg-white ring-1 ring-primary/10 p-4 sm:p-5 hover:ring-accent/40 hover:shadow-card transition-all">
          <span class="mt-2 inline-block h-[2px] w-4 bg-accent rounded-full shrink-0" aria-hidden="true"></span>
          <div class="min-w-0">
            <h3 class="text-sm sm:text-[15px] font-semibold text-primary-dark">{it.title}</h3>
            <p class="mt-1.5 text-sm text-muted leading-relaxed">{it.desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </Container>
</section>
