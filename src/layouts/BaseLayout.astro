---
import "../styles/globals.css";
import Header from "../components/site/Header.astro";
import Footer from "../components/site/Footer.astro";
import ClientsAndPartners from "../components/sections/shared/ClientsAndPartners.astro";
import CookieConsent from "../components/site/CookieConsent.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Empereal — Smart Solar & EPC Solutions",
  description = "A global smart solar & EPC leader delivering high-performance energy solutions across Asia and the Middle East.",
  image = "/images/dewa-hq-main.jpg",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const org = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Empereal Energy Solutions",
  url: "https://empereal.energy",
  logo: "https://empereal.energy/logo.svg",
  slogan: "Energizing Communities",
  description,
  industry: "Solar EPC · Smart Energy · Sustainability",
  sameAs: ["https://linkedin.com/company/empereal", "https://twitter.com/empereal"],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Dubai",
    addressCountry: "AE",
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: "+971-XX-XXX-XXXX",
    contactType: "sales",
    areaServed: "Middle East, Asia",
    availableLanguage: ["English", "Arabic"],
  },
};
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#1F3C5C" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preload" as="image" href="/images/sustainability-city.jpg" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(org)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <ClientsAndPartners />
    <Footer />
    <CookieConsent />

    <script>
      const reveals = document.querySelectorAll(
        ".reveal, .reveal-left, .reveal-right, .reveal-scale, .reveal-fade, .reveal-zoom, .reveal-stagger"
      );
      if (reveals.length) {
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce) {
          reveals.forEach((el) => el.classList.add("is-visible"));
        } else {
          // will-change is applied only for the duration of the reveal transition,
          // then stripped — leaving it on permanently keeps every revealed element
          // (there can be dozens per page) promoted to its own GPU layer forever,
          // which is a major source of scroll jank on mobile.
          const promote = (el: Element) => {
            const targets = el.classList.contains("reveal-stagger")
              ? Array.from(el.children)
              : [el];
            targets.forEach((t) => {
              (t as HTMLElement).style.willChange = "opacity, transform";
              const clear = () => {
                (t as HTMLElement).style.willChange = "";
                t.removeEventListener("transitionend", clear);
              };
              t.addEventListener("transitionend", clear);
              // Fallback in case transitionend never fires (e.g. element unmounted mid-transition)
              setTimeout(clear, 1200);
            });
          };
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (e.isIntersecting) {
                  promote(e.target);
                  e.target.classList.add("is-visible");
                  io.unobserve(e.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
          );
          reveals.forEach((el) => io.observe(el));
        }
      }
    </script>
  </body>
</html>
