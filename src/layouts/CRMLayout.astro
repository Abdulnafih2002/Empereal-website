---
import CRMSidebar from "../components/crm/CRMSidebar.astro";
import "../styles/globals.css";
interface Props { title: string; newEnquiries?: number }
const { title, newEnquiries = 0 } = Astro.props;
const today = new Date().toLocaleDateString("en-GB", { weekday: "short", day: "numeric", month: "short", year: "numeric" });
---
<!doctype html>
<html lang="en" class="h-full bg-slate-50">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} — Empereal CRM</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; }
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="h-full flex bg-slate-50">
  <CRMSidebar newEnquiries={newEnquiries} />

  <!-- Main content -->
  <div class="flex min-w-0 flex-1 flex-col lg:pl-64">
    <!-- Top header -->
    <header class="sticky top-0 z-10 flex h-14 shrink-0 items-center gap-4 border-b border-slate-200 bg-white px-4 shadow-sm sm:px-6">
      <!-- Hamburger (mobile only) -->
      <button
        id="sidebar-open"
        type="button"
        class="inline-flex items-center justify-center rounded-md p-2 text-slate-500 hover:bg-slate-100 hover:text-slate-700 transition-colors lg:hidden"
        aria-label="Open sidebar"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

      <!-- Page title -->
      <div class="flex flex-1 items-center gap-2 min-w-0">
        <span class="hidden text-xs text-slate-400 sm:block shrink-0">Empereal CRM</span>
        <span class="hidden text-slate-300 sm:block">/</span>
        <h1 class="truncate text-sm font-semibold text-slate-800">{title}</h1>
      </div>

      <!-- Right actions -->
      <div class="flex items-center gap-3 shrink-0">
        <span class="hidden text-xs text-slate-400 sm:block">{today}</span>
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary text-xs font-bold text-white select-none">
          A
        </div>
      </div>
    </header>

    <!-- Page content -->
    <main class="flex-1 overflow-y-auto p-4 sm:p-6">
      <slot />
    </main>
  </div>

  <!-- Mobile close button inside sidebar (injected by JS via sidebar-close id) -->
  <button
    id="sidebar-close"
    type="button"
    class="fixed top-4 right-4 z-40 hidden items-center justify-center rounded-md bg-white p-2 text-slate-500 shadow-md hover:bg-slate-50 lg:hidden"
    aria-label="Close sidebar"
    style="display:none"
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <script>
    const openBtn = document.getElementById("sidebar-open");
    const closeBtn = document.getElementById("sidebar-close");
    openBtn?.addEventListener("click", () => { closeBtn && (closeBtn.style.display = "flex"); });
    (document.getElementById("sidebar-overlay") as HTMLElement)?.addEventListener("click", () => {
      closeBtn && (closeBtn.style.display = "none");
    });
    closeBtn?.addEventListener("click", () => { closeBtn.style.display = "none"; });

    // ── Real-time enquiry polling ──────────────────────────────────────────────
    // Poll every 60 s. Updates the sidebar badge and, on the dashboard / enquiries
    // pages, shows a banner so the user can reload to see new entries.

    const POLL_MS = 60_000;
    const PAGES_WITH_TABLE = ["/crm", "/crm/enquiries"];

    let lastNewCount = -1; // -1 means "not yet known"

    function getSidebarBadge(): HTMLElement | null {
      // The badge is inside the Enquiries nav link — find it by its rounded-full class
      return document.querySelector<HTMLElement>('a[href="/crm/enquiries"] span.rounded-full');
    }

    function updateBadge(newCount: number) {
      const badge = getSidebarBadge();
      if (newCount > 0) {
        if (badge) {
          badge.textContent = String(newCount);
        } else {
          // Badge doesn't exist yet — create it inside the Enquiries link
          const link = document.querySelector<HTMLElement>('a[href="/crm/enquiries"]');
          if (link) {
            const span = document.createElement("span");
            span.className = "inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-orange px-1.5 text-xs font-bold text-white";
            span.textContent = String(newCount);
            link.appendChild(span);
          }
        }
      } else if (badge) {
        badge.remove();
      }
    }

    function showRefreshBanner(added: number) {
      if (document.getElementById("eq-refresh-banner")) return; // already shown
      const banner = document.createElement("div");
      banner.id = "eq-refresh-banner";
      banner.className = "fixed bottom-5 right-5 z-50 flex items-center gap-3 rounded-xl bg-primary text-white px-5 py-3.5 shadow-lg text-sm font-medium cursor-pointer";
      banner.innerHTML = `
        <svg class="h-4 w-4 shrink-0 text-orange" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v4.59L7.3 9.24a.75.75 0 00-1.1 1.02l3.25 3.5a.75.75 0 001.1 0l3.25-3.5a.75.75 0 10-1.1-1.02l-1.95 2.1V6.75z" clip-rule="evenodd"/>
        </svg>
        <span>${added} new enquir${added === 1 ? "y" : "ies"} — click to refresh</span>
        <button class="ml-1 text-white/50 hover:text-white" aria-label="Dismiss">✕</button>
      `;
      banner.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).tagName === "BUTTON") {
          banner.remove();
        } else {
          window.location.reload();
        }
      });
      document.body.appendChild(banner);
    }

    async function poll() {
      try {
        const res = await fetch("/api/crm/enquiries", { cache: "no-store" });
        if (!res.ok) return;
        const enquiries = await res.json() as Array<{ status: string }>;
        const newCount = enquiries.filter((e) => e.status === "new").length;

        updateBadge(newCount);

        const path = window.location.pathname.replace(/\/$/, "") || "/crm";
        const onTablePage = PAGES_WITH_TABLE.some((p) => path === p || path.startsWith(p + "?"));

        if (lastNewCount !== -1 && newCount > lastNewCount && onTablePage) {
          showRefreshBanner(newCount - lastNewCount);
        }

        lastNewCount = newCount;
      } catch {
        // silently ignore network errors
      }
    }

    // First poll after a short delay so the page fully renders first
    setTimeout(poll, 3000);
    setInterval(poll, POLL_MS);
  </script>
</body>
</html>
